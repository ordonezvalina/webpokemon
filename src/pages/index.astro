---
import "../styles/global.css";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Catalogo personal de figuras Pokemon Tomy Moncolle y variantes."
    />
    <title>Catalogo Tomy Pokemon</title>
  </head>
  <body class="bg-zinc-950 text-zinc-100 antialiased">
    <!-- Ambient background glow -->
    <div class="pointer-events-none fixed inset-0 -z-10 bg-[radial-gradient(ellipse_80%_50%_at_50%_-10%,rgba(120,100,60,0.12),transparent)]"></div>
    <main class="mx-auto flex min-h-screen w-full max-w-7xl flex-col px-4 pb-24 pt-5 sm:px-6 lg:px-8">
      <header class="mb-5 flex flex-col gap-4 sm:mb-8 sm:flex-row sm:items-end sm:justify-between">
        <div class="space-y-2">
          <p class="text-xs font-semibold uppercase tracking-[0.22em] text-amber-300">
            Tomy Moncolle Archive
          </p>
          <h1 class="max-w-3xl text-4xl font-semibold leading-tight tracking-tight sm:text-6xl">
            <span class="bg-gradient-to-br from-white via-zinc-100 to-zinc-400 bg-clip-text text-transparent">Coleccion Pokemon</span>
          </h1>
          <p class="max-w-2xl text-sm leading-6 text-zinc-400 sm:text-base">
            Catálogo de mi coleccion personal de figuras Tomy.
          </p>
        </div>

        <div class="grid grid-cols-3 gap-2 rounded-xl border border-zinc-800/60 bg-zinc-900/60 p-2 text-center shadow-2xl shadow-black/40 backdrop-blur-sm">
          <div class="px-3 py-2">
            <p id="total-count" class="text-xl font-semibold text-white">0</p>
            <p class="text-[11px] uppercase tracking-[0.16em] text-zinc-500">Figuras</p>
          </div>
          <div class="border-x border-zinc-800 px-3 py-2">
            <p id="visible-count" class="text-xl font-semibold text-white">0</p>
            <p class="text-[11px] uppercase tracking-[0.16em] text-zinc-500">Visibles</p>
          </div>
          <div class="px-3 py-2">
            <p id="filter-count" class="text-xl font-semibold text-white">0</p>
            <p class="text-[11px] uppercase tracking-[0.16em] text-zinc-500">Filtros</p>
          </div>
        </div>
      </header>

      <div class="mb-5 max-w-md">
        <div class="relative">
          <span class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none text-zinc-500">
            <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
          </span>
          <input 
            type="text" 
            id="buscador-principal" 
            placeholder="Buscar por nombre o número (ej: Pikachu o 0025)..." 
            class="w-full rounded-lg border border-zinc-800/70 bg-zinc-900/60 py-2 pl-9 pr-4 text-sm text-zinc-100 placeholder-zinc-500 backdrop-blur-sm transition-all duration-200 focus:border-amber-400/70 focus:bg-zinc-900 focus:outline-none focus:ring-1 focus:ring-amber-400/50"
          />
        </div>
      </div>

      <nav class="sticky top-0 z-20 -mx-4 border-y border-zinc-800/60 bg-zinc-950/90 px-4 py-3 backdrop-blur-md sm:-mx-6 sm:px-6 lg:-mx-8 lg:px-8">
        <div
          id="generation-tabs"
          class="scrollbar-none flex gap-2 overflow-x-auto"
          aria-label="Filtro por generacion"
        >
          <button
            class="tab-button shrink-0 rounded-lg border px-4 py-2 text-sm font-medium transition"
            type="button"
            data-generation="all"
          >
            Todas
          </button>
          {
            Array.from({ length: 9 }, (_, index) => index + 1).map((generation) => (
              <button
                class="tab-button shrink-0 rounded-lg border px-4 py-2 text-sm font-medium transition"
                type="button"
                data-generation={String(generation)}
              >
                Gen {generation}
              </button>
            ))
          }
        </div>
      </nav>

      <section class="mt-5 flex items-center justify-between gap-3">
        <div>
          <p id="active-label" class="text-sm font-medium text-zinc-300">Gen 1</p>
          <p id="active-subtitle" class="text-xs text-zinc-500">Mostrando figuras disponibles</p>
        </div>
        <button
          id="filter-toggle"
          class="inline-flex min-h-11 items-center gap-2 rounded-lg border border-zinc-700/80 bg-zinc-900/60 px-4 py-2 text-sm font-semibold text-zinc-200 shadow-lg shadow-black/30 backdrop-blur-sm transition-all duration-200 hover:border-zinc-500 hover:bg-zinc-800 hover:text-white"
          type="button"
          aria-expanded="false"
          aria-controls="filter-panel"
        >
          <span class="grid h-5 w-5 place-items-center">
            <svg viewBox="0 0 24 24" class="h-5 w-5" aria-hidden="true">
              <path
                d="M4 7h16M7 12h10M10 17h4"
                fill="none"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-width="2"
              ></path>
            </svg>
          </span>
          Filtros
        </button>
      </section>

      <section
        id="filter-panel"
        class="mt-3 hidden rounded-xl border border-zinc-800/60 bg-zinc-900/70 p-4 shadow-2xl shadow-black/50 backdrop-blur-md"
      >
        <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">

          <!-- Línea -->
          <div>
            <p class="mb-2 text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-500">Línea</p>
            <div id="linea-filters" class="flex flex-col gap-1.5">
              <button
                class="linea-filter rounded-lg border px-3 py-2 text-sm font-semibold transition text-left"
                type="button"
                data-linea="tomy"
              >
                Takara Tomy / Moncolle
              </button>
              <button
                class="linea-filter rounded-lg border px-3 py-2 text-sm font-semibold transition text-left"
                type="button"
                data-linea="t_arts"
              >
                Takara Tomy Arts (T-Arts)
              </button>
            </div>
          </div>

          <!-- Atributos -->
          <div>
            <p class="mb-2 text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-500">Atributos</p>
            <div id="atributo-filters" class="flex flex-col gap-1.5">
              <button class="atributo-filter rounded-lg border px-3 py-2 text-sm font-semibold transition text-left" type="button" data-atributo="brillante">Brillante / Pearl</button>
              <button class="atributo-filter rounded-lg border px-3 py-2 text-sm font-semibold transition text-left" type="button" data-atributo="shiny">Shiny / Variocolor</button>
              <button class="atributo-filter rounded-lg border px-3 py-2 text-sm font-semibold transition text-left" type="button" data-atributo="clear">Translúcida / Clear</button>
              <button class="atributo-filter rounded-lg border px-3 py-2 text-sm font-semibold transition text-left" type="button" data-atributo="con-base">Con Base / Peana / Diorama</button>
            </div>
          </div>

          <!-- Colección -->
          <div class="sm:col-span-2">
            <p class="mb-2 text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-500">Colección</p>
            <select
              id="coleccion-select"
              class="w-full rounded-lg border border-zinc-700 bg-zinc-950 px-3 py-2 text-sm font-semibold text-zinc-200 focus:border-amber-400 focus:outline-none focus:ring-1 focus:ring-amber-400"
            >
              <option value="">— Todas las colecciones —</option>
            </select>
            <!-- Hidden div kept for JS compatibility -->
            <div id="coleccion-filters" class="hidden"></div>
          </div>

          <!-- Etiquetas -->
          <div class="sm:col-span-2">
            <p class="mb-2 text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-500">Etiquetas</p>
            <div id="etiqueta-filters" class="flex flex-wrap gap-1.5">
              <!-- Se llenará dinámicamente con JavaScript -->
            </div>
          </div>

        </div>
      </section>

      <section
        id="catalog-grid"
        class="mt-5 grid grid-cols-2 gap-3 sm:grid-cols-3 sm:gap-4 lg:grid-cols-4 xl:grid-cols-5"
        aria-live="polite"
      ></section>

      <section
        id="empty-state"
        class="mt-10 hidden rounded-lg border border-dashed border-zinc-700 bg-zinc-900/50 p-8 text-center"
      >
        <p class="text-base font-semibold text-white">No hay figuras para este filtro.</p>
        <p class="mt-2 text-sm text-zinc-400">
          Cambia la generacion, la linea o los atributos para ver mas resultados.
        </p>
      </section>

      <section
        id="loading-state"
        class="mt-10 rounded-lg border border-zinc-800 bg-zinc-900/70 p-8 text-center"
      >
        <p class="text-sm font-medium text-zinc-300">Cargando coleccion...</p>
      </section>
    </main>

    <div
      id="lightbox"
      class="fixed inset-0 z-50 hidden items-center justify-center bg-black/90 p-4 backdrop-blur-sm"
      role="dialog"
      aria-modal="true"
      aria-label="Vista ampliada de la foto"
    >
      <button
        id="lightbox-close"
        class="absolute right-4 top-4 z-10 grid h-11 w-11 place-items-center rounded-full border border-zinc-600 bg-zinc-900/80 text-2xl text-white transition hover:border-zinc-400"
        type="button"
        aria-label="Cerrar"
      >
        &times;
      </button>

      <button
        id="lightbox-prev"
        class="absolute left-2 top-1/2 z-10 hidden h-11 w-11 -translate-y-1/2 place-items-center rounded-full border border-zinc-600 bg-zinc-900/80 text-2xl text-white transition hover:border-zinc-400 sm:left-4"
        type="button"
        aria-label="Foto anterior"
      >
        &#8249;
      </button>

      <button
        id="lightbox-next"
        class="absolute right-2 top-1/2 z-10 hidden h-11 w-11 -translate-y-1/2 place-items-center rounded-full border border-zinc-600 bg-zinc-900/80 text-2xl text-white transition hover:border-zinc-400 sm:right-4"
        type="button"
        aria-label="Foto siguiente"
      >
        &#8250;
      </button>

      <figure class="flex max-h-[90vh] max-w-5xl flex-col items-center gap-3">
        <img
          id="lightbox-image"
          class="max-h-[78vh] max-w-full rounded-lg object-contain shadow-2xl shadow-black/50"
          alt=""
        />
        <figcaption id="lightbox-caption" class="text-center text-sm font-medium text-zinc-300"></figcaption>
        <p id="lightbox-counter" class="text-xs text-zinc-500"></p>
      </figure>
    </div>

    <script>
      // @ts-nocheck
      import { supabase } from "../lib/supabaseClient";
      import { getFigurePhotos } from "../lib/figurePhotos";
      import {
        figureMatchesAtributoFilters,
        figureMatchesLineFilter,
        getAtributoLabel,
        getFigureAtributos,
        getLineaLabel
      } from "../lib/figureTaxonomy";

      function createSlug(text: string): string {
        return text
          .toLowerCase()
          .normalize("NFD")
          .replace(/[\u0300-\u036f]/g, "")
          .replace(/[^a-z0-9\s-]/g, "")
          .trim()
          .replace(/\s+/g, "-")
          .replace(/-+/g, "-");
      }

      const state = {
        figures: [],
        colecciones: [],
        etiquetas: [],
        generation: "1",
        linea: null,
        atributos: [],
        coleccion: null,
        etiquetasSeleccionadas: [],
        search: "",
        lightbox: {
          photos: [],
          index: 0,
          caption: ""
        }
      };

      const catalogGrid = document.querySelector("#catalog-grid");
      const emptyState = document.querySelector("#empty-state");
      const loadingState = document.querySelector("#loading-state");
      const generationTabs = document.querySelector("#generation-tabs");
      const filterPanel = document.querySelector("#filter-panel");
      const lineaFilters = document.querySelector("#linea-filters");
      const atributoFilters = document.querySelector("#atributo-filters");
      const filterToggle = document.querySelector("#filter-toggle");
      const activeLabel = document.querySelector("#active-label");
      const activeSubtitle = document.querySelector("#active-subtitle");
      const totalCount = document.querySelector("#total-count");
      const visibleCount = document.querySelector("#visible-count");
      const filterCount = document.querySelector("#filter-count");
      const lightbox = document.querySelector("#lightbox");
      const lightboxImage = document.querySelector("#lightbox-image");
      const lightboxCaption = document.querySelector("#lightbox-caption");
      const lightboxCounter = document.querySelector("#lightbox-counter");
      const lightboxClose = document.querySelector("#lightbox-close");
      const lightboxPrev = document.querySelector("#lightbox-prev");
      const lightboxNext = document.querySelector("#lightbox-next");
      const buscadorPrincipal = document.querySelector("#buscador-principal"); // MODIFICADO: Selector del input

      const atributoClasses = {
        brillante: "border-fuchsia-300/50 bg-fuchsia-300/12 text-fuchsia-100",
        shiny: "border-amber-300/60 bg-amber-300/14 text-amber-100",
        clear: "border-cyan-300/50 bg-cyan-300/12 text-cyan-100",
        mega: "border-rose-300/55 bg-rose-300/12 text-rose-100",
        "con-base": "border-emerald-300/55 bg-emerald-300/12 text-emerald-100"
      };

      function getAtributoClass(atributo) {
        return atributoClasses[atributo] ?? "border-indigo-300/50 bg-indigo-300/12 text-indigo-100";
      }

      function getActiveFilterCount() {
        return (state.linea ? 1 : 0) + state.atributos.length + (state.coleccion ? 1 : 0) + state.etiquetasSeleccionadas.length;
      }

      function escapeHtml(value) {
        return String(value ?? "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#039;");
      }

      function getGenerationFigures() {
        if (state.generation === "all") {
          return state.figures;
        }
        return state.figures.filter((figure) => String(figure.pokemon?.generation) === state.generation);
      }

      function getFilteredFigures() {
        const baseFigures = state.search ? state.figures : getGenerationFigures();

        return baseFigures.filter(
          (figure) =>
            figureMatchesLineFilter(figure, state.linea) &&
            figureMatchesAtributoFilters(figure, state.atributos) &&
            (state.coleccion === null || figure.volumes?.collections?.id === state.coleccion) &&
            (state.etiquetasSeleccionadas.length === 0 || 
             state.etiquetasSeleccionadas.some(etiquetaId => 
               figure.etiquetas?.includes(etiquetaId)
             )) &&
            (state.search === "" ||
              figure.pokemon?.full_names?.es?.toLowerCase().includes(state.search) ||
              String(figure.pokemon?.pokedex_number).includes(state.search) ||
              String(figure.pokemon?.pokedex_number).padStart(4, "0").includes(state.search))
        );
      }

      function renderTabs() {
        document.querySelectorAll(".tab-button").forEach((button) => {
          const isActive = button.dataset.generation === state.generation;
          button.className = [
            "tab-button shrink-0 rounded-lg border px-4 py-2 text-sm font-semibold transition-all duration-200",
            isActive
              ? "border-amber-500/60 bg-gradient-to-r from-amber-500 to-yellow-400 text-zinc-950 shadow-md shadow-amber-500/20 ring-1 ring-amber-400/30"
              : "border-zinc-800 bg-zinc-900/40 text-zinc-400 hover:border-zinc-600 hover:bg-zinc-800/60 hover:text-zinc-200"
          ].join(" ");
        });
      }

      function renderLineaFilters() {
        document.querySelectorAll(".linea-filter").forEach((button) => {
          const isActive = state.linea === button.dataset.linea;
          button.className = [
            "linea-filter text-left rounded-lg border px-3 py-2 text-sm font-semibold transition-all duration-200",
            isActive
              ? "border-amber-500/60 bg-gradient-to-r from-amber-500/20 to-yellow-500/10 text-amber-300 ring-1 ring-amber-400/40 shadow-sm shadow-amber-500/10"
              : "border-zinc-700/80 bg-zinc-800/40 text-zinc-400 hover:border-zinc-500 hover:bg-zinc-800 hover:text-zinc-200"
          ].join(" ");
        });
      }

      function renderAtributoFilters() {
        document.querySelectorAll(".atributo-filter").forEach((button) => {
          const isActive = state.atributos.includes(button.dataset.atributo);
          button.className = [
            "atributo-filter text-left rounded-lg border px-3 py-2 text-sm font-semibold transition-all duration-200",
            isActive
              ? "border-amber-500/60 bg-gradient-to-r from-amber-500/20 to-yellow-500/10 text-amber-300 ring-1 ring-amber-400/40 shadow-sm shadow-amber-500/10"
              : "border-zinc-700/80 bg-zinc-800/40 text-zinc-400 hover:border-zinc-500 hover:bg-zinc-800 hover:text-zinc-200"
          ].join(" ");
        });
      }

      function renderColeccionFilters() {
        const select = document.querySelector("#coleccion-select");
        if (!select) return;
        const currentVal = state.coleccion ? String(state.coleccion) : "";
        select.innerHTML = `<option value="">— Todas las colecciones —</option>` +
          state.colecciones
            .map((c) => `<option value="${c.id}" ${String(c.id) === currentVal ? "selected" : ""}>${escapeHtml(c.name)}</option>`)
            .join("");
        select.className = [
          "w-full rounded-lg border px-3 py-2 text-sm font-semibold transition focus:outline-none focus:ring-1",
          state.coleccion
            ? "border-amber-400 bg-amber-400/10 text-amber-300 focus:border-amber-400 focus:ring-amber-400/50"
            : "border-zinc-700 bg-zinc-950 text-zinc-200 focus:border-amber-400 focus:ring-amber-400"
        ].join(" ");
      }

      function renderEtiquetaFilters() {
        const etiquetaFilters = document.querySelector("#etiqueta-filters");
        etiquetaFilters.innerHTML = state.etiquetas
          .map((etiqueta) => `
            <button
              class="etiqueta-filter rounded-lg border px-3 py-2 text-sm font-semibold transition"
              type="button"
              data-etiqueta="${etiqueta.id}"
            >
              ${escapeHtml(etiqueta.name)}
            </button>
          `)
          .join("");
        document.querySelectorAll(".etiqueta-filter").forEach((button) => {
          const isActive = state.etiquetasSeleccionadas.includes(Number(button.dataset.etiqueta));
          button.className = [
            "etiqueta-filter rounded-lg border px-3 py-2 text-sm font-semibold transition-all duration-200",
            isActive
              ? "border-amber-500/60 bg-gradient-to-r from-amber-500/20 to-yellow-500/10 text-amber-300 ring-1 ring-amber-400/40 shadow-sm shadow-amber-500/10"
              : "border-zinc-700/80 bg-zinc-800/40 text-zinc-400 hover:border-zinc-500 hover:bg-zinc-800 hover:text-zinc-200"
          ].join(" ");
        });
      }

      function renderFilterState() {
        renderLineaFilters();
        renderAtributoFilters();
        renderColeccionFilters();
        renderEtiquetaFilters();
        filterCount.textContent = String(getActiveFilterCount());
      }

      function formatPokedexNumber(number) {
        return String(number).padStart(4, "0");
      }

      function getColeccionVolumenText(figure) {
        if (!figure.volumes?.collections) return "";
        const coleccionNombre = figure.volumes.collections.name;
        const volumenNum = figure.volumes.volume;
        return `${coleccionNombre} · Vol. ${volumenNum}`;
      }

      function getLightboxCaption(figure) {
        const parts = [figure.pokemon?.full_names?.es || "Unknown"];
        if (figure.year) {
          parts.push(String(figure.year));
        }
        return parts.join(" · ");
      }

      function renderPhotoArea(figure) {
        const photos = getFigurePhotos(figure);

        if (photos.length === 0) {
          return `<div class="grid h-full w-full place-items-center bg-zinc-800 text-sm font-semibold text-zinc-500">#${escapeHtml(formatPokedexNumber(figure.pokemon?.pokedex_number))}</div>`;
        }

        const photoCountBadge =
          photos.length > 1
            ? `<span class="absolute bottom-2 right-2 rounded-md bg-black/65 px-2 py-1 text-[11px] font-bold text-white backdrop-blur-sm">${photos.length} fotos</span>`
            : "";

        return `
          <div class="relative block h-full w-full overflow-hidden">
            <img
              class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.03]"
              src="${escapeHtml(photos[0])}"
              alt="${escapeHtml(figure.pokemon?.full_names?.es)}"
              loading="lazy"
            />
            ${photoCountBadge}
          </div>
        `;
      }

      function openLightbox(figureId, photoIndex = 0) {
        const figure = state.figures.find((item) => item.id === figureId);
        if (!figure) return;

        const photos = getFigurePhotos(figure);
        if (photos.length === 0) return;

        state.lightbox = {
          photos,
          index: Math.min(Math.max(photoIndex, 0), photos.length - 1),
          caption: getLightboxCaption(figure)
        };

        updateLightbox();
        lightbox.classList.remove("hidden");
        lightbox.classList.add("flex");
        document.body.classList.add("overflow-hidden");
      }

      function closeLightbox() {
        lightbox.classList.add("hidden");
        lightbox.classList.remove("flex");
        document.body.classList.remove("overflow-hidden");
      }

      function updateLightbox() {
        const { photos, index, caption } = state.lightbox;
        lightboxImage.src = photos[index];
        lightboxImage.alt = caption;
        lightboxCaption.textContent = caption;
        lightboxCounter.textContent = photos.length > 1 ? `${index + 1} / ${photos.length}` : "";
        lightboxPrev.classList.toggle("hidden", photos.length <= 1);
        lightboxNext.classList.toggle("hidden", photos.length <= 1);
        lightboxPrev.classList.toggle("grid", photos.length > 1);
        lightboxNext.classList.toggle("grid", photos.length > 1);
      }

      function showNextPhoto(step) {
        const { photos } = state.lightbox;
        if (photos.length <= 1) return;

        state.lightbox.index = (state.lightbox.index + step + photos.length) % photos.length;
        updateLightbox();
      }

      function renderCards() {
        const figures = getFilteredFigures();
        const generationFigures = getGenerationFigures();

        visibleCount.textContent = String(figures.length);
        
        // MODIFICADO: Ajustamos dinámicamente el texto de los subtítulos según si estás buscando globalmente o no
        if (state.search) {
          activeLabel.textContent = `Búsqueda: "${state.search}"`;
          activeSubtitle.textContent = `Encontradas ${figures.length} figuras globalmente`;
        } else {
          activeLabel.textContent = state.generation === "all" ? "Todas las generaciones" : `Gen ${state.generation}`;
          activeSubtitle.textContent = `${generationFigures.length} figuras en esta vista`;
        }

        emptyState.classList.toggle("hidden", figures.length > 0);

        catalogGrid.innerHTML = figures
          .map((figure) => {
            const atributos = getFigureAtributos(figure);
            const atributoBadges = atributos
              .map((atributo) =>
                `<span class="rounded-md border px-1.5 py-0.5 text-[10px] font-bold ${getAtributoClass(atributo)}">${escapeHtml(getAtributoLabel(atributo))}</span>`
              )
              .join("");
            const lineaBadge = `<span class="rounded-md border border-zinc-600 bg-zinc-700/60 px-1.5 py-0.5 text-[10px] font-bold text-zinc-300">${escapeHtml(getLineaLabel(figure.line))}</span>`;
            const image = renderPhotoArea(figure);
            const pokedexBadge = `<span class="absolute top-2 right-2 rounded-md bg-black/60 px-1.5 py-0.5 font-mono text-[10px] text-zinc-400 backdrop-blur-sm">#${escapeHtml(formatPokedexNumber(figure.pokemon?.pokedex_number))}</span>`;
            const coleccionLine = getColeccionVolumenText(figure)
              ? `<p class="mt-1 truncate text-[11px] text-zinc-500">${escapeHtml(getColeccionVolumenText(figure))}</p>`
              : "";

            return `
              <a
                href="/figure/${escapeHtml(figure.slug ?? figure.id)}"
                class="group flex flex-col overflow-hidden rounded-xl border border-zinc-800/50 bg-zinc-900/60 shadow-lg shadow-black/50 backdrop-blur-md transition-all duration-300 hover:-translate-y-1 hover:border-zinc-600 hover:shadow-xl hover:shadow-amber-500/5"
              >
                <div class="relative aspect-square overflow-hidden bg-zinc-800/50">
                  ${image}
                  ${pokedexBadge}
                </div>
                <div class="flex flex-col gap-1.5 border-t border-zinc-800/60 bg-zinc-900/80 p-2.5">
                  <h2 class="truncate text-sm font-semibold leading-tight text-white">${escapeHtml(figure.pokemon?.full_names?.es)}</h2>
                  ${coleccionLine}
                  <div class="flex flex-wrap gap-1">
                    ${lineaBadge}
                    ${atributoBadges}
                  </div>
                </div>
              </a>
            `;
          })
          .join("");
      }

      function render() {
        renderTabs();
        renderFilterState();
        renderCards();
      }

      async function loadFigures() {
        loadingState.classList.remove("hidden");

        const { data, error } = await supabase
          .from("figures")
          .select(`
            *,
            pokemon(*),
            volumes(
              id,
              volume,
              name_eng,
              collections(id, name)
            )
          `)
          .order("visual_order", { ascending: true });

        loadingState.classList.add("hidden");

        if (error) {
          emptyState.classList.remove("hidden");
          emptyState.querySelector("p").textContent = "No se pudo cargar la coleccion.";
          return;
        }

        const figures = data ?? [];

        // Cargar todas las relaciones de etiquetas en una sola query
        const { data: relacionesData } = await supabase
          .from("figure_tags")
          .select("figure_id, tag_id");

        // Crear un mapa de figura -> array de etiquetas
        const etiquetasPorFigura = {};
        if (relacionesData) {
          relacionesData.forEach(rel => {
            if (!etiquetasPorFigura[rel.figure_id]) {
              etiquetasPorFigura[rel.figure_id] = [];
            }
            etiquetasPorFigura[rel.figure_id].push(rel.tag_id);
          });
        }

        // Asignar las etiquetas a cada figura
        figures.forEach(figure => {
          figure.etiquetas = etiquetasPorFigura[figure.id] || [];
        });

        // Ordenar: pokedex_number ASC, luego line (tomy < t_arts < resto), luego visual_order ASC
        const linePriority = (line) => {
          if (line === "tomy") return 0;
          if (line === "t_arts") return 1;
          return 2;
        };
        figures.sort((a, b) => {
          const numA = a.pokemon?.pokedex_number ?? 0;
          const numB = b.pokemon?.pokedex_number ?? 0;
          if (numA !== numB) return numA - numB;
          const lpA = linePriority(a.line);
          const lpB = linePriority(b.line);
          if (lpA !== lpB) return lpA - lpB;
          return (a.visual_order ?? 0) - (b.visual_order ?? 0);
        });

        state.figures = figures;
        totalCount.textContent = String(state.figures.length);
        render();
      }

      async function loadColecciones() {
        const { data, error } = await supabase
          .from("collections")
          .select("*")
          .order("name", { ascending: true });

        if (error) {
          console.error("Error al cargar colecciones:", error);
          return;
        }

        state.colecciones = data ?? [];
        renderColeccionFilters();
      }

      async function loadEtiquetas() {
        const { data, error } = await supabase
          .from("tags")
          .select("*")
          .order("name", { ascending: true });

        if (error) {
          console.error("Error al cargar etiquetas:", error);
          return;
        }

        state.etiquetas = data ?? [];
        renderEtiquetaFilters();
      }

      // MODIFICADO: Evento para capturar el texto escrito en el buscador
      buscadorPrincipal?.addEventListener("input", (event) => {
        state.search = event.target.value.toLowerCase().trim();
        render();
      });

      generationTabs.addEventListener("click", (event) => {
        const button = event.target.closest("[data-generation]");
        if (!button) return;

        state.generation = button.dataset.generation;
        
        // Opcional: Limpiamos el buscador al cambiar explícitamente de pestaña de generación
        if (state.search && buscadorPrincipal) {
          state.search = "";
          buscadorPrincipal.value = "";
        }

        render();
      });

      filterToggle.addEventListener("click", () => {
        const isHidden = filterPanel.classList.toggle("hidden");
        filterToggle.setAttribute("aria-expanded", String(!isHidden));
      });

      lineaFilters.addEventListener("click", (event) => {
        const button = event.target.closest("[data-linea]");
        if (!button) return;

        const linea = button.dataset.linea;
        state.linea = state.linea === linea ? null : linea;
        render();
      });

      atributoFilters.addEventListener("click", (event) => {
        const button = event.target.closest("[data-atributo]");
        if (!button) return;

        const atributo = button.dataset.atributo;
        const index = state.atributos.indexOf(atributo);

        if (index >= 0) {
          state.atributos.splice(index, 1);
        } else {
          state.atributos.push(atributo);
        }

        render();
      });

      // Event listener para el select de colecciones
      document.querySelector("#coleccion-select")?.addEventListener("change", (event) => {
        const val = event.target.value;
        state.coleccion = val ? Number(val) : null;
        renderColeccionFilters();
        render();
      });

      // Event listeners para filtros de etiquetas
      document.addEventListener("click", (event) => {
        const button = event.target.closest("[data-etiqueta]");
        if (!button) return;

        const etiquetaId = Number(button.dataset.etiqueta);
        const index = state.etiquetasSeleccionadas.indexOf(etiquetaId);

        if (index >= 0) {
          state.etiquetasSeleccionadas.splice(index, 1);
        } else {
          state.etiquetasSeleccionadas.push(etiquetaId);
        }

        render();
      });

      catalogGrid.addEventListener("click", (event) => {
        const trigger = event.target.closest(".photo-trigger");
        if (!trigger) return;

        openLightbox(trigger.dataset.figureId, Number(trigger.dataset.photoIndex || 0));
      });

      lightboxClose.addEventListener("click", closeLightbox);
      lightboxPrev.addEventListener("click", () => showNextPhoto(-1));
      lightboxNext.addEventListener("click", () => showNextPhoto(1));

      lightbox.addEventListener("click", (event) => {
        if (event.target === lightbox) {
          closeLightbox();
        }
      });

      document.addEventListener("keydown", (event) => {
        if (lightbox.classList.contains("hidden")) return;

        if (event.key === "Escape") closeLightbox();
        if (event.key === "ArrowLeft") showNextPhoto(-1);
        if (event.key === "ArrowRight") showNextPhoto(1);
      });

      loadFigures();
      loadColecciones();
      loadEtiquetas();
    </script>
  </body>
</html>