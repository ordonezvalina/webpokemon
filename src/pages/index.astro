---
import BaseLayout from "../components/BaseLayout.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import { getCatalog, getTagsForFigure } from "../lib/catalogCache";
import { sortFigures } from "../lib/sortFigures";
import { homeMeta, webSiteSchema } from "../lib/seo";

const { figures: rawFigures, collections, tags, figureTags } = await getCatalog();

const siteUrl = Astro.site?.toString() || "https://example.com";
const seo = homeMeta(rawFigures.length, siteUrl);
const schemas = webSiteSchema(siteUrl, seo.description);

const figures = rawFigures.map((figure: any) => ({ ...figure }));

figures.forEach((figure: any) => {
  figure.tagIds = getTagsForFigure(figure.id, figureTags).map((tag: any) =>
    Number(tag.id)
  );
});

const sortedFigures = sortFigures(figures);

const initialFigures = sortedFigures;
const initialColecciones = collections;
const initialEtiquetas = tags;
---

<BaseLayout
  title={seo.title}
  description={seo.description}
  seo={seo}
  schemas={schemas}
  showThemeToggle={false}
>
  <!-- Ambient background glow -->
    <div class="pointer-events-none fixed inset-0 -z-10 bg-[radial-gradient(ellipse_80%_50%_at_50%_-10%,rgba(120,100,60,0.12),transparent)]"></div>
    <main class="mx-auto flex min-h-screen w-full max-w-7xl flex-col px-4 pb-24 pt-5 sm:px-6 lg:px-8">
      <header class="mb-5 sm:mb-8">
        <p class="text-xs font-semibold uppercase tracking-[0.22em] text-amber-600 dark:text-amber-300">
          Tomy Moncolle Archive
        </p>
        <h1 class="mt-1 text-4xl font-semibold leading-tight tracking-tight sm:text-6xl">
          <span class="bg-gradient-to-br from-zinc-900 via-zinc-700 to-zinc-500 bg-clip-text text-transparent dark:from-white dark:via-zinc-100 dark:to-zinc-400">Pokémon Collection</span>
        </h1>
        <p class="mt-1 max-w-2xl text-sm leading-6 text-zinc-600 dark:text-zinc-400 sm:text-base">
          My personal catalogue of Tomy figures.
        </p>

        <!-- Search bar -->
        <div class="relative mt-4 max-w-md">
          <span class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3 text-zinc-400 dark:text-zinc-500">
            <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <circle cx="11" cy="11" r="8"></circle>
              <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
            </svg>
          </span>
          <input
            type="text"
            id="buscador-principal"
            placeholder="Search Pokémon or #001"
            class="w-full rounded-lg border border-zinc-300/80 bg-zinc-100/60 py-2 pl-9 pr-9 text-sm text-zinc-900 placeholder-zinc-500 backdrop-blur-sm transition-all duration-200 focus:border-amber-500/70 focus:bg-white focus:outline-none focus:ring-1 focus:ring-amber-500/50 dark:border-zinc-800/70 dark:bg-zinc-900/60 dark:text-zinc-100 dark:placeholder-zinc-400 dark:focus:border-amber-400/70 dark:focus:bg-zinc-900"
          />
          <button
            id="buscador-clear"
            class="absolute inset-y-0 right-0 hidden items-center pr-3 text-zinc-500 hover:text-zinc-900 dark:text-zinc-400 dark:hover:text-white"
            type="button"
            aria-label="Clear search"
          >
            <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <line x1="18" y1="6" x2="6" y2="18"></line>
              <line x1="6" y1="6" x2="18" y2="18"></line>
            </svg>
          </button>
        </div>
      </header>

      <!-- Hidden counters for JS -->
      <span id="total-count" class="hidden">0</span>
      <span id="visible-count" class="hidden">0</span>
      <span id="filter-count" class="hidden">0</span>

      <nav class="sticky top-0 z-20 -mx-4 border-y border-zinc-200/80 bg-white/90 px-4 py-3 backdrop-blur-md sm:-mx-6 sm:px-6 lg:-mx-8 lg:px-8 relative dark:border-zinc-800/60 dark:bg-zinc-950/90">
        <div class="flex items-center gap-3">
          <div
            id="generation-tabs"
            class="scrollbar-none flex flex-1 gap-2 overflow-x-auto"
            aria-label="Filter by generation"
          >
            <button
              class="tab-button shrink-0 rounded-lg border px-4 py-2 text-sm font-medium transition border-zinc-200 bg-zinc-100 text-zinc-700 hover:border-zinc-400 hover:bg-zinc-200 hover:text-zinc-900 dark:border-zinc-800 dark:bg-zinc-900/40 dark:text-zinc-400 dark:hover:border-zinc-600 dark:hover:bg-zinc-800/60 dark:hover:text-zinc-200"
              type="button"
              data-generation="all"
            >
              <span class="block font-semibold">All</span>
              <span class="block text-xs font-normal opacity-70">All</span>
            </button>
            {
              (() => {
                const regions = ["","Kanto","Johto","Hoenn","Sinnoh","Unova","Kalos","Alola","Galar","Paldea"];
                return Array.from({ length: 9 }, (_, i) => i + 1).map((generation) => (
                  <button
                    class="tab-button shrink-0 rounded-lg border px-4 py-2 text-sm font-medium transition border-zinc-200 bg-zinc-100 text-zinc-700 hover:border-zinc-400 hover:bg-zinc-200 hover:text-zinc-900 dark:border-zinc-800 dark:bg-zinc-900/40 dark:text-zinc-400 dark:hover:border-zinc-600 dark:hover:bg-zinc-800/60 dark:hover:text-zinc-200"
                    type="button"
                    data-generation={String(generation)}
                  >
                    <span class="block font-semibold">Gen {generation}</span>
                    <span class="block text-xs font-normal opacity-70">{regions[generation]}</span>
                  </button>
                ));
              })()
            }
          </div>
          <button
            id="filter-toggle"
            class="inline-flex shrink-0 items-center gap-2 self-stretch rounded-lg border border-zinc-300/80 bg-white/60 px-4 py-2 text-sm font-semibold text-zinc-700 shadow-lg shadow-zinc-900/10 backdrop-blur-sm transition-all duration-200 hover:border-zinc-400 hover:bg-zinc-100 hover:text-zinc-900 dark:border-zinc-700/80 dark:bg-zinc-900/60 dark:text-zinc-200 dark:shadow-black/30 dark:hover:border-zinc-500 dark:hover:bg-zinc-800 dark:hover:text-white"
            type="button"
            aria-expanded="false"
            aria-controls="filter-panel"
            aria-label="Filters"
          >
            <span class="grid h-5 w-5 place-items-center">
              <svg viewBox="0 0 24 24" class="h-5 w-5" aria-hidden="true">
                <path
                  d="M4 7h16M7 12h10M10 17h4"
                  fill="none"
                  stroke="currentColor"
                  stroke-linecap="round"
                  stroke-width="2"
                ></path>
              </svg>
            </span>
            <span class="hidden sm:inline">Filters</span>
          </button>
          <div class="flex shrink-0">
            <ThemeToggle />
          </div>
        </div>

        <section
          id="filter-panel"
          class="hidden absolute left-0 right-0 top-full z-30 -mx-4 sm:-mx-6 lg:-mx-8 rounded-b-xl border-b border-zinc-200/70 bg-white/95 px-4 py-4 shadow-2xl shadow-zinc-900/10 backdrop-blur-md sm:px-6 lg:px-8 dark:border-zinc-800/60 dark:bg-zinc-900/95 dark:shadow-black/50"
        >
          <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">

            <!-- Line -->
            <div>
              <p class="mb-2 text-xs font-bold uppercase tracking-[0.2em] text-zinc-400">Line</p>
              <div id="linea-filters" class="flex flex-col gap-1.5">
                <button
                  class="linea-filter rounded-lg border px-3 py-2 text-sm font-semibold transition text-left"
                  type="button"
                  data-linea="tomy"
                >
                  Takara Tomy / Moncolle
                </button>
                <button
                  class="linea-filter rounded-lg border px-3 py-2 text-sm font-semibold transition text-left"
                  type="button"
                  data-linea="t_arts"
                >
                  Takara Tomy Arts (T-Arts)
                </button>
              </div>
            </div>

            <!-- Attributes -->
            <div>
              <p class="mb-2 text-xs font-bold uppercase tracking-[0.2em] text-zinc-400">Attributes</p>
              <div id="atributo-filters" class="flex flex-col gap-1.5">
                <button class="atributo-filter rounded-lg border px-3 py-2 text-sm font-semibold transition text-left" type="button" data-atributo="brillante">Pearl / Brillante</button>
                <button class="atributo-filter rounded-lg border px-3 py-2 text-sm font-semibold transition text-left" type="button" data-atributo="shiny">Shiny / Variocolor</button>
                <button class="atributo-filter rounded-lg border px-3 py-2 text-sm font-semibold transition text-left" type="button" data-atributo="clear">Clear / Translucent</button>
                <button class="atributo-filter rounded-lg border px-3 py-2 text-sm font-semibold transition text-left" type="button" data-atributo="con-base">With Base / Diorama</button>
              </div>
            </div>

            <!-- Collection -->
            <div class="sm:col-span-2">
              <p class="mb-2 text-xs font-bold uppercase tracking-[0.2em] text-zinc-400">Collection</p>
              <select
                id="coleccion-select"
                class="w-full rounded-lg border border-zinc-300 bg-white px-3 py-2 text-sm font-semibold text-zinc-900 focus:border-amber-500 focus:outline-none focus:ring-1 focus:ring-amber-500 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-200 dark:focus:border-amber-400 dark:focus:ring-amber-400"
              >
                <option value="">— All collections —</option>
              </select>
              <!-- Hidden div kept for JS compatibility -->
              <div id="coleccion-filters" class="hidden"></div>
            </div>

            <!-- Tags -->
            <div class="sm:col-span-2">
              <p class="mb-2 text-xs font-bold uppercase tracking-[0.2em] text-zinc-400">Tags</p>
              <div id="etiqueta-filters" class="flex flex-wrap gap-1.5">
                <!-- Filled dynamically by JavaScript -->
              </div>
            </div>

          </div>

          <!-- Apply / Clear action row -->
          <div class="mt-5 flex items-center justify-end gap-3 border-t border-zinc-200/70 pt-4 dark:border-zinc-800/60">
            <button
              id="filter-clear-btn"
              class="inline-flex items-center gap-1.5 rounded-lg border border-zinc-300/80 bg-white/60 px-4 py-2 text-sm font-semibold text-zinc-500 shadow-sm backdrop-blur-sm transition-all duration-200 hover:border-zinc-400 hover:text-zinc-900 dark:border-zinc-700/80 dark:bg-zinc-900/60 dark:text-zinc-400 dark:hover:border-zinc-500 dark:hover:text-white"
              type="button"
            >
              <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6"></path>
              </svg>
              Clear
            </button>
            <button
              id="filter-apply-btn"
              class="inline-flex items-center gap-1.5 rounded-lg border border-amber-500/60 bg-gradient-to-r from-amber-500 to-yellow-400 px-5 py-2 text-sm font-semibold text-zinc-950 shadow-md shadow-amber-500/20 ring-1 ring-amber-400/30 transition-all duration-200 hover:from-amber-400 hover:to-yellow-300"
              type="button"
            >
              <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              Apply Filters
            </button>
          </div>

        </section>
      </nav>

      <!-- Filter panel overlay (click-outside to close) -->
      <div id="filter-overlay" class="fixed inset-0 z-10 hidden" aria-hidden="true"></div>

      <section class="mt-5 flex items-center justify-between gap-3">
        <div>
          <p id="active-label" class="text-sm font-medium text-zinc-700 dark:text-zinc-300">Gen 1</p>
          <p id="active-subtitle" class="text-xs text-zinc-400">Showing available figures</p>
        </div>
        <button
          id="reset-filters"
          class="hidden items-center gap-1.5 rounded-lg border border-zinc-300/80 bg-white/60 px-3 py-2 text-sm font-semibold text-zinc-500 shadow-lg shadow-zinc-900/10 backdrop-blur-sm transition-all duration-200 hover:border-zinc-400 hover:text-zinc-900 dark:border-zinc-700/80 dark:bg-zinc-900/60 dark:text-zinc-400 dark:shadow-black/30 dark:hover:border-zinc-500 dark:hover:text-white"
          type="button"
          aria-label="Reset filters"
        >
          <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M3 6h18M8 6V4h8v2M19 6l-1 14H6L5 6"></path>
          </svg>
          Reset
        </button>
      </section>

      <section
        id="catalog-grid"
        class="mt-5 grid grid-cols-2 gap-3 sm:grid-cols-3 sm:gap-4 lg:grid-cols-4"
        aria-live="polite"
      ></section>

      <section
        id="empty-state"
        class="mt-10 hidden rounded-lg border border-dashed border-zinc-300 bg-zinc-100/60 p-8 text-center dark:border-zinc-700 dark:bg-zinc-900/50"
      >
        <p class="text-base font-semibold text-zinc-900 dark:text-white">No figures match this filter.</p>
        <p class="mt-2 text-sm text-zinc-500 dark:text-zinc-400">
          Try changing the generation, line or attributes to see more results.
        </p>
      </section>

      <section
        id="loading-state"
        class="mt-10 rounded-lg border border-zinc-200 bg-white/70 p-8 text-center dark:border-zinc-800 dark:bg-zinc-900/70"
      >
        <p class="text-sm font-medium text-zinc-700 dark:text-zinc-300">Loading collection...</p>
      </section>
    </main>

    <div
      id="lightbox"
      class="fixed inset-0 z-50 hidden items-center justify-center bg-black/90 p-4 backdrop-blur-sm"
      role="dialog"
      aria-modal="true"
      aria-label="Enlarged photo view"
    >
      <button
        id="lightbox-close"
        class="absolute right-4 top-4 z-10 grid h-11 w-11 place-items-center rounded-full border border-zinc-400 bg-white/90 text-2xl text-zinc-900 transition hover:border-zinc-600 dark:border-zinc-600 dark:bg-zinc-900/80 dark:text-white dark:hover:border-zinc-400"
        type="button"
        aria-label="Close"
      >
        &times;
      </button>

      <button
        id="lightbox-prev"
        class="absolute left-2 top-1/2 z-10 hidden h-11 w-11 -translate-y-1/2 place-items-center rounded-full border border-zinc-400 bg-white/90 text-2xl text-zinc-900 transition hover:border-zinc-600 dark:border-zinc-600 dark:bg-zinc-900/80 dark:text-white dark:hover:border-zinc-400 sm:left-4"
        type="button"
        aria-label="Previous photo"
      >
        &#8249;
      </button>

      <button
        id="lightbox-next"
        class="absolute right-2 top-1/2 z-10 hidden h-11 w-11 -translate-y-1/2 place-items-center rounded-full border border-zinc-400 bg-white/90 text-2xl text-zinc-900 transition hover:border-zinc-600 dark:border-zinc-600 dark:bg-zinc-900/80 dark:text-white dark:hover:border-zinc-400 sm:right-4"
        type="button"
        aria-label="Next photo"
      >
        &#8250;
      </button>

      <figure class="flex max-h-[90vh] max-w-5xl flex-col items-center gap-3">
        <img
          id="lightbox-image"
          class="max-h-[78vh] max-w-full rounded-lg object-contain shadow-2xl shadow-black/50"
          alt=""
        />
        <figcaption id="lightbox-caption" class="text-center text-sm font-medium text-zinc-700 dark:text-zinc-300"></figcaption>
        <p id="lightbox-counter" class="text-xs text-zinc-500 dark:text-zinc-500"></p>
      </figure>
    </div>

    <script is:inline define:vars={{ initialFigures, initialColecciones, initialEtiquetas }}>
      window.__FIGURES__ = initialFigures;
      window.__COLECCIONES__ = initialColecciones;
      window.__ETIQUETAS__ = initialEtiquetas;
    </script>

    <script>
      // @ts-nocheck
      import { getFigurePhotos } from "../lib/figurePhotos";
      import {
        LINES,
        ATTRIBUTES,
        figureMatchesAttributeFilters,
        figureMatchesLineFilter,
        getAttributeLabel,
        getFigureAttributes,
        getLineLabel
      } from "../lib/figureTaxonomy";

      function createSlug(text: string): string {
        return text
          .toLowerCase()
          .normalize("NFD")
          .replace(/[\u0300-\u036f]/g, "")
          .replace(/[^a-z0-9\s-]/g, "")
          .trim()
          .replace(/\s+/g, "-")
          .replace(/-+/g, "-");
      }

      const state = {
        figures: [],
        collections: [],
        tags: [],
        generation: "1",
        line: null,
        attributes: [],
        collection: null,
        selectedTags: [],
        search: "",
        lightbox: {
          photos: [],
          index: 0,
          caption: ""
        }
      };

      const catalogGrid = document.querySelector("#catalog-grid");
      const emptyState = document.querySelector("#empty-state");
      const loadingState = document.querySelector("#loading-state");
      const generationTabs = document.querySelector("#generation-tabs");
      const filterPanel = document.querySelector("#filter-panel");
      const lineFilters = document.querySelector("#linea-filters");
      const attributeFilters = document.querySelector("#atributo-filters");
      const filterToggle = document.querySelector("#filter-toggle");
      const filterOverlay = document.querySelector("#filter-overlay");
      const filterApplyBtn = document.querySelector("#filter-apply-btn");
      const filterClearBtn = document.querySelector("#filter-clear-btn");
      const activeLabel = document.querySelector("#active-label");
      const activeSubtitle = document.querySelector("#active-subtitle");
      const totalCount = document.querySelector("#total-count");
      const visibleCount = document.querySelector("#visible-count");
      const filterCount = document.querySelector("#filter-count");
      const lightbox = document.querySelector("#lightbox");
      const lightboxImage = document.querySelector("#lightbox-image");
      const lightboxCaption = document.querySelector("#lightbox-caption");
      const lightboxCounter = document.querySelector("#lightbox-counter");
      const lightboxClose = document.querySelector("#lightbox-close");
      const lightboxPrev = document.querySelector("#lightbox-prev");
      const lightboxNext = document.querySelector("#lightbox-next");
      const searchInput = document.querySelector("#buscador-principal");
      const searchClear = document.querySelector("#buscador-clear");
      const resetFiltersBtn = document.querySelector("#reset-filters");

      const atributoClasses = {
        brillante: "border-fuchsia-600/40 bg-fuchsia-500/10 text-fuchsia-800 dark:border-fuchsia-300/50 dark:bg-fuchsia-300/12 dark:text-fuchsia-100",
        shiny: "border-amber-600/40 bg-amber-500/10 text-amber-800 dark:border-amber-300/60 dark:bg-amber-300/14 dark:text-amber-100",
        clear: "border-cyan-600/40 bg-cyan-500/10 text-cyan-800 dark:border-cyan-300/50 dark:bg-cyan-300/12 dark:text-cyan-100",
        mega: "border-rose-600/40 bg-rose-500/10 text-rose-800 dark:border-rose-300/55 dark:bg-rose-300/12 dark:text-rose-100",
        "con-base": "border-emerald-600/40 bg-emerald-500/10 text-emerald-800 dark:border-emerald-300/55 dark:bg-emerald-300/12 dark:text-emerald-100"
      };

      function getAtributoClass(atributo) {
        return atributoClasses[atributo] ?? "border-indigo-600/40 bg-indigo-500/10 text-indigo-800 dark:border-indigo-300/50 dark:bg-indigo-300/12 dark:text-indigo-100";
      }

      function getActiveFilterCount() {
        return (state.line ? 1 : 0) + state.attributes.length + (state.collection ? 1 : 0) + state.selectedTags.length;
      }

      function escapeHtml(value) {
        return String(value ?? "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#039;");
      }

      function getGenerationFigures() {
        if (state.generation === "all") {
          return state.figures;
        }
        return state.figures.filter((figure) => String(figure.pokemon?.generation) === state.generation);
      }

      function getFilteredFigures() {
        const baseFigures = state.search ? state.figures : getGenerationFigures();

        return baseFigures.filter(
          (figure) =>
            figureMatchesLineFilter(figure, state.line) &&
            figureMatchesAttributeFilters(figure, state.attributes) &&
            (state.collection === null || createSlug(figure.volumes?.collections?.name ?? "") === state.collection) &&
            (state.selectedTags.length === 0 || 
             state.selectedTags.some(tagId => 
               figure.tagIds?.includes(tagId)
             )) &&
            (state.search === "" ||
              figure.pokemon?.full_names?.es?.toLowerCase().includes(state.search) ||
              String(figure.pokemon?.pokedex_number).includes(state.search) ||
              String(figure.pokemon?.pokedex_number).padStart(4, "0").includes(state.search))
        );
      }

      function renderTabs() {
        document.querySelectorAll(".tab-button").forEach((button) => {
          const isActive = button.dataset.generation === state.generation;
          button.className = [
            "tab-button shrink-0 rounded-lg border px-4 py-2 text-sm font-semibold transition-all duration-200",
            isActive
              ? "border-amber-500/60 bg-gradient-to-r from-amber-500 to-yellow-400 text-zinc-950 shadow-md shadow-amber-500/20 ring-1 ring-amber-400/30"
              : "border-zinc-200 bg-zinc-100 text-zinc-700 hover:border-zinc-400 hover:bg-zinc-200 hover:text-zinc-900 dark:border-zinc-800 dark:bg-zinc-900/40 dark:text-zinc-400 dark:hover:border-zinc-600 dark:hover:bg-zinc-800/60 dark:hover:text-zinc-200"
          ].join(" ");
        });
      }

      function renderLineFilters() {
        document.querySelectorAll(".linea-filter").forEach((button) => {
          const isActive = state.line === button.dataset.linea;
          button.className = [
            "linea-filter text-left rounded-lg border px-3 py-2 text-sm font-semibold transition-all duration-200",
            isActive
              ? "border-amber-500/60 bg-gradient-to-r from-amber-500/20 to-yellow-500/10 text-amber-700 ring-1 ring-amber-400/40 shadow-sm shadow-amber-500/10 dark:text-amber-300"
              : "border-zinc-200/80 bg-zinc-100/40 text-zinc-600 hover:border-zinc-400 hover:bg-zinc-200 hover:text-zinc-900 dark:border-zinc-700/80 dark:bg-zinc-800/40 dark:text-zinc-400 dark:hover:border-zinc-500 dark:hover:bg-zinc-800 dark:hover:text-zinc-200"
          ].join(" ");
        });
      }

      function renderAttributeFilters() {
        document.querySelectorAll(".atributo-filter").forEach((button) => {
          const isActive = state.attributes.includes(button.dataset.atributo);
          button.className = [
            "atributo-filter text-left rounded-lg border px-3 py-2 text-sm font-semibold transition-all duration-200",
            isActive
              ? "border-amber-500/60 bg-gradient-to-r from-amber-500/20 to-yellow-500/10 text-amber-700 ring-1 ring-amber-400/40 shadow-sm shadow-amber-500/10 dark:text-amber-300"
              : "border-zinc-200/80 bg-zinc-100/40 text-zinc-600 hover:border-zinc-400 hover:bg-zinc-200 hover:text-zinc-900 dark:border-zinc-700/80 dark:bg-zinc-800/40 dark:text-zinc-400 dark:hover:border-zinc-500 dark:hover:bg-zinc-800 dark:hover:text-zinc-200"
          ].join(" ");
        });
      }

      function renderCollectionFilters() {
        const select = document.querySelector("#coleccion-select");
        if (!select) return;
        select.innerHTML = `<option value="">— All collections —</option>` +
          state.collections
            .map((c) => {
              const slug = createSlug(c.name);
              return `<option value="${escapeHtml(slug)}" ${slug === state.collection ? "selected" : ""}>${escapeHtml(c.name)}</option>`;
            })
            .join("");
        select.className = [
          "w-full rounded-lg border px-3 py-2 text-sm font-semibold transition focus:outline-none focus:ring-1",
          state.collection
            ? "border-amber-500 bg-amber-500/10 text-amber-700 focus:border-amber-500 focus:ring-amber-500/50 dark:border-amber-400 dark:bg-amber-400/10 dark:text-amber-300 dark:focus:border-amber-400 dark:focus:ring-amber-400/50"
            : "border-zinc-300 bg-white text-zinc-900 focus:border-amber-500 focus:ring-amber-500 dark:border-zinc-700 dark:bg-zinc-950 dark:text-zinc-200 dark:focus:border-amber-400 dark:focus:ring-amber-400"
        ].join(" ");
      }

      function renderTagFilters() {
        const tagFilters = document.querySelector("#etiqueta-filters");
        tagFilters.innerHTML = state.tags
          .map((tag) => `
            <button
              class="etiqueta-filter rounded-lg border px-3 py-2 text-sm font-semibold transition"
              type="button"
              data-etiqueta="${tag.id}"
            >
              ${escapeHtml(tag.name)}
            </button>
          `)
          .join("");
        document.querySelectorAll(".etiqueta-filter").forEach((button) => {
          const isActive = state.selectedTags.includes(Number(button.dataset.etiqueta));
          button.className = [
            "etiqueta-filter rounded-lg border px-3 py-2 text-sm font-semibold transition-all duration-200",
            isActive
              ? "border-amber-500/60 bg-gradient-to-r from-amber-500/20 to-yellow-500/10 text-amber-700 ring-1 ring-amber-400/40 shadow-sm shadow-amber-500/10 dark:text-amber-300"
              : "border-zinc-200/80 bg-zinc-100/40 text-zinc-600 hover:border-zinc-400 hover:bg-zinc-200 hover:text-zinc-900 dark:border-zinc-700/80 dark:bg-zinc-800/40 dark:text-zinc-400 dark:hover:border-zinc-500 dark:hover:bg-zinc-800 dark:hover:text-zinc-200"
          ].join(" ");
        });
      }

      function hasActiveFilters() {
        return state.line !== null || state.attributes.length > 0 || state.collection !== null || state.selectedTags.length > 0;
      }

      function renderFilterState() {
        renderLineFilters();
        renderAttributeFilters();
        renderCollectionFilters();
        renderTagFilters();
        filterCount.textContent = String(getActiveFilterCount());
        if (resetFiltersBtn) {
          resetFiltersBtn.classList.toggle("hidden", !hasActiveFilters());
          resetFiltersBtn.classList.toggle("inline-flex", hasActiveFilters());
        }
      }

      function formatPokedexNumber(number) {
        return String(number).padStart(4, "0");
      }

      function getCollectionVolumeText(figure) {
        if (!figure.volumes?.collections) return "";
        const collectionName = figure.volumes.collections.name;
        const volumeNum = figure.volumes.volume;
        return `${collectionName} · Vol. ${volumeNum}`;
      }

      function getLightboxCaption(figure) {
        const parts = [figure.pokemon?.full_names?.es || "Unknown"];
        if (figure.year) {
          parts.push(String(figure.year));
        }
        return parts.join(" · ");
      }

      function renderPhotoArea(figure) {
        const photos = getFigurePhotos(figure);

        if (photos.length === 0) {
          return `<div class="grid h-full w-full place-items-center bg-zinc-100 text-sm font-semibold text-zinc-400 dark:bg-zinc-800 dark:text-zinc-500">#${escapeHtml(formatPokedexNumber(figure.pokemon?.pokedex_number))}</div>`;
        }

        const photoCountBadge =
          photos.length > 1
            ? `<span class="absolute bottom-2 right-2 rounded-md bg-black/65 px-2 py-1 text-xs font-bold text-white backdrop-blur-sm dark:bg-black/65 dark:text-white">${photos.length} photos</span>`
            : "";

        return `
          <div class="relative block h-full w-full overflow-hidden">
            <img
              class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.03]"
              src="${escapeHtml(photos[0])}"
              alt="${escapeHtml(figure.pokemon?.full_names?.es)}"
              loading="lazy"
              decoding="async"
            />
            ${photoCountBadge}
          </div>
        `;
      }

      function openLightbox(figureId, photoIndex = 0) {
        const figure = state.figures.find((item) => item.id === figureId);
        if (!figure) return;

        const photos = getFigurePhotos(figure);
        if (photos.length === 0) return;

        state.lightbox = {
          photos,
          index: Math.min(Math.max(photoIndex, 0), photos.length - 1),
          caption: getLightboxCaption(figure)
        };

        updateLightbox();
        lightbox.classList.remove("hidden");
        lightbox.classList.add("flex");
        document.body.classList.add("overflow-hidden");
      }

      function closeLightbox() {
        lightbox.classList.add("hidden");
        lightbox.classList.remove("flex");
        document.body.classList.remove("overflow-hidden");
      }

      function updateLightbox() {
        const { photos, index, caption } = state.lightbox;
        lightboxImage.src = photos[index];
        lightboxImage.alt = caption;
        lightboxCaption.textContent = caption;
        lightboxCounter.textContent = photos.length > 1 ? `${index + 1} / ${photos.length}` : "";
        lightboxPrev.classList.toggle("hidden", photos.length <= 1);
        lightboxNext.classList.toggle("hidden", photos.length <= 1);
        lightboxPrev.classList.toggle("grid", photos.length > 1);
        lightboxNext.classList.toggle("grid", photos.length > 1);
      }

      function showNextPhoto(step) {
        const { photos } = state.lightbox;
        if (photos.length <= 1) return;

        state.lightbox.index = (state.lightbox.index + step + photos.length) % photos.length;
        updateLightbox();
      }

      function renderCards() {
        const figures = getFilteredFigures();
        const generationFigures = getGenerationFigures();

        visibleCount.textContent = String(figures.length);
        
        if (state.search) {
          activeLabel.textContent = `Search: "${state.search}"`;
          activeSubtitle.textContent = `Found ${figures.length} figures`;
        } else {
          activeLabel.textContent = state.generation === "all" ? "All generations" : `Gen ${state.generation}`;
          activeSubtitle.textContent = `${generationFigures.length} figures in this view`;
        }

        emptyState.classList.toggle("hidden", figures.length > 0);

        catalogGrid.innerHTML = figures
          .map((figure) => {
            const attributes = getFigureAttributes(figure);
            const maxBadges = 3;
            const visibleAttributes = attributes.slice(0, Math.max(0, maxBadges - 1));
            const overflowCount = attributes.length - visibleAttributes.length;

            const attributeBadges = visibleAttributes
              .map((attribute) =>
                `<span class="rounded-md border px-1.5 py-0.5 text-xs font-bold ${getAtributoClass(attribute)}">${escapeHtml(getAttributeLabel(attribute))}</span>`
              )
              .join("");
            const overflowBadge = overflowCount > 0
              ? `<span class="rounded-md border border-zinc-300 bg-zinc-200/70 px-1.5 py-0.5 text-xs font-bold text-zinc-600 dark:border-zinc-700 dark:bg-zinc-800/60 dark:text-zinc-400">+${overflowCount}</span>`
              : "";
            const lineBadge = `<span class="rounded-md border border-zinc-300 bg-zinc-200/70 px-1.5 py-0.5 text-xs font-bold text-zinc-700 dark:border-zinc-600 dark:bg-zinc-700/60 dark:text-zinc-300">${escapeHtml(getLineLabel(figure.line))}</span>`;
            const image = renderPhotoArea(figure);
            const pokedexBadge = `<span class="absolute top-2 right-2 rounded-md bg-black/60 px-1.5 py-0.5 font-mono text-xs text-white backdrop-blur-sm dark:bg-black/60 dark:text-zinc-300">#${escapeHtml(formatPokedexNumber(figure.pokemon?.pokedex_number))}</span>`;

            const metaParts = [];
            if (figure.year) metaParts.push(escapeHtml(figure.year));
            const collectionText = getCollectionVolumeText(figure);
            if (collectionText) metaParts.push(escapeHtml(collectionText));
            const metaLine = metaParts.length > 0
              ? `<p class="truncate text-xs font-medium text-zinc-500">${metaParts.join(" · ")}</p>`
              : "";

            const figureName = escapeHtml(figure.pokemon?.full_names?.es) || `Figure #${escapeHtml(formatPokedexNumber(figure.pokemon?.pokedex_number))}`;

            return `
              <a
                href="/figure/${escapeHtml(figure.slug ?? figure.id)}"
                class="group flex h-full flex-col overflow-hidden rounded-xl border border-zinc-200/80 bg-white/80 shadow-lg shadow-zinc-900/10 backdrop-blur-md transition-all duration-300 hover:-translate-y-1 hover:border-zinc-400 hover:shadow-xl hover:shadow-zinc-900/10 dark:border-zinc-800/50 dark:bg-zinc-900/60 dark:shadow-black/50 dark:hover:border-zinc-600 dark:hover:shadow-amber-500/5"
              >
                <div class="relative aspect-square overflow-hidden bg-zinc-100 dark:bg-zinc-800/50">
                  ${image}
                  ${pokedexBadge}
                </div>
                <div class="flex min-h-[4.5rem] flex-col gap-2 border-t border-zinc-200/80 bg-white/90 p-3 dark:border-zinc-800/60 dark:bg-zinc-900/80">
                  <h2 class="truncate text-sm font-semibold leading-tight text-zinc-900 sm:text-base dark:text-white">${figureName}</h2>
                  ${metaLine}
                  <div class="flex flex-wrap items-center gap-1">
                    ${lineBadge}
                    ${attributeBadges}
                    ${overflowBadge}
                  </div>
                </div>
              </a>
            `;
          })
          .join("");
      }

      function render() {
        renderTabs();
        renderFilterState();
        renderCards();
        writeStateToUrl();

        if (import.meta.env.DEV) {
          const roundTripped = readStateFromUrl();
          const serialisable = ["generation", "line", "attributes", "collection", "selectedTags", "search"];
          const ok = serialisable.every((k) => JSON.stringify(roundTripped[k]) === JSON.stringify(state[k]));
          if (!ok) console.warn("[URL round-trip] invariant violated", { state, roundTripped });
        }
      }

      async function loadFigures() {
        loadingState.classList.add("hidden");
        state.figures = window.__FIGURES__ || [];
        totalCount.textContent = String(state.figures.length);
      }

      async function loadCollections() {
        state.collections = window.__COLECCIONES__ || [];
        renderCollectionFilters();
      }

      async function loadTags() {
        state.tags = window.__ETIQUETAS__ || [];
        renderTagFilters();
      }

      // --- URL state codec (canonical source of truth for filter state) ---

      const VALID_GENERATIONS = new Set(["all", "1", "2", "3", "4", "5", "6", "7", "8", "9"]);
      const VALID_LINES = new Set(LINES.map((l) => l.value));
      const VALID_ATTRIBUTES = new Set(ATTRIBUTES.map((a) => a.value));

      function writeStateToUrl() {
        const p = new URLSearchParams();
        p.set("gen", state.generation);
        if (state.line)                      p.set("line", state.line);
        if (state.attributes.length)         p.set("attr", [...state.attributes].sort().join(","));
        if (state.collection)                p.set("col",  state.collection);
        if (state.selectedTags.length)       p.set("tag",  [...state.selectedTags].sort((a, b) => a - b).join(","));
        if (state.search)                    p.set("q",    state.search);
        const newUrl = `?${p.toString()}`;
        history.replaceState(null, "", newUrl);
      }

      function readStateFromUrl() {
        const p = new URLSearchParams(location.search);

        const gen = (p.get("gen") ?? "1").trim();
        const generation = VALID_GENERATIONS.has(gen) ? gen : "1";

        const rawLine = (p.get("line") ?? "").toLowerCase().trim();
        const line = VALID_LINES.has(rawLine) ? rawLine : null;

        const rawAttrs = (p.get("attr") ?? "").toLowerCase().trim();
        const attributes = rawAttrs
          ? rawAttrs.split(",").filter((a) => VALID_ATTRIBUTES.has(a)).sort()
          : [];

        const rawCol = (p.get("col") ?? "").toLowerCase().trim();
        const collection = rawCol || null;

        const rawTags = (p.get("tag") ?? "").trim();
        const knownTagIds = new Set(state.tags.map((t) => t.id));
        const selectedTags = rawTags
          ? rawTags.split(",").map(Number).filter((id) => !isNaN(id) && knownTagIds.has(id)).sort((a, b) => a - b)
          : [];

        const search = (p.get("q") ?? "").trim().toLowerCase();

        return { generation, line, attributes, collection, selectedTags, search };
      }

      // --- scrollY persistence (sessionStorage — non-shareable, ephemeral only) ---

      const SCROLL_KEY = "catalogScrollY";

      function saveScrollY() {
        try { sessionStorage.setItem(SCROLL_KEY, String(window.scrollY)); } catch (e) {}
      }

      function loadScrollY() {
        try {
          const raw = sessionStorage.getItem(SCROLL_KEY);
          sessionStorage.removeItem(SCROLL_KEY);
          return raw !== null ? Number(raw) : null;
        } catch (e) { return null; }
      }

      searchInput?.addEventListener("input", (event) => {
        state.search = event.target.value.toLowerCase().trim();
        if (searchClear) {
          searchClear.classList.toggle("hidden", state.search === "");
          searchClear.classList.toggle("flex", state.search !== "");
        }
        render();
      });

      searchClear?.addEventListener("click", () => {
        state.search = "";
        if (searchInput) searchInput.value = "";
        searchClear.classList.add("hidden");
        searchClear.classList.remove("flex");
        render();
      });

      resetFiltersBtn?.addEventListener("click", () => {
        state.line = null;
        state.attributes = [];
        state.collection = null;
        state.selectedTags = [];
        render();
      });

      generationTabs.addEventListener("click", (event) => {
        const button = event.target.closest("[data-generation]");
        if (!button) return;

        state.generation = button.dataset.generation;
        
        // Clear the search when explicitly switching generation tab
        if (state.search && searchInput) {
          state.search = "";
          searchInput.value = "";
        }

        render();
      });

      function openFilterPanel() {
        filterPanel.classList.remove("hidden");
        filterOverlay.classList.remove("hidden");
        filterToggle.setAttribute("aria-expanded", "true");
      }

      function closeFilterPanel() {
        filterPanel.classList.add("hidden");
        filterOverlay.classList.add("hidden");
        filterToggle.setAttribute("aria-expanded", "false");
      }

      filterToggle.addEventListener("click", () => {
        const isHidden = filterPanel.classList.contains("hidden");
        if (isHidden) {
          openFilterPanel();
        } else {
          closeFilterPanel();
        }
      });

      filterOverlay.addEventListener("click", () => {
        closeFilterPanel();
      });

      filterApplyBtn.addEventListener("click", () => {
        render();
        closeFilterPanel();
      });

      filterClearBtn.addEventListener("click", () => {
        state.line = null;
        state.attributes = [];
        state.collection = null;
        state.selectedTags = [];
        renderFilterState();
        render();
        closeFilterPanel();
      });

      lineFilters.addEventListener("click", (event) => {
        const button = event.target.closest("[data-linea]");
        if (!button) return;

        const line = button.dataset.linea;
        state.line = state.line === line ? null : line;
        render();
      });

      attributeFilters.addEventListener("click", (event) => {
        const button = event.target.closest("[data-atributo]");
        if (!button) return;

        const attribute = button.dataset.atributo;
        const index = state.attributes.indexOf(attribute);

        if (index >= 0) {
          state.attributes.splice(index, 1);
        } else {
          state.attributes.push(attribute);
        }

        render();
      });

      // Event listener for collection select
      document.querySelector("#coleccion-select")?.addEventListener("change", (event) => {
        const val = event.target.value.trim();
        state.collection = val || null;
        renderCollectionFilters();
        render();
      });

      // Event listeners for tag filters
      document.addEventListener("click", (event) => {
        const button = event.target.closest("[data-etiqueta]");
        if (!button) return;

        const tagId = Number(button.dataset.etiqueta);
        const index = state.selectedTags.indexOf(tagId);

        if (index >= 0) {
          state.selectedTags.splice(index, 1);
        } else {
          state.selectedTags.push(tagId);
        }

        render();
      });

      catalogGrid.addEventListener("click", (event) => {
        const trigger = event.target.closest(".photo-trigger");
        if (!trigger) return;

        openLightbox(trigger.dataset.figureId, Number(trigger.dataset.photoIndex || 0));
      });

      lightboxClose.addEventListener("click", closeLightbox);
      lightboxPrev.addEventListener("click", () => showNextPhoto(-1));
      lightboxNext.addEventListener("click", () => showNextPhoto(1));

      lightbox.addEventListener("click", (event) => {
        if (event.target === lightbox) {
          closeLightbox();
        }
      });

      document.addEventListener("keydown", (event) => {
        if (lightbox.classList.contains("hidden")) return;

        if (event.key === "Escape") closeLightbox();
        if (event.key === "ArrowLeft") showNextPhoto(-1);
        if (event.key === "ArrowRight") showNextPhoto(1);
      });

      function init() {
        loadFigures();
        loadCollections();
        loadTags();

        const fromUrl = readStateFromUrl();
        state.generation   = fromUrl.generation;
        state.line         = fromUrl.line;
        state.attributes   = fromUrl.attributes;
        state.collection   = fromUrl.collection;
        state.selectedTags = fromUrl.selectedTags;
        state.search       = fromUrl.search;

        if (searchInput) searchInput.value = state.search;
        if (searchClear) {
          searchClear.classList.toggle("hidden", state.search === "");
          searchClear.classList.toggle("flex", state.search !== "");
        }

        render();

        const scrollY = loadScrollY();
        if (scrollY !== null) {
          requestAnimationFrame(() => {
            window.scrollTo({ top: scrollY, behavior: "instant" });
          });
        }
      }

      init();

      window.addEventListener("beforeunload", saveScrollY);
      window.addEventListener("pagehide", saveScrollY);
    </script>
</BaseLayout>