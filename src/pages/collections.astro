---
import BaseLayout from "../components/BaseLayout.astro";
import CollectionCard from "../components/CollectionCard.astro";
import { getCatalog } from "../lib/catalogCache";
import { createSlug } from "../lib/slug";
import { sortCollections, formatCollectionDate } from "../lib/collectionSort";
import { normalizeLine } from "../lib/figureTaxonomy";
import { collectionsMeta, collectionsListSchema, breadcrumbSchema, absoluteImageUrl } from "../lib/seo";

const monthNames = [
  "January", "February", "March", "April", "May", "June",
  "July", "August", "September", "October", "November", "December"
];

const { figures, collections, releases } = await getCatalog();

const sortedCollections = sortCollections(collections, releases).map((collection) => {
  const collectionSlug = createSlug(collection.name);
  const collectionReleases = releases
    .filter((release) => release.collection_id === collection.id)
    .sort((a, b) => (a.number ?? 0) - (b.number ?? 0));

  const releaseIds = new Set(collectionReleases.map((release) => release.id));
  const collectionFigures = figures.filter((figure) => releaseIds.has(figure.release_id));
  const figureCount = collectionFigures.length;
  const releaseCount = collectionReleases.length;
  const coverImage = collectionReleases.find((release) => release.cover_image)?.cover_image;
  const dateLabel = formatCollectionDate(collection.id, releases, monthNames);

  const lineValues = new Set(
    collectionFigures
      .map((figure) => normalizeLine(figure.line))
      .filter(Boolean)
  );
  const lines = Array.from(lineValues).sort();

  return {
    collection,
    collectionSlug,
    figureCount,
    releaseCount,
    coverImage,
    dateLabel,
    lines,
  };
});

const totalFigures = sortedCollections.reduce((sum, item) => sum + item.figureCount, 0);
const siteUrl = Astro.site?.toString() || "https://example.com";
const seo = collectionsMeta(sortedCollections.length, totalFigures, siteUrl);
const schemas = [
  collectionsListSchema(
    sortedCollections.map((item) => ({
      name: item.collection.name,
      slug: item.collectionSlug,
      figuresCount: item.figureCount,
      coverImage: item.coverImage ? absoluteImageUrl(siteUrl, item.coverImage) : undefined,
    })),
    siteUrl
  ),
  breadcrumbSchema([{ label: "Collections" }], siteUrl),
];
---

<BaseLayout title={seo.title} description={seo.description} seo={seo} schemas={schemas}>
  <main class="mx-auto min-h-screen w-full max-w-7xl px-4 pb-24 pt-5 sm:px-6 lg:px-8">
    <header class="mb-8 space-y-3">
      <p class="text-xs font-bold uppercase tracking-[0.2em] text-amber-600 dark:text-amber-300">Pokémon Tomy Catalogue</p>
      <h1 class="text-4xl font-semibold leading-tight text-zinc-900 sm:text-5xl dark:text-white">
        Collections
      </h1>
      <p class="max-w-2xl text-base text-zinc-600 dark:text-zinc-400">
        {sortedCollections.length} collections · {totalFigures} figures, organised chronologically.
      </p>
    </header>

    {sortedCollections.length > 0 ? (
      <section class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {sortedCollections.map((item) => (
          <CollectionCard
            collection={item.collection}
            collectionSlug={item.collectionSlug}
            figureCount={item.figureCount}
            releaseCount={item.releaseCount}
            coverImage={item.coverImage}
            dateLabel={item.dateLabel}
            lines={item.lines}
          />
        ))}
      </section>
    ) : (
      <p class="rounded-xl border border-zinc-200 bg-zinc-50 p-6 text-center text-zinc-600 dark:border-zinc-800 dark:bg-zinc-900 dark:text-zinc-400">
        No collections found.
      </p>
    )}
  </main>
</BaseLayout>
