---
import BaseLayout from "../../components/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import BackLink from "../../components/BackLink.astro";
import ReleaseCard from "../../components/ReleaseCard.astro";
import FigureCard from "../../components/FigureCard.astro";
import EmptyState from "../../components/EmptyState.astro";
import { getCatalog, getTagsForFigure } from "../../lib/catalogCache";
import { createSlug } from "../../lib/slug";
import { sortCollections } from "../../lib/collectionSort";
import PrevNextNav from "../../components/PrevNextNav.astro";
import { collectionMeta, collectionSchema, breadcrumbSchema, absoluteImageUrl, addImage } from "../../lib/seo";

export async function getStaticPaths() {
  const { collections } = await getCatalog();

  return collections.map((col: any) => ({
    params: { slug: createSlug(col.name) },
  }));
}

const { slug } = Astro.params;

const { figures, collections, releases, figureTags } = await getCatalog();

const collection = collections.find((c: any) => createSlug(c.name) === slug);

if (!collection) {
  return Astro.redirect("/404");
}

const sortedCollections = sortCollections(collections, releases);
const currentCollectionIndex = sortedCollections.findIndex((c: any) => c.id === collection.id);
const prevCollection = currentCollectionIndex > 0 ? sortedCollections[currentCollectionIndex - 1] : null;
const nextCollection = currentCollectionIndex >= 0 && currentCollectionIndex < sortedCollections.length - 1
  ? sortedCollections[currentCollectionIndex + 1]
  : null;

const prevNav = prevCollection
  ? { href: `/collection/${createSlug(prevCollection.name)}/`, label: prevCollection.name }
  : null;
const nextNav = nextCollection
  ? { href: `/collection/${createSlug(nextCollection.name)}/`, label: nextCollection.name }
  : null;

const collectionReleases = releases
  .filter((r: any) => r.collection_id === collection.id)
  .sort((a: any, b: any) => (a.number || Number.MAX_SAFE_INTEGER) - (b.number || Number.MAX_SAFE_INTEGER));

const releaseIds = new Set(collectionReleases.map((r: any) => r.id));

const collectionFigures = figures
  .filter((f: any) => releaseIds.has(f.release_id))
  .sort((a: any, b: any) => (a.visual_order ?? 0) - (b.visual_order ?? 0));

const figuresWithTags = collectionFigures.map((f: any) => ({
  ...f,
  tags: getTagsForFigure(f.id, figureTags)
}));

const siteUrl = Astro.site?.toString() || "https://example.com";
const coverImageUrls = collectionReleases
  .map((r: any) => r.cover_image)
  .filter((url): url is string => typeof url === "string")
  .map((url) => absoluteImageUrl(siteUrl, url))
  .filter((url): url is string => typeof url === "string");

const breadcrumbItems = [
  { label: "Collections", href: "/collections/" },
  { label: collection.name },
];
const seo = collectionMeta(collection, collectionReleases.length, figuresWithTags.length, siteUrl);
const imageSeo = coverImageUrls.length > 0 ? addImage(seo, coverImageUrls[0]) : seo;
const schemas = [
  collectionSchema(collection, siteUrl, figuresWithTags.length, coverImageUrls),
  breadcrumbSchema(breadcrumbItems, siteUrl),
];
---

<BaseLayout title={imageSeo.title} description={imageSeo.description} seo={imageSeo} schemas={schemas}>
  <main class="mx-auto min-h-screen w-full max-w-7xl px-4 pb-24 pt-5 sm:px-6 lg:px-8">
    
    <Breadcrumb items={breadcrumbItems} />

    <header class="mb-5 flex flex-col gap-4 sm:mb-8 sm:flex-row sm:items-end sm:justify-between">
      <div class="space-y-2">
        <BackLink href="/collections/" text="Back to collections" />
        <h1 class="max-w-3xl text-4xl font-semibold leading-tight text-zinc-900 sm:text-6xl dark:text-white">
          {collection.name}
        </h1>
        <p class="max-w-2xl text-sm leading-6 text-zinc-600 sm:text-base dark:text-zinc-400">
          {collectionReleases?.length || 0} releases · {figuresWithTags.length} figures
        </p>
      </div>
    </header>

    <div class="mb-8">
      <PrevNextNav prev={prevNav} next={nextNav} />
    </div>

    {/* Collection releases */}
    {collectionReleases && collectionReleases.length > 0 && (
      <section class="mb-8">
        <h2 class="mb-4 text-xl font-semibold text-zinc-900 dark:text-white">Releases</h2>
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6">
          {collectionReleases.map((rel: any) => (
            <ReleaseCard collectionSlug={slug} release={rel} />
          ))}
        </div>
      </section>
    )}

    {/* Collection figures */}
    <section>
      <h2 class="mb-4 text-xl font-semibold text-zinc-900 dark:text-white">All figures</h2>
      {figuresWithTags.length > 0 ? (
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 sm:gap-4 lg:grid-cols-4">
          {figuresWithTags.map((fig: any) => (
            <FigureCard figure={fig} showRelease />
          ))}
        </div>
      ) : (
        <EmptyState message="No figures in this collection." />
      )}
    </section>

  </main>
</BaseLayout>
