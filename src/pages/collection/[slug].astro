---
import BaseLayout from "../../components/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import BackLink from "../../components/BackLink.astro";
import VolumeCard from "../../components/VolumeCard.astro";
import FigureCard from "../../components/FigureCard.astro";
import EmptyState from "../../components/EmptyState.astro";
import { getCatalog, getTagsForFigure } from "../../lib/catalogCache";
import { createSlug } from "../../lib/slug";
import { collectionMeta, collectionSchema, breadcrumbSchema, absoluteImageUrl, addImage } from "../../lib/seo";

export async function getStaticPaths() {
  const { collections } = await getCatalog();

  return collections.map((coleccion: any) => ({
    params: { slug: createSlug(coleccion.name) },
  }));
}

const { slug } = Astro.params;

const { figures, collections, volumes, figureTags } = await getCatalog();

const coleccion = collections.find((c: any) => createSlug(c.name) === slug);

if (!coleccion) {
  return Astro.redirect("/404");
}

const volumenes = volumes
  .filter((v: any) => v.collection_id === coleccion.id)
  .sort((a: any, b: any) => (a.volume ?? 0) - (b.volume ?? 0));

const volumenIds = new Set(volumenes.map((v: any) => v.id));

const figuras = figures
  .filter((f: any) => volumenIds.has(f.volume_id))
  .sort((a: any, b: any) => (a.visual_order ?? 0) - (b.visual_order ?? 0));

const figurasConEtiquetas = figuras.map((f: any) => ({
  ...f,
  etiquetas: getTagsForFigure(f.id, figureTags)
}));

const siteUrl = Astro.site?.toString() || "https://example.com";
const coverImageUrls = volumenes
  .map((v: any) => v.cover_image)
  .filter((url): url is string => typeof url === "string")
  .map((url) => absoluteImageUrl(siteUrl, url))
  .filter((url): url is string => typeof url === "string");

const breadcrumbItems = [{ label: coleccion.name }];
const seo = collectionMeta(coleccion, volumenes.length, figurasConEtiquetas.length, siteUrl);
const imageSeo = coverImageUrls.length > 0 ? addImage(seo, coverImageUrls[0]) : seo;
const schemas = [
  collectionSchema(coleccion, siteUrl, figurasConEtiquetas.length, coverImageUrls),
  breadcrumbSchema(breadcrumbItems, siteUrl),
];
---

<BaseLayout title={imageSeo.title} description={imageSeo.description} seo={imageSeo} schemas={schemas}>
  <main class="mx-auto min-h-screen w-full max-w-7xl px-4 pb-24 pt-5 sm:px-6 lg:px-8">
    
    <Breadcrumb items={breadcrumbItems} />

    <header class="mb-5 flex flex-col gap-4 sm:mb-8 sm:flex-row sm:items-end sm:justify-between">
      <div class="space-y-2">
        <BackLink href="/" text="Volver al catálogo" />
        <h1 class="max-w-3xl text-4xl font-semibold leading-tight text-white sm:text-6xl">
          {coleccion.name}
        </h1>
        <p class="max-w-2xl text-sm leading-6 text-zinc-400 sm:text-base">
          {volumenes?.length || 0} volúmenes · {figurasConEtiquetas.length} figuras
        </p>
      </div>
    </header>

    {/* Volúmenes de la colección */}
    {volumenes && volumenes.length > 0 && (
      <section class="mb-8">
        <h2 class="mb-4 text-xl font-semibold text-white">Volúmenes</h2>
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6">
          {volumenes.map((volumen: any) => (
            <VolumeCard collectionSlug={slug} volume={volumen} />
          ))}
        </div>
      </section>
    )}

    {/* Figuras de la colección */}
    <section>
      <h2 class="mb-4 text-xl font-semibold text-white">Todas las figuras</h2>
      {figurasConEtiquetas.length > 0 ? (
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 sm:gap-4 lg:grid-cols-4">
          {figurasConEtiquetas.map((figura: any) => (
            <FigureCard figure={figura} showVolume />
          ))}
        </div>
      ) : (
        <EmptyState message="No hay figuras en esta colección." />
      )}
    </section>

  </main>
</BaseLayout>
