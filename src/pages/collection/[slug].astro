---
import BaseLayout from "../../components/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import BackLink from "../../components/BackLink.astro";
import VolumeCard from "../../components/VolumeCard.astro";
import FigureCard from "../../components/FigureCard.astro";
import EmptyState from "../../components/EmptyState.astro";
import { getCatalog, getTagsForFigure } from "../../lib/catalogCache";
import { createSlug } from "../../lib/slug";
import { collectionMeta, collectionSchema, breadcrumbSchema, absoluteImageUrl, addImage } from "../../lib/seo";

export async function getStaticPaths() {
  const { collections } = await getCatalog();

  return collections.map((col: any) => ({
    params: { slug: createSlug(col.name) },
  }));
}

const { slug } = Astro.params;

const { figures, collections, volumes, figureTags } = await getCatalog();

const collection = collections.find((c: any) => createSlug(c.name) === slug);

if (!collection) {
  return Astro.redirect("/404");
}

const collectionVolumes = volumes
  .filter((v: any) => v.collection_id === collection.id)
  .sort((a: any, b: any) => (a.volume ?? 0) - (b.volume ?? 0));

const volumeIds = new Set(collectionVolumes.map((v: any) => v.id));

const collectionFigures = figures
  .filter((f: any) => volumeIds.has(f.volume_id))
  .sort((a: any, b: any) => (a.visual_order ?? 0) - (b.visual_order ?? 0));

const figuresWithTags = collectionFigures.map((f: any) => ({
  ...f,
  tags: getTagsForFigure(f.id, figureTags)
}));

const siteUrl = Astro.site?.toString() || "https://example.com";
const coverImageUrls = collectionVolumes
  .map((v: any) => v.cover_image)
  .filter((url): url is string => typeof url === "string")
  .map((url) => absoluteImageUrl(siteUrl, url))
  .filter((url): url is string => typeof url === "string");

const breadcrumbItems = [{ label: collection.name }];
const seo = collectionMeta(collection, collectionVolumes.length, figuresWithTags.length, siteUrl);
const imageSeo = coverImageUrls.length > 0 ? addImage(seo, coverImageUrls[0]) : seo;
const schemas = [
  collectionSchema(collection, siteUrl, figuresWithTags.length, coverImageUrls),
  breadcrumbSchema(breadcrumbItems, siteUrl),
];
---

<BaseLayout title={imageSeo.title} description={imageSeo.description} seo={imageSeo} schemas={schemas}>
  <main class="mx-auto min-h-screen w-full max-w-7xl px-4 pb-24 pt-5 sm:px-6 lg:px-8">
    
    <Breadcrumb items={breadcrumbItems} />

    <header class="mb-5 flex flex-col gap-4 sm:mb-8 sm:flex-row sm:items-end sm:justify-between">
      <div class="space-y-2">
        <BackLink href="/" text="Back to catalogue" />
        <h1 class="max-w-3xl text-4xl font-semibold leading-tight text-zinc-900 sm:text-6xl dark:text-white">
          {collection.name}
        </h1>
        <p class="max-w-2xl text-sm leading-6 text-zinc-600 sm:text-base dark:text-zinc-400">
          {collectionVolumes?.length || 0} volumes · {figuresWithTags.length} figures
        </p>
      </div>
    </header>

    {/* Collection volumes */}
    {collectionVolumes && collectionVolumes.length > 0 && (
      <section class="mb-8">
        <h2 class="mb-4 text-xl font-semibold text-zinc-900 dark:text-white">Volumes</h2>
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6">
          {collectionVolumes.map((vol: any) => (
            <VolumeCard collectionSlug={slug} volume={vol} />
          ))}
        </div>
      </section>
    )}

    {/* Collection figures */}
    <section>
      <h2 class="mb-4 text-xl font-semibold text-zinc-900 dark:text-white">All figures</h2>
      {figuresWithTags.length > 0 ? (
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 sm:gap-4 lg:grid-cols-4">
          {figuresWithTags.map((fig: any) => (
            <FigureCard figure={fig} showVolume />
          ))}
        </div>
      ) : (
        <EmptyState message="No figures in this collection." />
      )}
    </section>

  </main>
</BaseLayout>
