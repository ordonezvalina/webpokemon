---
import BaseLayout from "../../../../components/BaseLayout.astro";
import Breadcrumb from "../../../../components/Breadcrumb.astro";
import BackLink from "../../../../components/BackLink.astro";
import FigureCard from "../../../../components/FigureCard.astro";
import EmptyState from "../../../../components/EmptyState.astro";
import PrevNextNav from "../../../../components/PrevNextNav.astro";
import { getCatalog, getTagsForFigure } from "../../../../lib/catalogCache";
import { createSlug } from "../../../../lib/slug";
import { releaseMeta, collectionSchema, breadcrumbSchema, absoluteImageUrl, addImage } from "../../../../lib/seo";

function releaseLabel(release: any): string {
  const number = release.number;
  const name = release.name;

  if (number != null && !name) return `Release ${number}`;
  if (!number && name) return name;
  if (number != null && name) return `Release ${number} - ${name}`;
  return "Release";
}

function formatReleaseDate(date: string | null | undefined): string | null {
  if (!date) return null;
  const d = new Date(date);
  if (Number.isNaN(d.getTime())) return null;
  return d.toLocaleDateString("es-ES", { year: "numeric", month: "long" });
}

export async function getStaticPaths() {
  const { collections, releases } = await getCatalog();

  return releases.map((rel: any) => {
    const col = collections.find((c: any) => c.id === rel.collection_id);
    const collectionSlug = createSlug(col?.name ?? "");
    const releaseSlug = rel.name ? createSlug(rel.name) : String(rel.number ?? "");
    return {
      params: {
        slug: collectionSlug,
        release: releaseSlug
      },
    };
  });
}

const { slug, release: releaseParam } = Astro.params;

const { figures, collections, releases, figureTags } = await getCatalog();

const collection = collections.find((c: any) => createSlug(c.name) === slug);

if (!collection) {
  return Astro.redirect("/404");
}

const release = releases.find((r: any) => {
  const releaseSlug = r.name ? createSlug(r.name) : String(r.number ?? "");
  return r.collection_id === collection.id && releaseSlug === releaseParam;
});

if (!release) {
  return Astro.redirect("/404");
}

const releaseFigures = figures
  .filter((f: any) => f.release_id === release.id)
  .sort((a: any, b: any) => (a.visual_order ?? 0) - (b.visual_order ?? 0));

const figuresWithTags = releaseFigures.map((f: any) => ({
  ...f,
  tags: getTagsForFigure(f.id, figureTags)
}));

const siblingReleases = releases
  .filter((r: any) => r.collection_id === collection.id)
  .sort((a: any, b: any) => (a.number || Number.MAX_SAFE_INTEGER) - (b.number || Number.MAX_SAFE_INTEGER));
const currentReleaseIndex = siblingReleases.findIndex((r: any) => r.id === release.id);
const prevRelease = currentReleaseIndex > 0 ? siblingReleases[currentReleaseIndex - 1] : null;
const nextRelease = currentReleaseIndex >= 0 && currentReleaseIndex < siblingReleases.length - 1
  ? siblingReleases[currentReleaseIndex + 1]
  : null;

const releaseHref = (r: any) => `/collection/${slug}/release/${r.name ? createSlug(r.name) : String(r.number ?? "")}/`;
const prevNav = prevRelease ? { href: releaseHref(prevRelease), label: releaseLabel(prevRelease) } : null;
const nextNav = nextRelease ? { href: releaseHref(nextRelease), label: releaseLabel(nextRelease) } : null;

const siteUrl = Astro.site?.toString() || "https://example.com";
const coverImageUrl = release.cover_image ? absoluteImageUrl(siteUrl, release.cover_image) : undefined;
const breadcrumbItems = [
  { label: "Collections", href: "/collections/" },
  { label: collection.name, href: `/collection/${slug}/` },
  { label: releaseLabel(release) }
];
const seo = releaseMeta(collection, release, figuresWithTags.length, siteUrl);
const imageSeo = coverImageUrl ? addImage(seo, coverImageUrl) : seo;
const schemas = [
  collectionSchema(collection, siteUrl, figuresWithTags.length, coverImageUrl ? [coverImageUrl] : undefined),
  breadcrumbSchema(breadcrumbItems, siteUrl),
];
---

<BaseLayout title={imageSeo.title} description={imageSeo.description} seo={imageSeo} schemas={schemas}>
  <main class="mx-auto min-h-screen w-full max-w-7xl px-4 pb-24 pt-5 sm:px-6 lg:px-8">
    
    <Breadcrumb items={breadcrumbItems} />

    <header class="mb-5 flex flex-col gap-4 sm:mb-8 sm:flex-row sm:items-end sm:justify-between">
      <div class="space-y-2">
        <BackLink href={`/collection/${slug}/`} text={`Back to ${collection.name}`} />
        <h1 class="max-w-3xl text-4xl font-semibold leading-tight text-zinc-900 sm:text-6xl dark:text-white">
          {releaseLabel(release)}
        </h1>
        <p class="max-w-2xl text-sm leading-6 text-zinc-600 sm:text-base dark:text-zinc-400">
          {collection.name}
          {release.name ? ` · ${release.name}` : ""} · {figuresWithTags.length} figures
        </p>
      </div>
    </header>

    {(release.product_code || release.release_date) && (
      <section class="mb-5">
        <div class="rounded-xl border border-zinc-200 bg-zinc-50/70 p-4 space-y-3 dark:border-zinc-800 dark:bg-zinc-900/40">
          {release.release_date && (
            <div class="flex justify-between items-center text-sm border-b border-zinc-200/80 pb-2 dark:border-zinc-800/60">
              <span class="text-zinc-500 font-medium dark:text-zinc-500">Release date</span>
              <span class="text-zinc-800 font-semibold dark:text-zinc-200">{formatReleaseDate(release.release_date)}</span>
            </div>
          )}

          {release.product_code && (
            <div class="flex justify-between items-center text-sm">
              <span class="text-zinc-500 font-medium dark:text-zinc-500">Official site</span>
              <a
                href={`https://www.takaratomy-arts.co.jp/items/item.html?n=${release.product_code}`}
                target="_blank"
                rel="noopener noreferrer"
                class="text-amber-700 hover:underline font-mono text-xs dark:text-amber-300"
              >
                {release.product_code} ↗
              </a>
            </div>
          )}
        </div>
      </section>
    )}

    {/* Release cover image */}
    {release.cover_image && (
      <section class="mb-8">
        <div class="max-w-md lg:max-w-lg lg:mx-auto overflow-hidden rounded-xl border border-zinc-200 bg-white shadow-xl shadow-zinc-900/10 cursor-zoom-in dark:border-zinc-800 dark:bg-zinc-900 dark:shadow-black/20">
          <img
            id="release-cover"
            class="h-full w-full object-cover"
            src={release.cover_image}
            alt={`Cover of ${releaseLabel(release)}`}
            fetchpriority="high"
            decoding="async"
          />
        </div>
      </section>
    )}

    {/* Previous / next release navigation - desktop */}
    <div class="hidden lg:block mb-8">
      <div class="max-w-md lg:max-w-lg mx-auto">
        <PrevNextNav prev={prevNav} next={nextNav} />
      </div>
    </div>

    {/* Release figures */}
    <section>
      <h2 class="mb-4 text-xl font-semibold text-zinc-900 dark:text-white">Figures in this release</h2>
      {figuresWithTags.length > 0 ? (
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 sm:gap-4 lg:grid-cols-4">
          {figuresWithTags.map((fig: any) => (
            <FigureCard figure={fig} />
          ))}
        </div>
      ) : (
        <EmptyState message="No figures in this release." />
      )}
    </section>

    {/* Previous / next release navigation - mobile */}
    <div class="mt-10 lg:hidden">
      <PrevNextNav prev={prevNav} next={nextNav} />
    </div>

  </main>

  {/* Lightbox */}
  <div
    id="lightbox"
    class="hidden fixed inset-0 z-50 overflow-auto bg-black/95 p-4 cursor-zoom-out flex"
  >
    <button class="fixed top-4 right-4 text-zinc-900 text-4xl font-light active:scale-95 z-50 bg-white/80 rounded-full w-12 h-12 flex items-center justify-center dark:text-white dark:bg-black/40" aria-label="Close modal">&times;</button>
    <img
      id="lightbox-img"
      class="max-w-none max-h-none rounded-lg shadow-2xl m-auto"
      src=""
      alt="Full screen view"
    />
  </div>

  <script>
    const releaseCover = document.getElementById("release-cover") as HTMLImageElement | null;
    const lightbox = document.getElementById("lightbox");
    const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement | null;

    if (releaseCover && lightbox && lightboxImg) {
      releaseCover.addEventListener("click", () => {
        lightboxImg.src = releaseCover.src;
        lightbox.classList.remove("hidden");
        document.body.classList.add("overflow-hidden");
      });
    }

    lightbox?.addEventListener("click", () => {
      lightbox.classList.add("hidden");
      document.body.classList.remove("overflow-hidden");
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && lightbox && !lightbox.classList.contains("hidden")) {
        lightbox.classList.add("hidden");
        document.body.classList.remove("overflow-hidden");
      }
    });
  </script>
</BaseLayout>
