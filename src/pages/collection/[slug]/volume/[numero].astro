---
import "../../../../styles/global.css";
import { getCatalog, getTagsForFigure } from "../../../../lib/catalogCache";
import { createSlug } from "../../../../lib/slug";
import { getFigurePhotos } from "../../../../lib/figurePhotos";
import { getLineaLabel, getFigureAtributos, getAtributoLabel } from "../../../../lib/figureTaxonomy";

function escapeHtml(value: string): string {
  return String(value ?? "")
    .replaceAll("&", "&amp;")
    .replaceAll("<", "&lt;")
    .replaceAll(">", "&gt;")
    .replaceAll('"', "&quot;")
    .replaceAll("'", "&#039;");
}

function getAtributoClass(atributo: string): string {
  const atributoClasses: { [key: string]: string } = {
    brillante: "border-fuchsia-300/50 bg-fuchsia-300/12 text-fuchsia-100",
    shiny: "border-amber-300/60 bg-amber-300/14 text-amber-100",
    clear: "border-cyan-300/50 bg-cyan-300/12 text-cyan-100",
    mega: "border-rose-300/55 bg-rose-300/12 text-rose-100",
    "con-base": "border-emerald-300/55 bg-emerald-300/12 text-emerald-100"
  };
  return atributoClasses[atributo] || "border-indigo-300/50 bg-indigo-300/12 text-indigo-100";
}

export async function getStaticPaths() {
  const { collections, volumes } = await getCatalog();

  return volumes.map((volumen: any) => {
    const coleccion = collections.find((c: any) => c.id === volumen.collection_id);
    const coleccionSlug = createSlug(coleccion?.name ?? "");
    const volumenSlug = volumen.name_eng ? createSlug(volumen.name_eng) : String(volumen.volume);
    return {
      params: {
        slug: coleccionSlug,
        numero: volumenSlug
      },
    };
  });
}

const { slug, numero } = Astro.params;

const { figures, collections, volumes, figureTags } = await getCatalog();

const coleccion = collections.find((c: any) => createSlug(c.name) === slug);

if (!coleccion) {
  return Astro.redirect("/404");
}

const volumen = volumes.find((v: any) => {
  const volumenSlug = v.name_eng ? createSlug(v.name_eng) : String(v.volume);
  return v.collection_id === coleccion.id && volumenSlug === numero;
});

if (!volumen) {
  return Astro.redirect("/404");
}

const figuras = figures
  .filter((f: any) => f.volume_id === volumen.id)
  .sort((a: any, b: any) => (a.visual_order ?? 0) - (b.visual_order ?? 0));

const figurasConEtiquetas = figuras.map((f: any) => ({
  ...f,
  etiquetas: getTagsForFigure(f.id, figureTags)
}));
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{coleccion.name} - Vol. {volumen.volume} | Mi Colección</title>
  </head>
  <body class="bg-zinc-950 text-zinc-100 antialiased">
    <main class="mx-auto min-h-screen w-full max-w-7xl px-4 pb-24 pt-5 sm:px-6 lg:px-8">
      
      <header class="mb-5 flex flex-col gap-4 sm:mb-8 sm:flex-row sm:items-end sm:justify-between">
        <div class="space-y-2">
          <a
            href={`/collection/${slug}`}
            class="inline-flex items-center gap-2 text-sm font-semibold text-zinc-400 hover:text-zinc-200 transition"
          >
            ← Volver a {coleccion.name}
          </a>
          <h1 class="max-w-3xl text-4xl font-semibold leading-tight text-white sm:text-6xl">
            Vol. {volumen.volume}
          </h1>
          <p class="max-w-2xl text-sm leading-6 text-zinc-400 sm:text-base">
            {coleccion.name}
            {volumen.name_eng ? ` · ${volumen.name_eng}` : ""} · {figurasConEtiquetas.length} figuras
          </p>
        </div>
      </header>

      {/* Imagen de portada del volumen */}
      {volumen.cover_image && (
        <section class="mb-8">
          <div class="max-w-xs overflow-hidden rounded-xl border border-zinc-800 bg-zinc-900">
            <img
              class="h-full w-full object-cover"
              src={volumen.cover_image}
              alt={`Portada Vol. ${volumen.volume}`}
            />
          </div>
        </section>
      )}

      {/* Figuras del volumen */}
      <section>
        <h2 class="mb-4 text-xl font-semibold text-white">Figuras de este volumen</h2>
        {figurasConEtiquetas.length > 0 ? (
          <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 sm:gap-4 lg:grid-cols-4 xl:grid-cols-5">
            {figurasConEtiquetas.map((figura: any) => {
              const fotos = getFigurePhotos(figura);
              const atributos = getFigureAtributos(figura);

              const image = fotos.length > 0 ? (
                <img
                  class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.03]"
                  src={fotos[0]}
                  alt={figura.pokemon?.full_names?.es}
                  loading="lazy"
                />
              ) : (
                <div class="grid h-full w-full place-items-center bg-zinc-800 text-sm font-semibold text-zinc-500">
                  #{String(figura.pokemon?.pokedex_number).padStart(4, "0")}
                </div>
              );

              return (
                <a
                  href={`/figure/${escapeHtml(figura.slug ?? figura.id)}`}
                  class="group block overflow-hidden rounded-lg border border-zinc-800 bg-zinc-900 shadow-lg shadow-black/20 transition duration-300 hover:-translate-y-0.5 hover:border-zinc-600"
                >
                  <div class="aspect-[4/5] overflow-hidden bg-zinc-800">
                    {image}
                  </div>
                  <div class="space-y-3 p-3">
                    <div class="flex items-start justify-between gap-2">
                      <div class="min-w-0">
                        <h2 class="truncate text-sm font-semibold text-white sm:text-base">{escapeHtml(figura.pokemon?.full_names?.es)}</h2>
                        {figura.year && <p class="mt-1 text-xs font-medium text-zinc-500">{escapeHtml(figura.year)}</p>}
                      </div>
                      <div class="flex max-w-[52%] flex-wrap justify-end gap-1">
                        <span class="shrink-0 rounded-md border border-zinc-600 bg-zinc-700/55 px-2 py-1 text-[11px] font-bold text-zinc-100">
                          {escapeHtml(getLineaLabel(figura.line))}
                        </span>
                        {atributos.map((atributo: string) => (
                          <a href={`/attribute/${createSlug(atributo)}`} class:list={["shrink-0 rounded-md border px-2 py-1 text-[11px] font-bold hover:opacity-80 transition", getAtributoClass(atributo)]}>
                            {escapeHtml(getAtributoLabel(atributo))}
                          </a>
                        ))}
                      </div>
                    </div>
                    {figura.details && <p class="line-clamp-2 text-xs leading-5 text-zinc-400">{escapeHtml(figura.details)}</p>}
                  </div>
                </a>
              );
            })}
          </div>
        ) : (
          <div class="rounded-lg border border-dashed border-zinc-700 bg-zinc-900/50 p-8 text-center">
            <p class="text-base font-semibold text-white">No hay figuras en este volumen.</p>
          </div>
        )}
      </section>

    </main>
  </body>
</html>
