---
import BaseLayout from "../../../../components/BaseLayout.astro";
import Breadcrumb from "../../../../components/Breadcrumb.astro";
import BackLink from "../../../../components/BackLink.astro";
import FigureCard from "../../../../components/FigureCard.astro";
import EmptyState from "../../../../components/EmptyState.astro";
import { getCatalog, getTagsForFigure } from "../../../../lib/catalogCache";
import { createSlug } from "../../../../lib/slug";
import { volumeMeta, collectionSchema, breadcrumbSchema, absoluteImageUrl, addImage } from "../../../../lib/seo";

export async function getStaticPaths() {
  const { collections, volumes } = await getCatalog();

  return volumes.map((vol: any) => {
    const col = collections.find((c: any) => c.id === vol.collection_id);
    const collectionSlug = createSlug(col?.name ?? "");
    const volumeSlug = vol.name_eng ? createSlug(vol.name_eng) : String(vol.volume);
    return {
      params: {
        slug: collectionSlug,
        numero: volumeSlug
      },
    };
  });
}

const { slug, numero } = Astro.params;

const { figures, collections, volumes, figureTags } = await getCatalog();

const collection = collections.find((c: any) => createSlug(c.name) === slug);

if (!collection) {
  return Astro.redirect("/404");
}

const volume = volumes.find((v: any) => {
  const volumeSlug = v.name_eng ? createSlug(v.name_eng) : String(v.volume);
  return v.collection_id === collection.id && volumeSlug === numero;
});

if (!volume) {
  return Astro.redirect("/404");
}

const volumeFigures = figures
  .filter((f: any) => f.volume_id === volume.id)
  .sort((a: any, b: any) => (a.visual_order ?? 0) - (b.visual_order ?? 0));

const figuresWithTags = volumeFigures.map((f: any) => ({
  ...f,
  tags: getTagsForFigure(f.id, figureTags)
}));

const siteUrl = Astro.site?.toString() || "https://example.com";
const coverImageUrl = volume.cover_image ? absoluteImageUrl(siteUrl, volume.cover_image) : undefined;
const breadcrumbItems = [
  { label: collection.name, href: `/collection/${slug}/` },
  { label: `Vol. ${volume.volume}` }
];
const seo = volumeMeta(collection, volume, figuresWithTags.length, siteUrl);
const imageSeo = coverImageUrl ? addImage(seo, coverImageUrl) : seo;
const schemas = [
  collectionSchema(collection, siteUrl, figuresWithTags.length, coverImageUrl ? [coverImageUrl] : undefined),
  breadcrumbSchema(breadcrumbItems, siteUrl),
];
---

<BaseLayout title={imageSeo.title} description={imageSeo.description} seo={imageSeo} schemas={schemas}>
  <main class="mx-auto min-h-screen w-full max-w-7xl px-4 pb-24 pt-5 sm:px-6 lg:px-8">
    
    <Breadcrumb items={breadcrumbItems} />

    <header class="mb-5 flex flex-col gap-4 sm:mb-8 sm:flex-row sm:items-end sm:justify-between">
      <div class="space-y-2">
        <BackLink href={`/collection/${slug}/`} text={`Back to ${collection.name}`} />
        <h1 class="max-w-3xl text-4xl font-semibold leading-tight text-zinc-900 sm:text-6xl dark:text-white">
          Vol. {volume.volume}
        </h1>
        <p class="max-w-2xl text-sm leading-6 text-zinc-600 sm:text-base dark:text-zinc-400">
          {collection.name}
          {volume.name_eng ? ` · ${volume.name_eng}` : ""} · {figuresWithTags.length} figures
        </p>
      </div>
    </header>

    {/* Volume cover image */}
    {volume.cover_image && (
      <section class="mb-8">
        <div class="max-w-xs overflow-hidden rounded-xl border border-zinc-200 bg-white dark:border-zinc-800 dark:bg-zinc-900">
          <img
            class="h-full w-full object-cover"
            src={volume.cover_image}
            alt={`Cover of volume ${volume.volume}${volume.name_eng ? ` · ${volume.name_eng}` : ""}`}
            loading="lazy"
            decoding="async"
          />
        </div>
      </section>
    )}

    {/* Volume figures */}
    <section>
      <h2 class="mb-4 text-xl font-semibold text-zinc-900 dark:text-white">Figures in this volume</h2>
      {figuresWithTags.length > 0 ? (
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 sm:gap-4 lg:grid-cols-4">
          {figuresWithTags.map((fig: any) => (
            <FigureCard figure={fig} />
          ))}
        </div>
      ) : (
        <EmptyState message="No figures in this volume." />
      )}
    </section>

  </main>
</BaseLayout>
