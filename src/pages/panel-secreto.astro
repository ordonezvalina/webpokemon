---
import "../styles/global.css";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Panel privado</title>
  </head>
  <body class="bg-zinc-950 text-zinc-100 antialiased">
    <main class="mx-auto min-h-screen w-full max-w-md px-4 pb-28 pt-4">
      <header class="sticky top-0 z-20 -mx-4 border-b border-zinc-800 bg-zinc-950/90 px-4 pb-4 pt-3 backdrop-blur">
        <div class="flex items-center justify-between gap-3">
          <div>
            <p class="text-xs font-semibold uppercase tracking-[0.2em] text-amber-300">Admin</p>
            <h1 class="text-2xl font-semibold text-white">Figuras Tomy</h1>
          </div>
          <button
            id="logout-button"
            class="hidden rounded-lg border border-zinc-700 px-3 py-2 text-sm font-semibold text-zinc-200"
            type="button"
          >
            Salir
          </button>
        </div>

        <label id="search-wrapper" class="mt-4 hidden">
          <span class="sr-only">Buscar figuras</span>
          <input
            id="search-input"
            class="min-h-12 w-full rounded-lg border border-zinc-800 bg-zinc-900 px-4 text-base text-white outline-none transition placeholder:text-zinc-500 focus:border-amber-300"
            type="search"
            placeholder="Buscar por nombre"
            autocomplete="off"
          />
        </label>
      </header>

      <section id="auth-view" class="mt-6 rounded-lg border border-zinc-800 bg-zinc-900 p-4 shadow-xl shadow-black/20">
        <form id="login-form" class="space-y-4">
          <div>
            <label class="text-sm font-medium text-zinc-300" for="email">Email</label>
            <input
              id="email"
              class="mt-2 min-h-12 w-full rounded-lg border border-zinc-700 bg-zinc-950 px-4 text-base text-white outline-none focus:border-amber-300"
              type="email"
              autocomplete="email"
              required
            />
          </div>
          <div>
            <label class="text-sm font-medium text-zinc-300" for="password">Password</label>
            <input
              id="password"
              class="mt-2 min-h-12 w-full rounded-lg border border-zinc-700 bg-zinc-950 px-4 text-base text-white outline-none focus:border-amber-300"
              type="password"
              autocomplete="current-password"
              required
            />
          </div>
          <button
            class="min-h-12 w-full rounded-lg bg-amber-300 px-4 text-base font-bold text-zinc-950 transition active:scale-[0.99]"
            type="submit"
          >
            Entrar
          </button>
        </form>
      </section>

      <section id="list-view" class="mt-4 hidden space-y-3"></section>

      <section
        id="editor-view"
        class="fixed inset-0 z-30 hidden overflow-y-auto bg-zinc-950 px-4 pb-28 pt-4"
      >
        <div class="mx-auto w-full max-w-md">
          <div class="sticky top-0 z-10 -mx-4 flex items-center justify-between border-b border-zinc-800 bg-zinc-950/92 px-4 pb-4 pt-2 backdrop-blur">
            <button
              id="close-editor"
              class="min-h-11 rounded-lg border border-zinc-700 px-4 text-sm font-semibold text-zinc-200"
              type="button"
            >
              Volver
            </button>
            <p id="editor-title" class="text-sm font-semibold text-zinc-300">Editar figura</p>
          </div>

          <form id="figure-form" class="mt-5 space-y-4">
            <input id="figure-id" type="hidden" />
            <input id="num-pokedex" type="hidden" />
            <input id="nombre" type="hidden" />

            <div class="grid grid-cols-1 gap-3">
              <div>
                <label class="text-sm font-medium text-zinc-300" for="generacion">Generacion</label>
                <select
                  id="generacion"
                  class="mt-2 min-h-12 w-full rounded-lg border border-zinc-800 bg-zinc-900 px-3 text-base text-white outline-none focus:border-amber-300"
                  required
                >
                  <option value="1">Gen 1</option>
                  <option value="2">Gen 2</option>
                  <option value="3">Gen 3</option>
                  <option value="4">Gen 4</option>
                  <option value="5">Gen 5</option>
                  <option value="6">Gen 6</option>
                  <option value="7">Gen 7</option>
                  <option value="8">Gen 8</option>
                  <option value="9">Gen 9</option>
                </select>
              </div>
              <div>
                <label class="text-sm font-medium text-zinc-300" for="pokemon-select">Pokemon</label>
                <select
                  id="pokemon-select"
                  class="mt-2 min-h-12 w-full rounded-lg border border-zinc-800 bg-zinc-900 px-3 text-base text-white outline-none focus:border-amber-300"
                  required
                ></select>
              </div>
            </div>

            <div class="rounded-lg border border-zinc-800 bg-zinc-900 p-3">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-zinc-500">Seleccion</p>
              <p id="pokemon-summary" class="mt-2 text-base font-semibold text-white">#0001 Bulbasaur</p>
            </div>

            <fieldset class="rounded-lg border border-zinc-800 bg-zinc-900 p-3">
              <legend class="px-1 text-sm font-medium text-zinc-300">Linea</legend>
              <div id="linea-options" class="mt-3 grid grid-cols-1 gap-2">
                {
                  [
                    { value: "moncolle", label: "Moncolle" },
                    { value: "tomy-arts", label: "Tomy Arts" }
                  ].map((linea) => (
                    <label class="flex min-h-11 items-center gap-3 rounded-lg border border-zinc-800 bg-zinc-950 px-3 text-sm font-semibold text-zinc-200">
                      <input
                        class="h-5 w-5 accent-amber-300"
                        type="radio"
                        name="linea"
                        value={linea.value}
                        checked={linea.value === "tomy-arts"}
                      />
                      {linea.label}
                    </label>
                  ))
                }
              </div>
            </fieldset>

            <div>
              <label class="text-sm font-medium text-zinc-300" for="coleccion">Coleccion</label>
              <select
                id="coleccion"
                class="mt-2 min-h-12 w-full rounded-lg border border-zinc-800 bg-zinc-900 px-3 text-base text-white outline-none focus:border-amber-300"
              >
                <option value="">Sin colección</option>
              </select>
            </div>

            <fieldset class="rounded-lg border border-zinc-800 bg-zinc-900 p-3">
              <legend class="px-1 text-sm font-medium text-zinc-300">Atributos</legend>
              <div id="atributo-checkboxes" class="mt-3 grid grid-cols-1 gap-2">
                {
                  [
                    { value: "brillante", label: "Brillante / Pearl" },
                    { value: "shiny", label: "Shiny / Variocolor" },
                    { value: "clear", label: "Translucida / Clear" },
                    { value: "mega", label: "Megaevolucion" },
                    { value: "con-base", label: "Con Base / Peana / Diorama" }
                  ].map((atributo) => (
                    <label class="flex min-h-11 items-center gap-3 rounded-lg border border-zinc-800 bg-zinc-950 px-3 text-sm font-semibold text-zinc-200">
                      <input
                        class="h-5 w-5 accent-amber-300"
                        type="checkbox"
                        name="atributos"
                        value={atributo.value}
                      />
                      {atributo.label}
                    </label>
                  ))
                }
              </div>
            </fieldset>

            <fieldset class="rounded-lg border border-zinc-800 bg-zinc-900 p-3">
              <legend class="px-1 text-sm font-medium text-zinc-300">Etiquetas</legend>
              <div id="etiqueta-checkboxes" class="mt-3 grid grid-cols-1 gap-2">
                <!-- Se llenará dinámicamente con JavaScript -->
              </div>
            </fieldset>

            <div>
              <label class="text-sm font-medium text-zinc-300" for="detalles">Detalles</label>
              <textarea
                id="detalles"
                class="mt-2 min-h-28 w-full resize-none rounded-lg border border-zinc-800 bg-zinc-900 px-4 py-3 text-base text-white outline-none focus:border-amber-300"
                placeholder="Dormido, sonriendo, Tomy antiguo..."
              ></textarea>
            </div>

            <div>
              <label class="text-sm font-medium text-zinc-300" for="anio">Ano</label>
              <input
                id="anio"
                class="mt-2 min-h-12 w-full rounded-lg border border-zinc-800 bg-zinc-900 px-4 text-base text-white outline-none focus:border-amber-300"
                type="number"
                inputmode="numeric"
                min="1970"
                max="2100"
                placeholder="2024"
              />
            </div>

            <div class="rounded-lg border border-zinc-800 bg-zinc-900 p-3">
              <div class="flex items-center justify-between gap-3">
                <label class="text-sm font-medium text-zinc-300" for="foto">Fotos</label>
                <span id="foto-count" class="text-xs font-semibold text-zinc-500">0 / 4</span>
              </div>
              <p class="mt-1 text-xs text-zinc-500">Hasta 4 fotos por figura.</p>
              <div id="foto-grid" class="mt-3 grid grid-cols-2 gap-2"></div>
              <input
                id="foto"
                class="sr-only"
                type="file"
                accept="image/*"
              />
              <button
                id="add-foto-button"
                class="mt-3 min-h-11 w-full rounded-lg border border-dashed border-zinc-700 bg-zinc-950 px-4 text-sm font-semibold text-zinc-300 transition hover:border-amber-300 hover:text-white"
                type="button"
              >
                Anadir foto
              </button>
            </div>

            <div>
              <label class="text-sm font-medium text-zinc-300" for="mfc-id">MyFigureCollection</label>
              <input
                id="mfc-id"
                class="mt-2 min-h-12 w-full rounded-lg border border-zinc-800 bg-zinc-900 px-4 text-base text-white outline-none focus:border-amber-300"
                type="text"
                inputmode="numeric"
                placeholder="430553"
              />
              <p class="mt-1 text-xs text-zinc-500">Solo el numero del item, opcional.</p>
            </div>

            <button
              id="save-button"
              class="min-h-12 w-full rounded-lg bg-amber-300 px-4 text-base font-bold text-zinc-950 transition active:scale-[0.99] disabled:cursor-wait disabled:opacity-60"
              type="submit"
            >
              Guardar
            </button>
          </form>
        </div>
      </section>

      <button
        id="add-button"
        class="fixed bottom-5 right-5 z-20 hidden h-14 w-14 rounded-full bg-amber-300 text-3xl font-light leading-none text-zinc-950 shadow-2xl shadow-black/40 active:scale-95"
        type="button"
        aria-label="Anadir figura"
      >
        +
      </button>

      <div
        id="toast"
        class="fixed bottom-5 left-1/2 z-40 hidden w-[calc(100%-2rem)] max-w-md -translate-x-1/2 rounded-lg border border-zinc-700 bg-zinc-900 px-4 py-3 text-sm font-semibold text-white shadow-2xl shadow-black/40"
        role="status"
      ></div>
    </main>

    <script>
      // @ts-nocheck
      import { supabase } from "../lib/supabaseClient";
      import { getFigurePhotos, MAX_FOTOS } from "../lib/figurePhotos";
      import {
        DEFAULT_LINEA,
        getFigureAtributos,
        getLineaLabel,
        getAtributoLabel,
        normalizeLinea
      } from "../lib/figureTaxonomy";

      const state = {
        figures: [],
        editing: null,
        pokedex: [],
        colecciones: [],
        etiquetas: [],
        editorPhotos: {
          existing: [],
          pending: []
        }
      };

      const generationRanges = {
        1: [1, 151],
        2: [152, 251],
        3: [252, 386],
        4: [387, 493],
        5: [494, 649],
        6: [650, 721],
        7: [722, 809],
        8: [810, 905],
        9: [906, 1025]
      };

      function setSelectedLinea(value) {
        const linea = normalizeLinea(value ?? DEFAULT_LINEA);
        document.querySelectorAll('input[name="linea"]').forEach((radio) => {
          radio.checked = radio.value === linea;
        });
      }

      function getSelectedLinea() {
        const selected = document.querySelector('input[name="linea"]:checked');
        return normalizeLinea(selected?.value ?? DEFAULT_LINEA);
      }

      function setSelectedAtributos(values) {
        const selected = new Set(Array.isArray(values) ? values : getFigureAtributos({ atributos: values }));
        document.querySelectorAll('input[name="atributos"]').forEach((checkbox) => {
          checkbox.checked = selected.has(checkbox.value);
        });
      }

      function populateColeccionSelect(selectedColeccionId = null) {
        fields.coleccion.innerHTML = `<option value="">Sin colección</option>` +
          state.colecciones
            .map((coleccion) => {
              const selected = coleccion.id === Number(selectedColeccionId) ? "selected" : "";
              return `<option value="${coleccion.id}" ${selected}>${escapeHtml(coleccion.nombre)}</option>`;
            })
            .join("");
      }

      function populateEtiquetaCheckboxes(selectedEtiquetaIds = []) {
        const selectedIds = new Set(selectedEtiquetaIds);
        const etiquetaCheckboxes = document.querySelector("#etiqueta-checkboxes");
        
        etiquetaCheckboxes.innerHTML = state.etiquetas
          .map((etiqueta) => {
            const checked = selectedIds.has(etiqueta.id) ? "checked" : "";
            return `
              <label class="flex min-h-11 items-center gap-3 rounded-lg border border-zinc-800 bg-zinc-950 px-3 text-sm font-semibold text-zinc-200">
                <input
                  class="h-5 w-5 accent-amber-300 etiqueta-checkbox"
                  type="checkbox"
                  name="etiquetas"
                  value="${etiqueta.id}"
                  ${checked}
                />
                ${escapeHtml(etiqueta.nombre)}
              </label>
            `;
          })
          .join("");
      }

      function getSelectedEtiquetaIds() {
        return Array.from(document.querySelectorAll(".etiqueta-checkbox:checked")).map(
          (checkbox) => Number(checkbox.value)
        );
      }

      function setSelectedEtiquetaIds(ids) {
        const selectedIds = new Set(ids);
        document.querySelectorAll(".etiqueta-checkbox").forEach((checkbox) => {
          checkbox.checked = selectedIds.has(Number(checkbox.value));
        });
      }

      function getSelectedAtributos() {
        return Array.from(document.querySelectorAll('input[name="atributos"]:checked')).map(
          (checkbox) => checkbox.value
        );
      }

      function formatAtributosSummary(figure) {
        const atributos = getFigureAtributos(figure);

        if (atributos.length === 0) {
          return "Normal";
        }

        return atributos.map((atributo) => getAtributoLabel(atributo)).join(", ");
      }

      const authView = document.querySelector("#auth-view");
      const loginForm = document.querySelector("#login-form");
      const logoutButton = document.querySelector("#logout-button");
      const searchWrapper = document.querySelector("#search-wrapper");
      const searchInput = document.querySelector("#search-input");
      const listView = document.querySelector("#list-view");
      const editorView = document.querySelector("#editor-view");
      const closeEditor = document.querySelector("#close-editor");
      const editorTitle = document.querySelector("#editor-title");
      const figureForm = document.querySelector("#figure-form");
      const addButton = document.querySelector("#add-button");
      const saveButton = document.querySelector("#save-button");
      const toast = document.querySelector("#toast");
      const fotoInput = document.querySelector("#foto");
      const fotoGrid = document.querySelector("#foto-grid");
      const fotoCount = document.querySelector("#foto-count");
      const addFotoButton = document.querySelector("#add-foto-button");
      const pokemonSelect = document.querySelector("#pokemon-select");
      const pokemonSummary = document.querySelector("#pokemon-summary");

      const fields = {
        id: document.querySelector("#figure-id"),
        numPokedex: document.querySelector("#num-pokedex"),
        nombre: document.querySelector("#nombre"),
        generacion: document.querySelector("#generacion"),
        detalles: document.querySelector("#detalles"),
        anio: document.querySelector("#anio"),
        mfcId: document.querySelector("#mfc-id"),
        coleccion: document.querySelector("#coleccion")
      };

      function escapeHtml(value) {
        return String(value ?? "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#039;");
      }

      function formatPokedexNumber(number) {
        return String(number).padStart(4, "0");
      }

      function normalizePokemonName(value) {
        return String(value)
          .split("-")
          .map((part) => part.charAt(0).toUpperCase() + part.slice(1))
          .join(" ");
      }

      function getFallbackPokedex() {
        return Object.entries(generationRanges).flatMap(([, range]) =>
          Array.from({ length: range[1] - range[0] + 1 }, (_, index) => {
            const num = range[0] + index;
            return {
              num,
              name: `Pokemon ${formatPokedexNumber(num)}`
            };
          })
        );
      }

      async function loadPokedex() {
        const cached = localStorage.getItem("tomy-pokedex-v1");

        if (cached) {
          state.pokedex = JSON.parse(cached);
          return;
        }

        try {
          const response = await fetch("https://pokeapi.co/api/v2/pokemon-species?limit=1025");

          if (!response.ok) {
            throw new Error("No se pudo cargar la Pokedex.");
          }

          const payload = await response.json();
          state.pokedex = payload.results.map((pokemon, index) => ({
            num: index + 1,
            name: normalizePokemonName(pokemon.name)
          }));
          localStorage.setItem("tomy-pokedex-v1", JSON.stringify(state.pokedex));
        } catch {
          state.pokedex = getFallbackPokedex();
          showToast("Pokedex externa no disponible. Usando numeros nacionales.");
        }
      }

      function getPokemonByGeneration(generation) {
        const range = generationRanges[generation];

        if (!range) {
          return [];
        }

        return state.pokedex.filter((pokemon) => pokemon.num >= range[0] && pokemon.num <= range[1]);
      }

      function getPokemonByNumber(number) {
        return state.pokedex.find((pokemon) => pokemon.num === Number(number)) ?? null;
      }

      function getGenerationByPokedexNumber(number) {
        const entry = Object.entries(generationRanges).find(([, range]) => {
          return Number(number) >= range[0] && Number(number) <= range[1];
        });

        return entry ? Number(entry[0]) : 1;
      }

      function populatePokemonSelect(selectedNumber = null) {
        const generation = Number(fields.generacion.value);
        const pokemonList = getPokemonByGeneration(generation);
        pokemonSelect.innerHTML = pokemonList
          .map((pokemon) => {
            const selected = pokemon.num === Number(selectedNumber) ? "selected" : "";
            return `<option value="${pokemon.num}" ${selected}>#${formatPokedexNumber(pokemon.num)} ${escapeHtml(pokemon.name)}</option>`;
          })
          .join("");

        if (selectedNumber && getPokemonByNumber(selectedNumber)) {
          pokemonSelect.value = String(selectedNumber);
        }

        syncSelectedPokemon();
      }

      function syncSelectedPokemon() {
        const pokemon = getPokemonByNumber(pokemonSelect.value);

        if (!pokemon) {
          fields.numPokedex.value = "";
          fields.nombre.value = "";
          pokemonSummary.textContent = "Selecciona un Pokemon";
          return;
        }

        fields.numPokedex.value = String(pokemon.num);
        fields.nombre.value = pokemon.name;
        pokemonSummary.textContent = `#${formatPokedexNumber(pokemon.num)} ${pokemon.name}`;
      }

      function normalizeMfcId(value) {
        const digits = String(value ?? "").replace(/\D/g, "");
        return digits || null;
      }

      function parseYear(value) {
        const year = Number.parseInt(String(value ?? "").trim(), 10);
        return Number.isFinite(year) && year >= 1970 && year <= 2100 ? year : null;
      }

      async function getNextInventoryId(numPokedex, linea) {
        const bitParidad = String(linea).toLowerCase() === "moncolle" ? "0" : "1";
        const prefijoId = `${numPokedex}-${bitParidad}-`;

        const { data, error } = await supabase
          .from("figuras")
          .select("id_inventario")
          .like("id_inventario", `${prefijoId}%`);

        if (error) {
          throw error;
        }

        let maxIncremental = 0;

        if (data && data.length > 0) {
          data.forEach((figure) => {
            const partes = figure.id_inventario.split("-");
            const valorIncrementalStr = partes[partes.length - 1];
            const valorIncrementalNum = parseInt(valorIncrementalStr, 10);

            if (!isNaN(valorIncrementalNum) && valorIncrementalNum > maxIncremental) {
              maxIncremental = valorIncrementalNum;
            }
          });
        }

        const siguienteIncremental = maxIncremental + 1;
        const incrementalConPadding = String(siguienteIncremental).padStart(3, "0");

        return `${prefijoId}${incrementalConPadding}`;
      }

      function showToast(message) {
        toast.textContent = message;
        toast.classList.remove("hidden");
        window.setTimeout(() => toast.classList.add("hidden"), 2600);
      }

      function setAuthenticatedUI(isAuthenticated) {
        authView.classList.toggle("hidden", isAuthenticated);
        logoutButton.classList.toggle("hidden", !isAuthenticated);
        searchWrapper.classList.toggle("hidden", !isAuthenticated);
        listView.classList.toggle("hidden", !isAuthenticated);
        addButton.classList.toggle("hidden", !isAuthenticated);
      }

      async function loadFigures() {
        listView.innerHTML = `<div class="rounded-lg border border-zinc-800 bg-zinc-900 p-4 text-sm text-zinc-400">Cargando...</div>`;

        const { data, error } = await supabase
          .from("figuras")
          .select("*")
          .order("num_pokedex", { ascending: true })
          .order("id_inventario", { ascending: true });

        if (error) {
          listView.innerHTML = `<div class="rounded-lg border border-red-400/40 bg-red-500/10 p-4 text-sm text-red-100">No se pudo cargar la lista.</div>`;
          return;
        }

        state.figures = data ?? [];
        renderList();
      }

      async function loadColecciones() {
        const { data, error } = await supabase
          .from("colecciones")
          .select("*")
          .order("nombre", { ascending: true });

        if (error) {
          console.error("Error al cargar colecciones:", error);
          return;
        }

        state.colecciones = data ?? [];
      }

      async function loadEtiquetas() {
        const { data, error } = await supabase
          .from("etiquetas")
          .select("*")
          .order("nombre", { ascending: true });

        if (error) {
          console.error("Error al cargar etiquetas:", error);
          return;
        }

        state.etiquetas = data ?? [];
      }

      function renderList() {
        const query = searchInput.value.trim().toLowerCase();
        const figures = state.figures.filter((figure) => {
          const name = String(figure.nombre ?? "").toLowerCase();
          return name.includes(query);
        });

        if (figures.length === 0) {
          listView.innerHTML = `<div class="rounded-lg border border-zinc-800 bg-zinc-900 p-4 text-sm text-zinc-400">Sin resultados.</div>`;
          return;
        }

        listView.innerHTML = figures
          .map((figure) => {
            const photos = getFigurePhotos(figure);
            const image = photos[0]
              ? `<img class="h-14 w-14 rounded-lg object-cover" src="${escapeHtml(photos[0])}" alt="${escapeHtml(figure.nombre)}" loading="lazy" />`
              : `<div class="grid h-14 w-14 place-items-center rounded-lg bg-zinc-800 text-xs font-bold text-zinc-500">#${escapeHtml(formatPokedexNumber(figure.num_pokedex))}</div>`;
            const photoLabel = photos.length > 1 ? ` · ${photos.length} fotos` : "";
            const yearLabel = figure.anio ? ` · ${figure.anio}` : "";

            return `
              <button
                class="flex min-h-[76px] w-full items-center gap-3 rounded-lg border border-zinc-800 bg-zinc-900 p-3 text-left active:scale-[0.99]"
                type="button"
                data-id="${escapeHtml(figure.id)}"
              >
                ${image}
                <span class="min-w-0 flex-1">
                  <span class="block truncate text-base font-semibold text-white">${escapeHtml(figure.nombre)}</span>
                  <span class="mt-1 block text-sm text-zinc-500">${escapeHtml(getLineaLabel(figure.linea))} · ${escapeHtml(formatAtributosSummary(figure))} · Gen ${escapeHtml(figure.generacion)}${yearLabel}${photoLabel}</span>
                </span>
              </button>
            `;
          })
          .join("");
      }

      function getEditorPhotoCount() {
        return state.editorPhotos.existing.length + state.editorPhotos.pending.length;
      }

      function revokePendingPreviews() {
        state.editorPhotos.pending.forEach((item) => {
          if (item.previewUrl) {
            URL.revokeObjectURL(item.previewUrl);
          }
        });
      }

      function resetEditorPhotos(existingUrls = []) {
        revokePendingPreviews();
        state.editorPhotos = {
          existing: [...existingUrls],
          pending: []
        };
        renderPhotoGrid();
      }

      function renderPhotoGrid() {
        const total = getEditorPhotoCount();
        fotoCount.textContent = `${total} / ${MAX_FOTOS}`;
        addFotoButton.classList.toggle("hidden", total >= MAX_FOTOS);

        const existingItems = state.editorPhotos.existing
          .map(
            (url, index) => `
              <div class="relative aspect-square overflow-hidden rounded-lg border border-zinc-800 bg-zinc-950">
                <img class="h-full w-full object-cover" src="${escapeHtml(url)}" alt="Foto ${index + 1}" />
                <button
                  class="remove-photo absolute right-1 top-1 grid h-7 w-7 place-items-center rounded-full bg-black/70 text-sm font-bold text-white"
                  type="button"
                  data-kind="existing"
                  data-index="${index}"
                  aria-label="Quitar foto ${index + 1}"
                >
                  &times;
                </button>
              </div>
            `
          )
          .join("");

        const pendingItems = state.editorPhotos.pending
          .map(
            (item, index) => `
              <div class="relative aspect-square overflow-hidden rounded-lg border border-amber-300/40 bg-zinc-950">
                <img class="h-full w-full object-cover" src="${escapeHtml(item.previewUrl)}" alt="Nueva foto ${index + 1}" />
                <span class="absolute left-1 top-1 rounded-md bg-amber-300 px-1.5 py-0.5 text-[10px] font-bold text-zinc-950">Nueva</span>
                <button
                  class="remove-photo absolute right-1 top-1 grid h-7 w-7 place-items-center rounded-full bg-black/70 text-sm font-bold text-white"
                  type="button"
                  data-kind="pending"
                  data-index="${index}"
                  aria-label="Quitar nueva foto ${index + 1}"
                >
                  &times;
                </button>
              </div>
            `
          )
          .join("");

        fotoGrid.innerHTML = existingItems + pendingItems;
      }

      function removeEditorPhoto(kind, index) {
        if (kind === "existing") {
          state.editorPhotos.existing.splice(index, 1);
        } else {
          const [removed] = state.editorPhotos.pending.splice(index, 1);

          if (removed?.previewUrl) {
            URL.revokeObjectURL(removed.previewUrl);
          }
        }

        renderPhotoGrid();
      }

      async function openEditor(figure = null) {
        state.editing = figure;
        editorTitle.textContent = figure ? "Editar figura" : "Nueva figura";
        fields.id.value = figure?.id ?? "";
        fields.numPokedex.value = figure?.num_pokedex ?? "";
        fields.nombre.value = figure?.nombre ?? "";
        fields.generacion.value = String(figure?.generacion ?? getGenerationByPokedexNumber(figure?.num_pokedex ?? 1));
        fields.detalles.value = figure?.detalles ?? "";
        fields.anio.value = figure?.anio ?? "";
        fields.mfcId.value = figure?.mfc_id ?? "";
        fields.coleccion.value = figure?.id_coleccion ?? "";
        setSelectedLinea(figure?.linea ?? DEFAULT_LINEA);
        setSelectedAtributos(getFigureAtributos(figure ?? {}));

        populatePokemonSelect(figure?.num_pokedex ?? null);
        populateColeccionSelect(figure?.id_coleccion ?? null);
        
        // Cargar etiquetas de la figura si es una edición
        let etiquetaIds = [];
        if (figure?.id) {
          const { data: etiquetasData } = await supabase
            .from("figuras_etiquetas")
            .select("id_etiqueta")
            .eq("id_figura", figure.id);
          etiquetaIds = etiquetasData?.map(e => e.id_etiqueta) ?? [];
        }
        populateEtiquetaCheckboxes(etiquetaIds);
        
        resetEditorPhotos(getFigurePhotos(figure ?? {}));
        editorView.classList.remove("hidden");
      }

      function closeEditorView() {
        editorView.classList.add("hidden");
        state.editing = null;
        figureForm.reset();
        setSelectedLinea(DEFAULT_LINEA);
        setSelectedAtributos([]);
        setSelectedEtiquetaIds([]);
        resetEditorPhotos();
      }

      function canvasToBlob(canvas, type, quality) {
        return new Promise((resolve, reject) => {
          canvas.toBlob(
            (blob) => {
              if (blob) {
                resolve(blob);
              } else {
                reject(new Error("No se pudo procesar la imagen."));
              }
            },
            type,
            quality
          );
        });
      }

      function loadImage(file) {
        return new Promise((resolve, reject) => {
          const image = new Image();
          image.onload = () => resolve(image);
          image.onerror = () => reject(new Error("No se pudo leer la imagen."));
          image.src = URL.createObjectURL(file);
        });
      }

      // NUEVO PROCESADOR OPTIMIZADO (PUNTO DULCE WEBP)
      async function compressImage(file) {
        const image = await loadImage(file);
        
        // Ajustamos la caja de límites para el Lightbox (Lado más largo máximo a 1200px)
        const MAX_DIMENSION = 1200;
        let width = image.naturalWidth || image.width;
        let height = image.naturalHeight || image.height;

        if (width > height) {
          if (width > MAX_DIMENSION) {
            height = Math.round(height * (MAX_DIMENSION / width));
            width = MAX_DIMENSION;
          }
        } else {
          if (height > MAX_DIMENSION) {
            width = Math.round(width * (MAX_DIMENSION / height));
            height = MAX_DIMENSION;
          }
        }

        const canvas = document.createElement("canvas");
        canvas.width = width;
        canvas.height = height;
        const context = canvas.getContext("2d");
        context.drawImage(image, 0, 0, width, height);
        
        // Compresión directa WebP al 82% de calidad. Sin bucles que rompan la resolución
        const blob = await canvasToBlob(canvas, "image/webp", 0.82);
        URL.revokeObjectURL(image.src);

        if (!blob) {
          throw new Error("No se pudo comprimir la imagen.");
        }

        // Mantenemos el nombre original del fichero pero cambiando la extensión a .webp
        const nombreWebp = file.name.replace(/\.[^/.]+$/, "") + ".webp";
        return new File([blob], nombreWebp, { type: "image/webp" });
      }

      async function uploadPhoto(file, figureId) {
        const fileExt = file.name.split('.').pop();
        const fileName = `${figureId}/${Date.now()}-${Math.random().toString(36).substring(2, 15)}.${fileExt}`;
        const filePath = fileName;

        const { data, error } = await supabase.storage
          .from('fotos-figuras')
          .upload(filePath, file);

        if (error) {
          throw error;
        }

        const { data: { publicUrl } } = supabase.storage
          .from('fotos-figuras')
          .getPublicUrl(filePath);

        return publicUrl;
      }



async function saveFigure(event) {
  event.preventDefault();
  saveButton.disabled = true;
  saveButton.textContent = "Guardando...";

  try {
    // 1. Recuperamos los atributos seleccionados (ej: ['shiny', 'clear'])
    const atributosSeleccionados = getSelectedAtributos();

    // 2. Construimos el payload traduciendo los atributos a tus columnas booleanas reales
    const payload = {
      num_pokedex: Number(fields.numPokedex.value),
      nombre: fields.nombre.value.trim(),
      generacion: Number(fields.generacion.value),
      linea: getSelectedLinea(),
      
      // Mapeo directo a las columnas de tu BD
      es_shiny: atributosSeleccionados.includes("shiny"),
      es_mega: atributosSeleccionados.includes("mega"),
      es_clear: atributosSeleccionados.includes("clear"),
      es_pearl: atributosSeleccionados.includes("brillante"),
      tiene_base: atributosSeleccionados.includes("con-base"),
      
      detalles: fields.detalles.value.trim() || null,
      anio: parseYear(fields.anio.value),
      mfc_id: normalizeMfcId(fields.mfcId.value),
      id_coleccion: fields.coleccion.value ? Number(fields.coleccion.value) : null
    };

    let figureId = fields.id.value;

    // 3. Si es una figura nueva, la insertamos primero para obtener su UUID (id)
    if (!figureId) {
      payload.id_inventario = await getNextInventoryId(payload.num_pokedex, payload.linea);

      const { data, error } = await supabase
        .from("figuras")
        .insert(payload)
        .select("id")
        .single();

      if (error) throw error;
      figureId = data.id;
    } else {
      // Si es edición, actualizamos primero los campos básicos
      const { error } = await supabase
        .from("figuras")
        .update(payload)
        .eq("id", figureId);
      
      if (error) throw error;
    }

    // 4. --- LÓGICA DE ETIQUETAS (M:N) ---
    const idEtiquetasSeleccionadas = getSelectedEtiquetaIds();

    // Primero limpiamos las relaciones antiguas en la tabla intermedia
    await supabase
      .from("figuras_etiquetas")
      .delete()
      .eq("id_figura", figureId);

    // Si el usuario marcó etiquetas, insertamos las nuevas relaciones
    if (idEtiquetasSeleccionadas.length > 0) {
      const relaciones = idEtiquetasSeleccionadas.map(idEtiqueta => ({
        id_figura: figureId,
        id_etiqueta: idEtiqueta
      }));

      const { error: errorEtiquetas } = await supabase
        .from("figuras_etiquetas")
        .insert(relaciones);

      if (errorEtiquetas) throw errorEtiquetas;
    }
    // --- FIN DE LA LÓGICA DE ETIQUETAS ---

    // 5. Procesamiento y subida de las fotos pendientes
    const uploadedUrls = [];
    for (const item of state.editorPhotos.pending) {
      uploadedUrls.push(await uploadPhoto(item.file, figureId));
    }

    // 6. Consolidamos el array de imágenes finales
    const fotosUrls = [...state.editorPhotos.existing, ...uploadedUrls].slice(0, MAX_FOTOS);
    payload.fotos_urls = fotosUrls;
    payload.foto_url = fotosUrls[0] ?? null;

    // 7. Actualización final de la figura (guarda URLs de fotos)
    const { error } = await supabase
      .from("figuras")
      .update({ fotos_urls: payload.fotos_urls, foto_url: payload.foto_url })
      .eq("id", figureId);

    if (error) throw error;

    // 8. Notificación y refresco de la UI
    showToast(fields.id.value ? "¡Figura actualizada!" : "¡Figura guardada!");
    closeEditorView();
    await loadFigures();
    
  } catch (error) {
    console.error(error);
    showToast("Error al guardar: " + error.message);
  } finally {
    saveButton.disabled = false;
    saveButton.textContent = "Guardar";
  }
}



      // --- EVENT LISTENERS DEL PANEL ---
      loginForm?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const email = document.querySelector("#email").value;
        const password = document.querySelector("#password").value;
        const { error } = await supabase.auth.signInWithPassword({ email, password });
        if (error) {
          showToast("Error de acceso: " + error.message);
        } else {
          setAuthenticatedUI(true);
          await loadFigures();
        }
      });

      logoutButton?.addEventListener("click", async () => {
        await supabase.auth.signOut();
        setAuthenticatedUI(false);
      });

      searchInput?.addEventListener("input", renderList);
      addButton?.addEventListener("click", () => openEditor());
      closeEditor?.addEventListener("click", closeEditorView);
      figureForm?.addEventListener("submit", saveFigure);

      fields.generacion.addEventListener("change", () => populatePokemonSelect());
      pokemonSelect.addEventListener("change", syncSelectedPokemon);
      addFotoButton?.addEventListener("click", () => fotoInput.click());

      fotoInput?.addEventListener("change", (e) => {
        const files = Array.from(e.target.files || []);
        if (files.length === 0) return;

        files.forEach((file) => {
          if (getEditorPhotoCount() >= MAX_FOTOS) return;
          const previewUrl = URL.createObjectURL(file);
          state.editorPhotos.pending.push({ file, previewUrl });
        });

        renderPhotoGrid();
        fotoInput.value = "";
      });

      fotoGrid?.addEventListener("click", (e) => {
        const btn = e.target.closest(".remove-photo");
        if (!btn) return;
        const kind = btn.dataset.kind;
        const index = parseInt(btn.dataset.index, 10);
        removeEditorPhoto(kind, index);
      });

      listView?.addEventListener("click", (e) => {
        const btn = e.target.closest("button[data-id]");
        if (!btn) return;
        const id = btn.dataset.id;
        const figure = state.figures.find((f) => f.id === id);
        if (figure) openEditor(figure);
      });

      // --- INICIALIZACIÓN ---
      async function init() {
        await loadPokedex();
        await loadColecciones();
        await loadEtiquetas();
        const { data: { session } } = await supabase.auth.getSession();
        const isAuthenticated = !!session;
        setAuthenticatedUI(isAuthenticated);
        if (isAuthenticated) {
          await loadFigures();
        }

        supabase.auth.onAuthStateChange((event, session) => {
          const auth = !!session;
          setAuthenticatedUI(auth);
          if (auth && state.figures.length === 0) {
            loadFigures();
          }
        });
      }

      init();
    </script>
  </body>
</html>