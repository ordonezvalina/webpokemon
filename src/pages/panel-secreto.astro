---
import "../styles/global.css";
import ThemeToggle from "../components/ThemeToggle.astro";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#111111" id="theme-color-meta" />
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme");
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const isDark = stored ? stored === "dark" : prefersDark;
        if (isDark) {
          document.documentElement.classList.add("dark");
        } else {
          document.documentElement.classList.remove("dark");
        }
        const meta = document.getElementById("theme-color-meta");
        if (meta) {
          meta.setAttribute("content", isDark ? "#111111" : "#fafafa");
        }
      })();
    </script>
    <title>Admin panel</title>
  </head>
  <body class="text-zinc-900 dark:text-zinc-100 antialiased">
    <main class="mx-auto min-h-screen w-full max-w-md px-4 pb-28 pt-4">
      <header class="sticky top-0 z-20 -mx-4 border-b border-zinc-200 dark:border-zinc-800 bg-white/90 dark:bg-zinc-950/90 px-4 pb-4 pt-3 backdrop-blur">
        <div class="flex items-center justify-between gap-3">
          <div class="flex items-center gap-3">
            <a
              href="/"
              class="grid h-9 w-9 place-items-center rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 text-zinc-600 dark:text-zinc-400 transition hover:border-zinc-400 dark:hover:border-zinc-500 hover:text-zinc-900 dark:hover:text-white"
              aria-label="Go to home page"
            >
              <svg viewBox="0 0 24 24" class="h-4 w-4" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M3 9.75L12 3l9 6.75V21a1 1 0 01-1 1H5a1 1 0 01-1-1V9.75z"></path>
                <path d="M9 22V12h6v10"></path>
              </svg>
            </a>
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.2em] text-amber-600 dark:text-amber-300">Admin</p>
              <h1 class="text-2xl font-semibold text-zinc-900 dark:text-white">Tomy Figures</h1>
            </div>
          </div>
          <button
            id="releases-toggle"
            class="hidden rounded-lg border border-zinc-300 dark:border-zinc-700 px-3 py-2 text-sm font-semibold text-zinc-800 dark:text-zinc-200"
            type="button"
          >
            Releases
          </button>
          <button
            id="logout-button"
            class="hidden rounded-lg border border-zinc-300 dark:border-zinc-700 px-3 py-2 text-sm font-semibold text-zinc-800 dark:text-zinc-200"
            type="button"
          >
            Log out
          </button>
          <ThemeToggle />
        </div>

        <div id="search-wrapper" class="mt-4 hidden space-y-3">
          <label>
            <span class="sr-only">Search figures</span>
            <input
              id="search-input"
              class="min-h-12 w-full rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 px-4 text-base text-zinc-900 dark:text-white outline-none transition placeholder:text-zinc-500 focus:border-amber-500 dark:focus:border-amber-300"
              type="search"
              placeholder="Search by name"
              autocomplete="off"
            />
          </label>
          <label class="flex min-h-11 cursor-pointer items-center gap-3 rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 px-3 text-sm font-semibold text-zinc-800 dark:text-zinc-200">
            <input
              id="exclude-with-photos"
              class="h-5 w-5 accent-amber-500 dark:accent-amber-300"
              type="checkbox"
            />
            <span>Excluir figuras con fotos</span>
          </label>
        </div>
      </header>

      <section id="auth-view" class="mt-6 rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-4 shadow-xl shadow-black/20">
        <form id="login-form" class="space-y-4">
          <div>
            <label class="text-sm font-medium text-zinc-700 dark:text-zinc-300" for="email">Email</label>
            <input
              id="email"
              class="mt-2 min-h-12 w-full rounded-lg border border-zinc-300 dark:border-zinc-700 bg-zinc-50 dark:bg-zinc-950 px-4 text-base text-zinc-900 dark:text-white outline-none focus:border-amber-500 dark:focus:border-amber-300"
              type="email"
              autocomplete="email"
              required
            />
          </div>
          <div>
            <label class="text-sm font-medium text-zinc-700 dark:text-zinc-300" for="password">Password</label>
            <input
              id="password"
              class="mt-2 min-h-12 w-full rounded-lg border border-zinc-300 dark:border-zinc-700 bg-zinc-50 dark:bg-zinc-950 px-4 text-base text-zinc-900 dark:text-white outline-none focus:border-amber-500 dark:focus:border-amber-300"
              type="password"
              autocomplete="current-password"
              required
            />
          </div>
          <button
            class="min-h-12 w-full rounded-lg bg-amber-400 dark:bg-amber-300 px-4 text-base font-bold text-zinc-950 transition active:scale-[0.99]"
            type="submit"
          >
            Log in
          </button>
        </form>
      </section>

      <section id="list-view" class="mt-4 hidden space-y-3"></section>

      <section id="releases-view" class="mt-4 hidden space-y-3">
        <div class="rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-4">
          <h2 class="mb-3 text-base font-semibold text-zinc-900 dark:text-white">Release metadata</h2>
          <p class="mb-4 text-sm text-zinc-600 dark:text-zinc-400">Edit release number, name and date for each collection. These dates drive chronological ordering on the public site.</p>
          <div id="releases-editor-list" class="space-y-3"></div>
        </div>
      </section>

      <section
        id="editor-view"
        class="fixed inset-0 z-30 hidden overflow-y-auto bg-zinc-50 dark:bg-zinc-950 px-4 pb-28 pt-4"
      >
        <div class="mx-auto w-full max-w-md">
          <div class="sticky top-0 z-10 -mx-4 flex items-center justify-between border-b border-zinc-200 dark:border-zinc-800 bg-white/92 dark:bg-zinc-950/92 px-4 pb-4 pt-2 backdrop-blur">
            <button
              id="close-editor"
              class="min-h-11 rounded-lg border border-zinc-300 dark:border-zinc-700 px-4 text-sm font-semibold text-zinc-800 dark:text-zinc-200"
              type="button"
            >
              Back
            </button>
            <p id="editor-title" class="text-sm font-semibold text-zinc-700 dark:text-zinc-300">Edit figure</p>
          </div>

          <form id="figure-form" class="mt-5 space-y-4">
            <input id="figure-id" type="hidden" />
            <input id="pokemon-id" type="hidden" />

            <div class="grid grid-cols-1 gap-3">
              <div>
                <label class="text-sm font-medium text-zinc-700 dark:text-zinc-300" for="generacion">Generation</label>
                <select
                  id="generacion"
                  class="mt-2 min-h-12 w-full rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 px-3 text-base text-zinc-900 dark:text-white outline-none focus:border-amber-500 dark:focus:border-amber-300"
                  required
                >
                  <option value="1">Gen 1</option>
                  <option value="2">Gen 2</option>
                  <option value="3">Gen 3</option>
                  <option value="4">Gen 4</option>
                  <option value="5">Gen 5</option>
                  <option value="6">Gen 6</option>
                  <option value="7">Gen 7</option>
                  <option value="8">Gen 8</option>
                  <option value="9">Gen 9</option>
                </select>
              </div>
              <div>
                <label class="text-sm font-medium text-zinc-700 dark:text-zinc-300" for="pokemon-select">Pokémon</label>
                <select
                  id="pokemon-select"
                  class="mt-2 min-h-12 w-full rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 px-3 text-base text-zinc-900 dark:text-white outline-none focus:border-amber-500 dark:focus:border-amber-300"
                  required
                ></select>
              </div>
            </div>

            <div class="rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-3">
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-zinc-500">Selection</p>
              <p id="pokemon-summary" class="mt-2 text-base font-semibold text-zinc-900 dark:text-white">#0001 Bulbasaur</p>
            </div>

            <fieldset class="rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-3">
              <legend class="px-1 text-sm font-medium text-zinc-700 dark:text-zinc-300">Line</legend>
              <div id="linea-options" class="mt-3 grid grid-cols-1 gap-2">
                {
                  [
                    { value: "tomy", label: "Takara Tomy / Moncolle" },
                    { value: "t_arts", label: "Takara Tomy Arts (T-Arts)" }
                  ].map((linea) => (
                    <label class="flex min-h-11 items-center gap-3 rounded-lg border border-zinc-200 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-950 px-3 text-sm font-semibold text-zinc-800 dark:text-zinc-200">
                      <input
                        class="h-5 w-5 accent-amber-500 dark:accent-amber-300"
                        type="radio"
                        name="linea"
                        value={linea.value}
                        checked={linea.value === "tomy"}
                      />
                      {linea.label}
                    </label>
                  ))
                }
              </div>
            </fieldset>

            <div id="coleccion-wrapper" class="hidden">
              <label class="text-sm font-medium text-zinc-700 dark:text-zinc-300" for="coleccion">Collection</label>
              <select
                id="coleccion"
                class="mt-2 min-h-12 w-full rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 px-3 text-base text-zinc-900 dark:text-white outline-none focus:border-amber-500 dark:focus:border-amber-300"
              >
                <option value="">No collection</option>
              </select>
            </div>

            <div id="release-wrapper" class="hidden">
              <label class="text-sm font-medium text-zinc-700 dark:text-zinc-300" for="release">Release</label>
              <select
                id="release"
                class="mt-2 min-h-12 w-full rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 px-3 text-base text-zinc-900 dark:text-white outline-none focus:border-amber-500 dark:focus:border-amber-300"
                disabled
              >
                <option value="">Select a collection first</option>
              </select>
            </div>

            <fieldset class="rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-3">
              <legend class="px-1 text-sm font-medium text-zinc-700 dark:text-zinc-300">Attributes</legend>
              <div id="atributo-checkboxes" class="mt-3 grid grid-cols-1 gap-2">
                {
                  [
                    { value: "brillante", label: "Pearl / Brillante" },
                    { value: "shiny", label: "Shiny / Variocolor" },
                    { value: "clear", label: "Clear / Translucent" },
                    { value: "con-base", label: "With Base / Diorama" }
                  ].map((atributo) => (
                    <label class="flex min-h-11 items-center gap-3 rounded-lg border border-zinc-200 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-950 px-3 text-sm font-semibold text-zinc-800 dark:text-zinc-200">
                      <input
                        class="h-5 w-5 accent-amber-500 dark:accent-amber-300"
                        type="checkbox"
                        name="atributos"
                        value={atributo.value}
                      />
                      {atributo.label}
                    </label>
                  ))
                }
              </div>
            </fieldset>

            <fieldset class="rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-3">
              <legend class="px-1 text-sm font-medium text-zinc-700 dark:text-zinc-300">Tags</legend>
              <div id="etiqueta-checkboxes" class="mt-3 grid grid-cols-1 gap-2">
                <!-- Filled dynamically by JavaScript -->
              </div>
            </fieldset>

            <div>
              <label class="text-sm font-medium text-zinc-700 dark:text-zinc-300" for="detalles">Details</label>
              <textarea
                id="detalles"
                class="mt-2 min-h-28 w-full resize-none rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 px-4 py-3 text-base text-zinc-900 dark:text-white outline-none focus:border-amber-500 dark:focus:border-amber-300"
                placeholder="Sleeping, smiling, vintage Tomy..."
              ></textarea>
            </div>

            <div>
              <label class="text-sm font-medium text-zinc-700 dark:text-zinc-300" for="anio">Year</label>
              <input
                id="anio"
                class="mt-2 min-h-12 w-full rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 px-4 text-base text-zinc-900 dark:text-white outline-none focus:border-amber-500 dark:focus:border-amber-300"
                type="number"
                inputmode="numeric"
                min="1970"
                max="2100"
                placeholder="2024"
              />
            </div>

            <div>
              <label class="text-sm font-medium text-zinc-700 dark:text-zinc-300" for="visual-order">Visual order</label>
              <input
                id="visual-order"
                class="mt-2 min-h-12 w-full rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 px-4 text-base text-zinc-900 dark:text-white outline-none focus:border-amber-500 dark:focus:border-amber-300"
                type="number"
                inputmode="numeric"
                step="any"
                placeholder="10"
              />
            </div>

            <div class="rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-3">
              <div class="flex items-center justify-between gap-3">
                <label class="text-sm font-medium text-zinc-700 dark:text-zinc-300" for="foto">Photos</label>
                <span id="foto-count" class="text-xs font-semibold text-zinc-500">0 / 4</span>
              </div>
              <p class="mt-1 text-xs text-zinc-500">Up to 4 photos per figure.</p>
              <div id="foto-processing" class="hidden mt-3 flex items-center gap-2 rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-3 text-sm text-zinc-700 dark:text-zinc-300">
                <span class="h-4 w-4 animate-spin rounded-full border-2 border-zinc-400 dark:border-zinc-600 border-t-amber-500 dark:border-t-amber-300"></span>
                <span>Processing photo...</span>
              </div>
              <div id="foto-grid" class="mt-3 grid grid-cols-2 gap-2"></div>
              <input
                id="foto"
                class="sr-only"
                type="file"
                accept="image/*"
                multiple
              />
              <input
                id="foto-camara"
                class="sr-only"
                type="file"
                accept="image/*"
                capture="environment"
              />
              <div id="add-foto-button" class="mt-3 grid grid-cols-2 gap-2">
                <button
                  id="add-foto-galeria"
                  class="min-h-11 rounded-lg border border-dashed border-zinc-300 dark:border-zinc-700 bg-zinc-50 dark:bg-zinc-950 px-3 text-sm font-semibold text-zinc-700 dark:text-zinc-300 transition hover:border-amber-500 dark:hover:border-amber-300 hover:text-zinc-900 dark:hover:text-white"
                  type="button"
                >
                  📁 Gallery
                </button>
                <button
                  id="add-foto-camara"
                  class="min-h-11 rounded-lg border border-dashed border-zinc-300 dark:border-zinc-700 bg-zinc-50 dark:bg-zinc-950 px-3 text-sm font-semibold text-zinc-700 dark:text-zinc-300 transition hover:border-amber-500 dark:hover:border-amber-300 hover:text-zinc-900 dark:hover:text-white"
                  type="button"
                >
                  📷 Camera
                </button>
              </div>
            </div>

            <div>
              <label class="text-sm font-medium text-zinc-700 dark:text-zinc-300" for="mfc-id">MyFigureCollection</label>
              <input
                id="mfc-id"
                class="mt-2 min-h-12 w-full rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 px-4 text-base text-zinc-900 dark:text-white outline-none focus:border-amber-500 dark:focus:border-amber-300"
                type="text"
                inputmode="numeric"
                placeholder="430553"
              />
              <p class="mt-1 text-xs text-zinc-500">Item number only, optional.</p>
            </div>

            <button
              id="save-button"
              class="min-h-12 w-full rounded-lg bg-amber-400 dark:bg-amber-300 px-4 text-base font-bold text-zinc-950 transition active:scale-[0.99] disabled:cursor-wait disabled:opacity-60"
              type="submit"
            >
              Save
            </button>
          </form>
        </div>
      </section>

      <button
        id="add-button"
        class="fixed bottom-5 right-5 z-20 hidden h-14 w-14 rounded-full bg-amber-400 dark:bg-amber-300 text-3xl font-light leading-none text-zinc-950 shadow-2xl shadow-black/40 active:scale-95"
        type="button"
        aria-label="Add figure"
      >
        +
      </button>

      <div
        id="toast"
        class="fixed bottom-5 left-1/2 z-40 hidden w-[calc(100%-2rem)] max-w-md -translate-x-1/2 rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-4 py-3 text-sm font-semibold text-zinc-900 dark:text-white shadow-2xl shadow-black/40"
        role="status"
      ></div>
    </main>

    <script>
      // @ts-nocheck
      import imageCompression from "browser-image-compression";
      import { supabase } from "../lib/supabaseClient";
      import { getFigurePhotos, MAX_PHOTOS } from "../lib/figurePhotos";
      import {
        DEFAULT_LINE,
        getFigureAttributes,
        getLineLabel,
        getAttributeLabel,
        normalizeLine
      } from "../lib/figureTaxonomy";

      const state = {
        figures: [],
        editing: null,
        pokemonByGeneration: {},
        pokemonMap: {},
        collections: [],
        releases: [],
        tags: [],
        isProcessingPhotos: false,
        editorPhotos: {
          existing: [],
          pending: []
        }
      };

      function setSelectedLine(value) {
        const line = normalizeLine(value ?? DEFAULT_LINE);
        document.querySelectorAll('input[name="linea"]').forEach((radio) => {
          radio.checked = radio.value === line;
        });
      }

      function getSelectedLine() {
        const selected = document.querySelector('input[name="linea"]:checked');
        return normalizeLine(selected?.value ?? DEFAULT_LINE);
      }

      function syncCollectionReleaseVisibility() {
        const isTArts = getSelectedLine() === "t_arts";
        coleccionWrapper?.classList.toggle("hidden", !isTArts);
        releaseWrapper?.classList.toggle("hidden", !isTArts);
        if (!isTArts) {
          fields.coleccion.value = "";
          fields.release.value = "";
          fields.release.disabled = true;
          fields.release.innerHTML = `<option value="">Select a collection first</option>`;
        }
      }

      function setSelectedAttributes(values) {
        const selected = new Set(Array.isArray(values) ? values : getFigureAttributes({ atributos: values }));
        document.querySelectorAll('input[name="atributos"]').forEach((checkbox) => {
          checkbox.checked = selected.has(checkbox.value);
        });
      }

      function populateCollectionSelect(selectedCollectionId = null) {
        fields.coleccion.innerHTML = `<option value="">No collection</option>` +
          state.collections
            .map((col) => {
              const selected = col.id === Number(selectedCollectionId) ? "selected" : "";
              return `<option value="${col.id}" ${selected}>${escapeHtml(col.name)}</option>`;
            })
            .join("");
      }

      function releaseOptionLabel(release) {
        const number = release.number;
        const name = release.name;

        if (number != null && !name) return `Release ${number}`;
        if (!number && name) return escapeHtml(name);
        if (number != null && name) return `Release ${number} - ${escapeHtml(name)}`;
        return "Release";
      }

      function populateReleaseSelect(collectionId, selectedReleaseId = null) {
        const filteredReleases = state.releases.filter(r => r.collection_id === Number(collectionId));
        
        if (!collectionId || filteredReleases.length === 0) {
          fields.release.innerHTML = `<option value="">No releases available</option>`;
          fields.release.disabled = true;
          return;
        }

        fields.release.disabled = false;
        fields.release.innerHTML = `<option value="">No release</option>` +
          filteredReleases
            .map((rel) => {
              const selected = rel.id === Number(selectedReleaseId) ? "selected" : "";
              return `<option value="${rel.id}" ${selected}>${releaseOptionLabel(rel)}</option>`;
            })
            .join("");
      }

      function populateTagCheckboxes(selectedTagIds = []) {
        const selectedIds = new Set(selectedTagIds);
        const tagCheckboxes = document.querySelector("#etiqueta-checkboxes");
        
        tagCheckboxes.innerHTML = state.tags
          .map((tag) => {
            const checked = selectedIds.has(tag.id) ? "checked" : "";
            return `
              <label class="flex min-h-11 items-center gap-3 rounded-lg border border-zinc-200 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-950 px-3 text-sm font-semibold text-zinc-800 dark:text-zinc-200">
                <input
                  class="h-5 w-5 accent-amber-500 dark:accent-amber-300 etiqueta-checkbox"
                  type="checkbox"
                  name="etiquetas"
                  value="${tag.id}"
                  ${checked}
                />
                ${escapeHtml(tag.name)}
              </label>
            `;
          })
          .join("");
      }

      function getSelectedTagIds() {
        return Array.from(document.querySelectorAll(".etiqueta-checkbox:checked")).map(
          (checkbox) => Number(checkbox.value)
        );
      }

      function setSelectedTagIds(ids) {
        const selectedIds = new Set(ids);
        document.querySelectorAll(".etiqueta-checkbox").forEach((checkbox) => {
          checkbox.checked = selectedIds.has(Number(checkbox.value));
        });
      }

      function getSelectedAttributes() {
        return Array.from(document.querySelectorAll('input[name="atributos"]:checked')).map(
          (checkbox) => checkbox.value
        );
      }

      function formatAttributesSummary(figure) {
        const attributes = getFigureAttributes(figure);

        if (attributes.length === 0) {
          return "Normal";
        }

        return attributes.map((attribute) => getAttributeLabel(attribute)).join(", ");
      }

      const authView = document.querySelector("#auth-view");
      const loginForm = document.querySelector("#login-form");
      const logoutButton = document.querySelector("#logout-button");
      const searchWrapper = document.querySelector("#search-wrapper");
      const searchInput = document.querySelector("#search-input");
      const excludeWithPhotos = document.querySelector("#exclude-with-photos");
      const listView = document.querySelector("#list-view");
      const editorView = document.querySelector("#editor-view");
      const closeEditor = document.querySelector("#close-editor");
      const editorTitle = document.querySelector("#editor-title");
      const figureForm = document.querySelector("#figure-form");
      const addButton = document.querySelector("#add-button");
      const saveButton = document.querySelector("#save-button");
      const toast = document.querySelector("#toast");
      const fotoInput = document.querySelector("#foto");
      const fotoGrid = document.querySelector("#foto-grid");
      const fotoProcessing = document.querySelector("#foto-processing");
      const fotoCount = document.querySelector("#foto-count");
      const addFotoButton = document.querySelector("#add-foto-button");
      const addFotoGaleria = document.querySelector("#add-foto-galeria");
      const addFotoCamara = document.querySelector("#add-foto-camara");
      const fotoCamaraInput = document.querySelector("#foto-camara");
      const pokemonSelect = document.querySelector("#pokemon-select");
      const pokemonSummary = document.querySelector("#pokemon-summary");

      const fields = {
        id: document.querySelector("#figure-id"),
        pokemonId: document.querySelector("#pokemon-id"),
        generacion: document.querySelector("#generacion"),
        detalles: document.querySelector("#detalles"),
        anio: document.querySelector("#anio"),
        visualOrder: document.querySelector("#visual-order"),
        mfcId: document.querySelector("#mfc-id"),
        coleccion: document.querySelector("#coleccion"),
        release: document.querySelector("#release")
      };

      const coleccionWrapper = document.querySelector("#coleccion-wrapper");
      const releaseWrapper = document.querySelector("#release-wrapper");

      const releasesToggle = document.querySelector("#releases-toggle");
      const releasesView = document.querySelector("#releases-view");
      const releasesEditorList = document.querySelector("#releases-editor-list");

      function escapeHtml(value) {
        return String(value ?? "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#039;");
      }

      function formatPokedexNumber(number) {
        return String(number ?? "").padStart(4, "0");
      }

      function getPokemonLabel(pokemon) {
        const base = pokemon.full_names?.es ?? `Pokémon #${formatPokedexNumber(pokemon.pokedex_number)}`;
        if (pokemon.form && pokemon.form !== "Base") {
          return `${base} (${pokemon.form})`;
        }
        return base;
      }

      async function loadPokemonForGeneration(generation) {
        if (state.pokemonByGeneration[generation]) return;

        pokemonSelect.innerHTML = `<option value="">Loading...</option>`;
        pokemonSelect.disabled = true;

        const { data, error } = await supabase
          .from("pokemon")
          .select("id, pokedex_number, full_names, form, generation")
          .eq("generation", generation)
          .order("pokedex_number", { ascending: true })
          .order("form", { ascending: true });

        if (error || !data) {
          showToast("Error loading Pokémon for Gen " + generation);
          pokemonSelect.innerHTML = `<option value="">Error loading</option>`;
          pokemonSelect.disabled = false;
          return;
        }

        state.pokemonByGeneration[generation] = data;
        data.forEach(p => { state.pokemonMap[String(p.id)] = p; });
        pokemonSelect.disabled = false;
      }

      async function populatePokemonSelect(selectedPokemonId = null) {
        const generation = Number(fields.generacion.value);
        await loadPokemonForGeneration(generation);

        const pokemonList = state.pokemonByGeneration[generation] ?? [];
        pokemonSelect.innerHTML = `<option value="">Select a Pokémon</option>` +
          pokemonList
            .map((pokemon) => {
              const label = getPokemonLabel(pokemon);
              const selected = String(pokemon.id) === String(selectedPokemonId) ? "selected" : "";
              return `<option value="${String(pokemon.id)}" ${selected}>#${formatPokedexNumber(pokemon.pokedex_number)} ${escapeHtml(label)}</option>`;
            })
            .join("");

        if (selectedPokemonId) {
          pokemonSelect.value = String(selectedPokemonId);
        }

        syncSelectedPokemon();
      }

      function syncSelectedPokemon() {
        const pokemonId = pokemonSelect.value;
        const pokemon = (pokemonId && pokemonId !== "") ? state.pokemonMap[String(pokemonId)] : null;

        if (!pokemon) {
          fields.pokemonId.value = "";
          pokemonSummary.textContent = "Select a Pokémon";
          return;
        }

        fields.pokemonId.value = String(pokemon.id);
        const label = getPokemonLabel(pokemon);
        pokemonSummary.textContent = `#${formatPokedexNumber(pokemon.pokedex_number)} ${label}`;
      }

      function generateFigureSlug(pokemonId, line, isShiny, isClear, isPearl) {
        const parts = [String(pokemonId), String(line)];
        if (isClear) parts.push("clear");
        if (isShiny) parts.push("shiny");
        if (isPearl) parts.push("pearl");
        return parts.join("-").toLowerCase();
      }

      async function getUniqueSlug(baseSlug, excludeId = null) {
        let query = supabase
          .from("figures")
          .select("slug")
          .like("slug", `${baseSlug}%`);
        if (excludeId) {
          query = query.neq("id", excludeId);
        }
        const { data } = await query;
        const existing = new Set((data ?? []).map(r => r.slug));
        if (!existing.has(baseSlug)) return baseSlug;
        let n = 2;
        while (existing.has(`${baseSlug}-${n}`)) n++;
        return `${baseSlug}-${n}`;
      }

      function normalizeMfcId(value) {
        const digits = String(value ?? "").replace(/\D/g, "");
        return digits || null;
      }

      function parseYear(value) {
        const year = Number.parseInt(String(value ?? "").trim(), 10);
        return Number.isFinite(year) && year >= 1970 && year <= 2100 ? year : null;
      }

      function parseVisualOrder(value) {
        const order = Number.parseFloat(String(value ?? "").trim());
        return Number.isFinite(order) && order >= 0 ? order : null;
      }

      function showToast(message) {
        toast.textContent = message;
        toast.classList.remove("hidden");
        window.setTimeout(() => toast.classList.add("hidden"), 2600);
      }

      function setAuthenticatedUI(isAuthenticated) {
        authView.classList.toggle("hidden", isAuthenticated);
        logoutButton.classList.toggle("hidden", !isAuthenticated);
        releasesToggle.classList.toggle("hidden", !isAuthenticated);
        searchWrapper.classList.toggle("hidden", !isAuthenticated);
        listView.classList.toggle("hidden", !isAuthenticated);
        addButton.classList.toggle("hidden", !isAuthenticated);
      }

      function setReleasesEditorOpen(isOpen) {
        releasesView.classList.toggle("hidden", !isOpen);
        listView.classList.toggle("hidden", isOpen);
        searchWrapper.classList.toggle("hidden", isOpen);
        addButton.classList.toggle("hidden", isOpen);
        releasesToggle.textContent = isOpen ? "Figures" : "Releases";
      }

      async function loadFigures() {
        listView.innerHTML = `<div class="rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-4 text-sm text-zinc-600 dark:text-zinc-400">Loading...</div>`;

        const { data, error } = await supabase
          .from("figures")
          .select(`*, pokemon(*)`)
          .order("visual_order", { ascending: true });

        if (error) {
          listView.innerHTML = `<div class="rounded-lg border border-red-300 dark:border-red-400/40 bg-red-100 dark:bg-red-500/10 p-4 text-sm text-red-700 dark:text-red-100">Could not load the list.</div>`;
          return;
        }

        const figures = data ?? [];
        const linePriority = (line) => {
          if (line === "tomy") return 0;
          if (line === "t_arts") return 1;
          return 2;
        };
        figures.sort((a, b) => {
          const numA = a.pokemon?.pokedex_number ?? 0;
          const numB = b.pokemon?.pokedex_number ?? 0;
          if (numA !== numB) return numA - numB;
          const lpA = linePriority(a.line);
          const lpB = linePriority(b.line);
          if (lpA !== lpB) return lpA - lpB;
          return (a.visual_order ?? 0) - (b.visual_order ?? 0);
        });
        state.figures = figures;
        renderList();
      }

      async function loadCollections() {
        const { data, error } = await supabase
          .from("collections")
          .select("*")
          .order("name", { ascending: true });

        if (error) {
          console.error("Error loading collections:", error);
          return;
        }

        state.collections = data ?? [];
      }

      function parseReleaseYear(value) {
        const year = Number.parseInt(String(value ?? "").trim(), 10);
        return Number.isFinite(year) && year >= 1970 && year <= 2100 ? year : null;
      }

      function parseReleaseMonth(value) {
        const month = Number.parseInt(String(value ?? "").trim(), 10);
        return Number.isFinite(month) && month >= 1 && month <= 12 ? month : null;
      }

      function formatDateInput(dateValue) {
        if (!dateValue) return "";
        const date = new Date(dateValue);
        if (Number.isNaN(date.getTime())) return "";
        const y = date.getFullYear();
        const m = String(date.getMonth() + 1).padStart(2, "0");
        const d = String(date.getDate()).padStart(2, "0");
        return `${y}-${m}-${d}`;
      }

      function renderReleasesEditor() {
        if (!releasesEditorList) return;

        if (state.collections.length === 0 || state.releases.length === 0) {
          releasesEditorList.innerHTML = `<p class="text-sm text-zinc-600 dark:text-zinc-400">No collections or releases found.</p>`;
          return;
        }

        const releasesByCollection = [...state.releases].sort((a, b) =>
          (a.number || Number.MAX_SAFE_INTEGER) - (b.number || Number.MAX_SAFE_INTEGER)
        );

        releasesEditorList.innerHTML = state.collections
          .sort((a, b) => String(a.name).localeCompare(String(b.name)))
          .map((collection) => {
            const collectionReleases = releasesByCollection.filter(
              (r) => r.collection_id === collection.id
            );
            if (collectionReleases.length === 0) return "";
            return `
              <div class="rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-4">
                <p class="mb-3 text-sm font-semibold text-zinc-900 dark:text-white">${escapeHtml(collection.name)}</p>
                <div class="space-y-3">
                  ${collectionReleases
                    .map((release) => {
                      const number = release.number ?? "";
                      const name = release.name ?? "";
                      const date = formatDateInput(release.release_date);
                      return `
                        <div class="rounded-lg border border-zinc-200 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-950 p-3" data-release-id="${escapeHtml(release.id)}">
                          <div class="mb-2 grid grid-cols-2 gap-2">
                            <label class="block text-xs text-zinc-600 dark:text-zinc-400">
                              Number
                              <input
                                type="number"
                                min="1"
                                placeholder="2"
                                value="${escapeHtml(number)}"
                                class="release-number mt-1 min-h-10 w-full rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-3 text-sm text-zinc-900 dark:text-white outline-none focus:border-amber-500 dark:focus:border-amber-300"
                              />
                            </label>
                            <label class="block text-xs text-zinc-600 dark:text-zinc-400">
                              Release date
                              <input
                                type="date"
                                value="${escapeHtml(date)}"
                                class="release-date mt-1 min-h-10 w-full rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-3 text-sm text-zinc-900 dark:text-white outline-none focus:border-amber-500 dark:focus:border-amber-300"
                              />
                            </label>
                          </div>
                          <label class="block text-xs text-zinc-600 dark:text-zinc-400">
                            Name
                            <input
                              type="text"
                              placeholder="Fire & Grass"
                              value="${escapeHtml(name)}"
                              class="release-name mt-1 min-h-10 w-full rounded-lg border border-zinc-300 dark:border-zinc-700 bg-white dark:bg-zinc-900 px-3 text-sm text-zinc-900 dark:text-white outline-none focus:border-amber-500 dark:focus:border-amber-300"
                            />
                          </label>
                          <button
                            type="button"
                            class="save-release mt-3 w-full rounded-lg bg-amber-400 dark:bg-amber-300 px-3 py-2 text-sm font-bold text-zinc-950 transition active:scale-[0.99]"
                          >
                            Save
                          </button>
                        </div>
                      `;
                    })
                    .join("")}
                </div>
              </div>
            `;
          })
          .join("");
      }

      async function saveReleaseMetadata(releaseId) {
        const card = releasesEditorList.querySelector(`[data-release-id="${releaseId}"]`);
        if (!card) return;

        const numberInput = card.querySelector(".release-number");
        const dateInput = card.querySelector(".release-date");
        const nameInput = card.querySelector(".release-name");
        const saveButton = card.querySelector(".save-release");

        const originalText = saveButton.textContent;
        saveButton.disabled = true;
        saveButton.textContent = "Saving...";

        try {
          const year = parseReleaseYear(dateInput.value);
          const month = parseReleaseMonth(dateInput.value);
          const numberValue = numberInput.value.trim();
          const number = numberValue ? Number.parseInt(numberValue, 10) : null;

          const payload = {
            number: Number.isFinite(number) && number >= 1 ? number : null,
            name: nameInput.value.trim() || null,
            release_date: dateInput.value || null
          };

          const { error } = await supabase
            .from("releases")
            .update(payload)
            .eq("id", releaseId);

          if (error) throw error;

          const release = state.releases.find((r) => String(r.id) === String(releaseId));
          if (release) {
            Object.assign(release, payload);
          }

          showToast("Release updated");
        } catch (error) {
          console.error(error);
          showToast("Error saving release: " + error.message);
        } finally {
          saveButton.disabled = false;
          saveButton.textContent = originalText;
        }
      }

      async function loadReleases() {
        const { data, error } = await supabase
          .from("releases")
          .select("*")
          .order("number", { ascending: true, nullsFirst: false });

        if (error) {
          console.error("Error loading releases:", error);
          return;
        }

        state.releases = data ?? [];
        renderReleasesEditor();
      }

      async function loadTags() {
        const { data, error } = await supabase
          .from("tags")
          .select("*")
          .order("name", { ascending: true });

        if (error) {
          console.error("Error loading tags:", error);
          return;
        }

        state.tags = data ?? [];
      }

      function renderList() {
        const query = searchInput.value.trim().toLowerCase();
        const hideWithPhotos = excludeWithPhotos?.checked ?? false;
        const figures = state.figures.filter((figure) => {
          const name = String(figure.pokemon?.full_names?.es ?? "").toLowerCase();
          if (!name.includes(query)) return false;
          if (hideWithPhotos && getFigurePhotos(figure).length > 0) return false;
          return true;
        });

        if (figures.length === 0) {
          listView.innerHTML = `<div class="rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-4 text-sm text-zinc-600 dark:text-zinc-400">No results.</div>`;
          return;
        }

        listView.innerHTML = figures
          .map((figure) => {
            const photos = getFigurePhotos(figure);
            const image = photos[0]
              ? `<img class="h-14 w-14 rounded-lg object-cover" src="${escapeHtml(photos[0])}" alt="${escapeHtml(figure.pokemon?.full_names?.es)}" loading="lazy" />`
              : `<div class="grid h-14 w-14 place-items-center rounded-lg bg-zinc-200 dark:bg-zinc-800 text-xs font-bold text-zinc-500">#${escapeHtml(formatPokedexNumber(figure.pokemon?.pokedex_number))}</div>`;
            const photoLabel = photos.length > 1 ? ` · ${photos.length} photos` : "";
            const yearLabel = figure.year ? ` · ${figure.year}` : "";

            return `
              <button
                class="flex min-h-[76px] w-full items-center gap-3 rounded-lg border border-zinc-200 dark:border-zinc-800 bg-white dark:bg-zinc-900 p-3 text-left active:scale-[0.99]"
                type="button"
                data-id="${escapeHtml(figure.id)}"
              >
                ${image}
                <span class="min-w-0 flex-1">
                  <span class="block truncate text-base font-semibold text-zinc-900 dark:text-white">${escapeHtml(figure.pokemon?.full_names?.es)}</span>
                  <span class="mt-1 block text-sm text-zinc-500">${escapeHtml(getLineLabel(figure.line))} · ${escapeHtml(formatAttributesSummary(figure))} · Gen ${escapeHtml(figure.pokemon?.generation)}${yearLabel}${photoLabel}</span>
                </span>
              </button>
            `;
          })
          .join("");
      }

      function getEditorPhotoCount() {
        return state.editorPhotos.existing.length + state.editorPhotos.pending.length;
      }

      function revokePendingPreviews() {
        state.editorPhotos.pending.forEach((item) => {
          if (item.previewUrl) {
            URL.revokeObjectURL(item.previewUrl);
          }
        });
      }

      function resetEditorPhotos(existingUrls = []) {
        revokePendingPreviews();
        state.editorPhotos = {
          existing: [...existingUrls],
          pending: []
        };
        renderPhotoGrid();
      }

      function renderPhotoGrid() {
        const total = getEditorPhotoCount();
        fotoCount.textContent = `${total} / ${MAX_PHOTOS}`;
        addFotoButton.classList.toggle("hidden", total >= MAX_PHOTOS);

        const existingItems = state.editorPhotos.existing
          .map(
            (url, index) => `
              <div class="relative aspect-square overflow-hidden rounded-lg border border-zinc-200 dark:border-zinc-800 bg-zinc-50 dark:bg-zinc-950">
                <img class="h-full w-full object-cover" src="${escapeHtml(url)}" alt="Photo ${index + 1}" />
                <button
                  class="remove-photo absolute right-1 top-1 grid h-7 w-7 place-items-center rounded-full bg-black/70 text-sm font-bold text-zinc-900 dark:text-white"
                  type="button"
                  data-kind="existing"
                  data-index="${index}"
                  aria-label="Remove photo ${index + 1}"
                >
                  &times;
                </button>
              </div>
            `
          )
          .join("");

        const pendingItems = state.editorPhotos.pending
          .map(
            (item, index) => `
              <div class="relative aspect-square overflow-hidden rounded-lg border border-amber-500/40 dark:border-amber-300/40 bg-zinc-50 dark:bg-zinc-950">
                <img class="h-full w-full object-cover" src="${escapeHtml(item.previewUrl)}" alt="New photo ${index + 1}" />
                <span class="absolute left-1 top-1 rounded-md bg-amber-400 dark:bg-amber-300 px-1.5 py-0.5 text-xs font-bold text-zinc-950">New</span>
                <button
                  class="remove-photo absolute right-1 top-1 grid h-7 w-7 place-items-center rounded-full bg-black/70 text-sm font-bold text-zinc-900 dark:text-white"
                  type="button"
                  data-kind="pending"
                  data-index="${index}"
                  aria-label="Remove new photo ${index + 1}"
                >
                  &times;
                </button>
              </div>
            `
          )
          .join("");

        fotoGrid.innerHTML = existingItems + pendingItems;
      }

      function removeEditorPhoto(kind, index) {
        if (kind === "existing") {
          state.editorPhotos.existing.splice(index, 1);
        } else {
          const [removed] = state.editorPhotos.pending.splice(index, 1);

          if (removed?.previewUrl) {
            URL.revokeObjectURL(removed.previewUrl);
          }
        }

        renderPhotoGrid();
      }

      async function openEditor(figure = null) {
        state.editing = figure;
        editorTitle.textContent = figure ? "Edit figure" : "New figure";
        fields.id.value = figure?.id ?? "";
        fields.generacion.value = String(figure?.pokemon?.generation ?? 1);
        fields.detalles.value = figure?.details ?? "";
        fields.anio.value = figure?.year ?? "";
        fields.visualOrder.value = figure?.visual_order ?? "";
        fields.mfcId.value = figure?.mfc_id ?? "";

        // Derive collection from the release
        let collectionId = null;
        let releaseId = figure?.release_id ?? null;
        if (releaseId) {
          const rel = state.releases.find(r => r.id === releaseId);
          collectionId = rel?.collection_id ?? null;
        }

        fields.coleccion.value = collectionId ?? "";
        fields.release.value = releaseId ?? "";
        setSelectedLine(figure?.line ?? DEFAULT_LINE);
        syncCollectionReleaseVisibility();
        setSelectedAttributes(getFigureAttributes(figure ?? {}));

        await populatePokemonSelect(figure?.pokemon_id ?? null);
        populateCollectionSelect(collectionId ?? null);
        populateReleaseSelect(collectionId ?? "", releaseId ?? null);
        
        // Load tags for the figure when editing
        let tagIds = [];
        if (figure?.id) {
          const { data: tagData } = await supabase
            .from("figure_tags")
            .select("tag_id")
            .eq("figure_id", figure.id);
          tagIds = tagData?.map(e => e.tag_id) ?? [];
        }
        populateTagCheckboxes(tagIds);
        
        resetEditorPhotos(getFigurePhotos(figure ?? {}));
        editorView.classList.remove("hidden");
      }

      function closeEditorView() {
        editorView.classList.add("hidden");
        state.editing = null;
        figureForm.reset();
        setSelectedLine(DEFAULT_LINE);
        syncCollectionReleaseVisibility();
        setSelectedAttributes([]);
        setSelectedTagIds([]);
        resetEditorPhotos();
      }

      function canvasToBlob(canvas, type, quality) {
        return new Promise((resolve, reject) => {
          canvas.toBlob(
            (blob) => {
              if (blob) {
                resolve(blob);
              } else {
                reject(new Error("Could not process the image."));
              }
            },
            type,
            quality
          );
        });
      }

      function loadImage(file) {
        return new Promise((resolve, reject) => {
          const image = new Image();
          const url = URL.createObjectURL(file);
          image.onload = () => {
            URL.revokeObjectURL(url);
            resolve(image);
          };
          image.onerror = () => {
            URL.revokeObjectURL(url);
            reject(new Error("Could not read the image."));
          };
          image.src = url;
        });
      }

      function detectBoundingBox(imageData, threshold = 25) {
        const { width, height, data } = imageData;
        const thresholdSq = threshold * threshold;

        let minX = width;
        let minY = height;
        let maxX = -1;
        let maxY = -1;
        let found = false;

        for (let y = 0; y < height; y++) {
          for (let x = 0; x < width; x++) {
            const i = (y * width + x) * 4;
            const r = data[i];
            const g = data[i + 1];
            const b = data[i + 2];

            const dr = 255 - r;
            const dg = 255 - g;
            const db = 255 - b;
            const distance = dr * dr + dg * dg + db * db;

            if (distance > thresholdSq) {
              if (x < minX) minX = x;
              if (y < minY) minY = y;
              if (x > maxX) maxX = x;
              if (y > maxY) maxY = y;
              found = true;
            }
          }
        }

        if (!found) return null;

        return {
          minX,
          minY,
          maxX,
          maxY,
          width: maxX - minX + 1,
          height: maxY - minY + 1
        };
      }

      async function centerFigureImage(file) {
        if (!file.type.startsWith("image/")) return file;

        const image = await loadImage(file);
        const { naturalWidth: width, naturalHeight: height } = image;

        const sourceCanvas = document.createElement("canvas");
        sourceCanvas.width = width;
        sourceCanvas.height = height;
        const sourceCtx = sourceCanvas.getContext("2d", { willReadFrequently: true });
        sourceCtx.drawImage(image, 0, 0);

        const imageData = sourceCtx.getImageData(0, 0, width, height);
        const box = detectBoundingBox(imageData);

        if (!box) {
          return file;
        }

        const maxBoxSide = Math.max(box.width, box.height);
        // Very tight margin: 1.5% of the figure side, minimum 6 px
        const margin = Math.max(6, Math.round(maxBoxSide * 0.015));

        const centerX = box.minX + box.width / 2;
        const centerY = box.minY + box.height / 2;
        let squareSize = maxBoxSide + margin * 2;

        // Do not make the square larger than the original image
        if (squareSize > width) squareSize = width;
        if (squareSize > height) squareSize = height;

        let cropX = Math.round(centerX - squareSize / 2);
        let cropY = Math.round(centerY - squareSize / 2);

        if (cropX < 0) cropX = 0;
        if (cropY < 0) cropY = 0;
        if (cropX + squareSize > width) cropX = width - squareSize;
        if (cropY + squareSize > height) cropY = height - squareSize;

        if (squareSize <= 0) return file;

        const outputCanvas = document.createElement("canvas");
        outputCanvas.width = squareSize;
        outputCanvas.height = squareSize;

        const outputCtx = outputCanvas.getContext("2d");
        // Straight crop, no white padding added
        outputCtx.drawImage(
          sourceCanvas,
          cropX,
          cropY,
          squareSize,
          squareSize,
          0,
          0,
          squareSize,
          squareSize
        );

        const blob = await canvasToBlob(outputCanvas, "image/webp", 0.92);
        const name = file.name.replace(/\.[^/.]+$/, "") + "-centered.webp";
        return new File([blob], name, { type: "image/webp" });
      }

      async function compressImage(file) {
        const MAX_SIZE_KB = 150;
        const MAX_SIZE_MB = MAX_SIZE_KB / 1024;
        const MAX_DIMENSION = 1600;
        
        let quality = 0.8;
        let compressedFile = file;
        
        while (quality >= 0.5) {
          const options = {
            maxSizeMB: MAX_SIZE_MB,
            maxWidthOrHeight: MAX_DIMENSION,
            useWebWorker: false,
            fileType: "image/webp",
            initialQuality: quality,
            alwaysUseOriginalSize: true
          };
          
          try {
            compressedFile = await imageCompression(file, options);
            
            if (compressedFile.size <= MAX_SIZE_KB * 1024) {
              break;
            }
            
            quality -= 0.05;
          } catch (error) {
  console.error("Compression error:", error);
  console.error("Type:", typeof error);

  throw new Error(
    "Could not compress the image: " +
    (error?.message ?? error?.toString() ?? JSON.stringify(error))
  );
}
        }
        
        const webpName = file.name.replace(/\.[^/.]+$/, "") + ".webp";
        return new File([compressedFile], webpName, { type: "image/webp" });
      }

      async function uploadPhoto(file, figureId) {
        const fileName = `${figureId}/${Date.now()}-${Math.random().toString(36).substring(2, 15)}.webp`;
        const filePath = fileName;

        const { data, error } = await supabase.storage
          .from('fotos-figuras')
          .upload(filePath, file);

        if (error) {
          throw error;
        }

        const { data: { publicUrl } } = supabase.storage
          .from('fotos-figuras')
          .getPublicUrl(filePath);

        return publicUrl;
      }



async function saveFigure(event) {
  event.preventDefault();
  saveButton.disabled = true;
  saveButton.textContent = "Saving...";

  try {
    // 1. Get selected attributes (e.g. ['shiny', 'clear'])
    const selectedAttributes = getSelectedAttributes();

    // 2. Build the payload mapping attributes to real boolean columns
    const selectedPokemonId = fields.pokemonId.value;
    if (!selectedPokemonId || selectedPokemonId === "") {
      showToast("Select a Pokémon before saving.");
      saveButton.disabled = false;
      saveButton.textContent = "Save";
      return;
    }

    const lineValue = getSelectedLine();
    const isShiny = selectedAttributes.includes("shiny");
    const isClear = selectedAttributes.includes("clear");
    const isPearl = selectedAttributes.includes("brillante");

    const payload = {
      pokemon_id: isNaN(Number(selectedPokemonId)) ? selectedPokemonId : Number(selectedPokemonId),
      line: lineValue,

      // Direct mapping to DB boolean columns
      is_shiny: isShiny,
      is_clear: isClear,
      is_pearl: isPearl,
      has_base: selectedAttributes.includes("con-base"),

      details: fields.detalles.value.trim() || null,
      year: parseYear(fields.anio.value),
      visual_order: parseVisualOrder(fields.visualOrder.value),
      mfc_id: normalizeMfcId(fields.mfcId.value),
      release_id: lineValue === "t_arts" && fields.release.value ? Number(fields.release.value) : null
    };

    let figureId = fields.id.value;

    // Generate a unique slug for the figure
    const baseSlug = generateFigureSlug(selectedPokemonId, lineValue, isShiny, isClear, isPearl);
    payload.slug = await getUniqueSlug(baseSlug, figureId || null);

    // 3. If new figure, insert first to obtain the UUID
    if (!figureId) {

      const { data, error } = await supabase
        .from("figures")
        .insert(payload)
        .select("id")
        .single();

      if (error) throw error;
      figureId = data.id;
    } else {
      // If editing, update basic fields first
      const { error } = await supabase
        .from("figures")
        .update(payload)
        .eq("id", figureId);
      
      if (error) throw error;
    }

    // 4. --- TAG LOGIC (M:N) ---
    const selectedTagIds = getSelectedTagIds();

    // Remove old relations from the join table
    await supabase
      .from("figure_tags")
      .delete()
      .eq("figure_id", figureId);

    // Insert new relations if any tags were selected
    if (selectedTagIds.length > 0) {
      const relations = selectedTagIds.map(tagId => ({
        figure_id: figureId,
        tag_id: tagId
      }));

      const { error: tagError } = await supabase
        .from("figure_tags")
        .insert(relations);

      if (tagError) throw tagError;
    }
    // --- END TAG LOGIC ---

    // 5. Process and upload pending photos
    const uploadedUrls = [];
    for (const item of state.editorPhotos.pending) {
      const compressedFile = await compressImage(item.file);
      uploadedUrls.push(await uploadPhoto(compressedFile, figureId));
    }

    // 6. Consolidate final image array
    const photoUrls = [...state.editorPhotos.existing, ...uploadedUrls].slice(0, MAX_PHOTOS);
    payload.images_urls = photoUrls;
    payload.image_url = photoUrls[0] ?? null;

    // 7. Final figure update (save photo URLs)
    const { error } = await supabase
      .from("figures")
      .update({ images_urls: payload.images_urls, image_url: payload.image_url })
      .eq("id", figureId);

    if (error) throw error;

    // 8. Notify and refresh UI
    showToast(fields.id.value ? "Figure updated!" : "Figure saved!");
    closeEditorView();
    await loadFigures();
    
  } catch (error) {
    console.error(error);
    showToast("Error saving: " + error.message);
  } finally {
    saveButton.disabled = false;
    saveButton.textContent = "Save";
  }
}



      // --- PANEL EVENT LISTENERS ---
      loginForm?.addEventListener("submit", async (e) => {
        e.preventDefault();
        const email = document.querySelector("#email").value;
        const password = document.querySelector("#password").value;
        const { error } = await supabase.auth.signInWithPassword({ email, password });
        if (error) {
          showToast("Access error: " + error.message);
        } else {
          setAuthenticatedUI(true);
          await loadFigures();
        }
      });

      logoutButton?.addEventListener("click", async () => {
        await supabase.auth.signOut();
        setAuthenticatedUI(false);
      });

      searchInput?.addEventListener("input", renderList);
      excludeWithPhotos?.addEventListener("change", renderList);
      addButton?.addEventListener("click", () => openEditor());
      closeEditor?.addEventListener("click", closeEditorView);
      figureForm?.addEventListener("submit", saveFigure);

      releasesToggle?.addEventListener("click", () => {
        const isOpen = releasesView.classList.contains("hidden");
        setReleasesEditorOpen(isOpen);
      });

      releasesEditorList?.addEventListener("click", (e) => {
        const button = e.target.closest(".save-release");
        if (!button) return;
        const card = button.closest("[data-release-id]");
        if (!card) return;
        saveReleaseMetadata(card.dataset.releaseId);
      });

      document.querySelectorAll('input[name="linea"]').forEach((radio) => {
        radio.addEventListener("change", syncCollectionReleaseVisibility);
      });
      fields.generacion.addEventListener("change", () => populatePokemonSelect(null));
      pokemonSelect.addEventListener("change", syncSelectedPokemon);
      fields.coleccion.addEventListener("change", () => populateReleaseSelect(fields.coleccion.value));

      function setPhotoProcessing(isProcessing) {
        state.isProcessingPhotos = isProcessing;
        fotoProcessing?.classList.toggle("hidden", !isProcessing);
        addFotoGaleria.disabled = isProcessing;
        addFotoCamara.disabled = isProcessing;
        addFotoGaleria?.classList.toggle("opacity-60", isProcessing);
        addFotoCamara?.classList.toggle("opacity-60", isProcessing);
      }

      async function handleNewFiles(files) {
        if (state.isProcessingPhotos) return;
        if (files.length === 0) return;

        setPhotoProcessing(true);

        try {
          for (const file of Array.from(files)) {
            if (getEditorPhotoCount() >= MAX_PHOTOS) break;

            try {
              const centeredFile = await centerFigureImage(file);
              const previewUrl = URL.createObjectURL(centeredFile);
              state.editorPhotos.pending.push({ file: centeredFile, previewUrl });
            } catch (error) {
              console.error("Error processing photo:", error);
              showToast("Could not process a photo.");
            }
          }
        } finally {
          setPhotoProcessing(false);
        }

        renderPhotoGrid();
      }

      addFotoGaleria?.addEventListener("click", () => fotoInput.click());
      addFotoCamara?.addEventListener("click", () => fotoCamaraInput.click());

      fotoInput?.addEventListener("change", async (e) => {
        const files = Array.from(e.target.files || []);
        if (files.length === 0) return;
        await handleNewFiles(files);
        fotoInput.value = "";
      });

      fotoCamaraInput?.addEventListener("change", async (e) => {
        const files = Array.from(e.target.files || []);
        if (files.length === 0) return;
        await handleNewFiles(files);
        fotoCamaraInput.value = "";
      });

      fotoGrid?.addEventListener("click", (e) => {
        const btn = e.target.closest(".remove-photo");
        if (!btn) return;
        const kind = btn.dataset.kind;
        const index = parseInt(btn.dataset.index, 10);
        removeEditorPhoto(kind, index);
      });

      listView?.addEventListener("click", (e) => {
        const btn = e.target.closest("button[data-id]");
        if (!btn) return;
        const id = btn.dataset.id;
        const figure = state.figures.find((f) => f.id === id);
        if (figure) openEditor(figure);
      });

      // --- INITIALISATION ---
      async function init() {
        await loadCollections();
        await loadReleases();
        await loadTags();
        const { data: { session } } = await supabase.auth.getSession();
        const isAuthenticated = !!session;
        setAuthenticatedUI(isAuthenticated);
        if (isAuthenticated) {
          await loadFigures();
        }

        supabase.auth.onAuthStateChange((event, session) => {
          const auth = !!session;
          setAuthenticatedUI(auth);
          if (auth && state.figures.length === 0) {
            loadFigures();
          }
        });
      }

      init();
    </script>
  </body>
</html>