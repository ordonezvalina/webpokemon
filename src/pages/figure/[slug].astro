---
import BaseLayout from "../../components/BaseLayout.astro";
import BackLink from "../../components/BackLink.astro";
import CollectionNav from "../../components/CollectionNav.astro";
import { getCatalog, getTagsForFigure } from "../../lib/catalogCache";
import { createSlug } from "../../lib/slug";
import { getFigurePhotos } from "../../lib/figurePhotos";
import { getLineaLabel, getFigureAtributos, getAtributoLabel } from "../../lib/figureTaxonomy";

export async function getStaticPaths() {
  const { figures } = await getCatalog();

  return figures
    .filter((figura: any) => figura.slug)
    .map((figura: any) => ({
      params: { slug: String(figura.slug) },
    }));
}

const { slug } = Astro.params;

const { figures, figureTags } = await getCatalog();
const figura = figures.find((f: any) => f.slug === slug);

if (!figura) {
  return Astro.redirect("/404");
}

const etiquetas = getTagsForFigure(figura.id, figureTags);

const fotos = getFigurePhotos(figura);
const atributos = getFigureAtributos(figura);
---

<BaseLayout title={`${figura.pokemon?.full_names?.es} (${getLineaLabel(figura.line)}) | Mi Colección`}>
  <main class="mx-auto min-h-screen w-full max-w-md px-4 pb-12 pt-4">
    
    <header class="mb-4 flex items-center justify-between border-b border-zinc-800 pb-4">
      <BackLink href="/" text="Volver al catálogo" />
    </header>

      <section class="space-y-2">
        {fotos.length > 0 ? (
          <>
            {/* Foto principal */}
            <div class="overflow-hidden rounded-xl border border-zinc-800 bg-zinc-900 aspect-square shadow-xl shadow-black/20 cursor-zoom-in">
              <img id="foto-principal" class="h-full w-full object-cover" src={fotos[0]} alt={figura.pokemon?.full_names?.es} />
            </div>
            
            {/* Miniaturas */}
            {fotos.length > 1 && (
              <div class="grid grid-cols-4 gap-2">
                {fotos.map((url: string, index: number) => (
                  <div class="overflow-hidden rounded-lg border border-zinc-800 bg-zinc-900 aspect-square">
                    <img 
                      class="foto-miniatura h-full w-full object-cover opacity-60 hover:opacity-100 transition cursor-pointer" 
                      src={url} 
                      alt={`Foto ${index + 1}`} 
                      data-src={url}
                    />
                  </div>
                ))}
              </div>
            )}
          </>
        ) : (
          <div class="grid aspect-square place-items-center rounded-xl border border-dashed border-zinc-800 bg-zinc-900 text-sm font-bold text-zinc-600">
            Sin imágenes disponibles
          </div>
        )}
      </section>

      <section class="mt-5 space-y-4">
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-amber-300">
            #{String(figura.pokemon?.pokedex_number).padStart(4, "0")} · Gen {figura.pokemon?.generation}
          </p>
          <h1 class="mt-1 text-3xl font-bold text-white tracking-tight">{figura.pokemon?.full_names?.es}</h1>
          <p class="mt-1 inline-block rounded-md bg-zinc-800 px-2.5 py-1 text-sm font-bold text-zinc-300 border border-zinc-700">
            {getLineaLabel(figura.line)}
          </p>
        </div>

        <CollectionNav figure={figura} />

        {atributos.length > 0 && (
          <div class="flex flex-wrap gap-1.5">
            {atributos.map((attr: string) => (
              <a href={`/attribute/${createSlug(attr)}`} class="rounded-full bg-amber-300/10 border border-amber-300/30 px-3 py-0.5 text-xs font-semibold text-amber-300 hover:bg-amber-300/20 transition">
                {getAtributoLabel(attr)}
              </a>
            ))}
          </div>
        )}

        {etiquetas.length > 0 && (
          <div class="flex flex-wrap gap-1.5">
            {etiquetas.map((etiqueta: any) => (
              <span class="rounded-full bg-purple-300/10 border border-purple-300/30 px-3 py-0.5 text-xs font-semibold text-purple-300">
                🏷️ {etiqueta.name}
              </span>
            ))}
          </div>
        )}

        {figura.details && (
          <div class="rounded-xl border border-zinc-800 bg-zinc-900 p-4 shadow-inner">
            <h3 class="text-xs font-semibold uppercase tracking-wider text-zinc-500">Detalles de la pieza</h3>
            <p class="mt-2 text-base text-zinc-300 leading-relaxed">{figura.details}</p>
          </div>
        )}

        <div class="rounded-xl border border-zinc-800 bg-zinc-900/40 p-4 space-y-3">
          <div class="flex justify-between items-center text-sm border-b border-zinc-800/60 pb-2">
            <span class="text-zinc-500 font-medium">Año de lanzamiento</span>
            <span class="text-zinc-200 font-semibold">{figura.year ?? "Desconocido"}</span>
          </div>

          {figura.mfc_id && (
            <div class="flex justify-between items-center text-sm">
              <span class="text-zinc-500 font-medium">MyFigureCollection</span>
              <a
                href={`https://myfigurecollection.net/item/${figura.mfc_id}`}
                target="_blank"
                rel="noopener noreferrer"
                class="text-amber-300 hover:underline font-mono text-xs"
              >
                #{figura.mfc_id} ↗
              </a>
            </div>
          )}
        </div>
      </section>

    </main>

    {/* LIGHTBOX MODIFICADO PARA TAMAÑO 100% Y ADMITIR SCROLL SI SUPERA LA PANTALLA */}
    <div 
      id="lightbox" 
      class="hidden fixed inset-0 z-50 overflow-auto bg-black/95 p-4 cursor-zoom-out flex"
    >
      <button class="fixed top-4 right-4 text-white text-4xl font-light active:scale-95 z-50 bg-black/40 rounded-full w-12 h-12 flex items-center justify-center" aria-label="Cerrar modal">&times;</button>
      <img 
        id="lightbox-img" 
        class="max-w-none max-h-none rounded-lg shadow-2xl m-auto" 
        src="" 
        alt="Visualización a pantalla completa" 
      />
    </div>

<script>
  const fotoPrincipal = document.getElementById("foto-principal") as HTMLImageElement | null;
  const miniaturas = document.querySelectorAll(".foto-miniatura");
  
  const lightbox = document.getElementById("lightbox");
  const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement | null;

  if (fotoPrincipal && lightbox && lightboxImg) {
    fotoPrincipal.addEventListener("click", () => {
      lightboxImg.src = fotoPrincipal.src; 
      lightbox.classList.remove("hidden"); 
      document.body.classList.add("overflow-hidden"); 
    });
  }

 // 2. CERRAR EL LIGHTBOX: Al pulsar en cualquier parte del fondo negro
  lightbox?.addEventListener("click", () => {
    lightbox.classList.add("hidden");
    document.body.classList.remove("overflow-hidden");
  });
  
	  // 2b. CERRAR CON LA TECLA ESCAPE
	document.addEventListener("keydown", (event) => {
	  if (event.key === "Escape" && lightbox && !lightbox.classList.contains("hidden")) {
		lightbox.classList.add("hidden");
		document.body.classList.remove("overflow-hidden");
	  }
	});

  if (fotoPrincipal && miniaturas.length > 0) {
    (miniaturas[0] as HTMLElement).classList.replace("opacity-60", "opacity-100");

    miniaturas.forEach((miniatura) => {
      miniatura.addEventListener("click", () => {
        const nuevaUrl = miniatura.getAttribute("data-src");
        if (nuevaUrl) {
          fotoPrincipal.src = nuevaUrl;
          
          miniaturas.forEach((m) => m.classList.replace("opacity-100", "opacity-60"));
          miniatura.classList.replace("opacity-60", "opacity-100");
        }
      });
    });
  }
</script>
</BaseLayout>