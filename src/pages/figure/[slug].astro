---
import BaseLayout from "../../components/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import BackLink from "../../components/BackLink.astro";
import CollectionNav from "../../components/CollectionNav.astro";
import { getCatalog, getTagsForFigure } from "../../lib/catalogCache";
import { createSlug } from "../../lib/slug";
import { getFigurePhotos } from "../../lib/figurePhotos";
import { getLineaLabel, getFigureAtributos, getAtributoLabel } from "../../lib/figureTaxonomy";
import { figureMeta, addImage, absoluteImageUrl, figureSchema, breadcrumbSchema } from "../../lib/seo";

export async function getStaticPaths() {
  const { figures } = await getCatalog();

  return figures
    .filter((figura: any) => figura.slug)
    .map((figura: any) => ({
      params: { slug: String(figura.slug) },
    }));
}

const { slug } = Astro.params;

const { figures, figureTags } = await getCatalog();
const figura = figures.find((f: any) => f.slug === slug);

if (!figura) {
  return Astro.redirect("/404");
}

const etiquetas = getTagsForFigure(figura.id, figureTags);

const fotos = getFigurePhotos(figura);
const atributos = getFigureAtributos(figura);

const coleccion = figura.volumes?.collections;
const volumen = figura.volumes;
const coleccionSlug = coleccion ? createSlug(coleccion.name) : "";
const volumenSlug = volumen?.name_eng ? createSlug(volumen.name_eng) : String(volumen?.volume || "");

const breadcrumbItems = [];
if (coleccion) {
  breadcrumbItems.push({ label: coleccion.name, href: `/collection/${coleccionSlug}` });
  if (volumen) {
    breadcrumbItems.push({ label: `Vol. ${volumen.volume}`, href: `/collection/${coleccionSlug}/volume/${volumenSlug}` });
  }
}
breadcrumbItems.push({ label: figura.pokemon?.full_names?.es });

const siteUrl = Astro.site?.toString() || "https://example.com";
const mainImage = fotos.length > 0 ? absoluteImageUrl(siteUrl, fotos[0]) : undefined;
const imageDomain = fotos.length > 0 && fotos[0].startsWith("http") ? new URL(fotos[0]).hostname : undefined;
const baseMeta = figureMeta(figura, siteUrl);
const seo = mainImage ? addImage(baseMeta, mainImage) : baseMeta;
const schemas = [
  figureSchema(figura, siteUrl, mainImage),
  breadcrumbSchema(breadcrumbItems, siteUrl),
];
---

<BaseLayout title={seo.title} description={seo.description} seo={seo} schemas={schemas} preconnectDomains={imageDomain ? [imageDomain] : []}>
  <main class="mx-auto min-h-screen w-full max-w-6xl px-4 pb-12 pt-4 sm:px-6 lg:px-8">

    <header class="mb-4 flex items-center justify-between border-b border-zinc-200 pb-4 dark:border-zinc-800">
      <BackLink href="/" text="Volver al catálogo" />
    </header>

    <Breadcrumb items={breadcrumbItems} />

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-12 lg:gap-10">
      {/* Galería de fotos */}
      <section class="lg:col-span-5 lg:sticky lg:top-4 lg:self-start space-y-3">
        {fotos.length > 0 ? (
          <>
            <div class="overflow-hidden rounded-xl border border-zinc-200 bg-white aspect-square shadow-xl shadow-zinc-900/10 cursor-zoom-in dark:border-zinc-800 dark:bg-zinc-900 dark:shadow-black/20">
              <img
                id="foto-principal"
                class="h-full w-full object-cover"
                src={fotos[0]}
                alt={figura.pokemon?.full_names?.es}
                fetchpriority="high"
                decoding="async"
              />
            </div>
            {fotos.length > 1 && (
              <div class="grid grid-cols-5 gap-2">
                {fotos.map((url: string, index: number) => (
                  <div class="overflow-hidden rounded-lg border border-zinc-200 bg-white aspect-square dark:border-zinc-800 dark:bg-zinc-900">
                    <img
                      class="foto-miniatura h-full w-full object-cover opacity-60 hover:opacity-100 transition cursor-pointer"
                      src={url}
                      alt={`Foto ${index + 1} de ${figura.pokemon?.full_names?.es}`}
                      data-src={url}
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                ))}
              </div>
            )}
          </>
        ) : (
          <div class="grid aspect-square place-items-center rounded-xl border border-dashed border-zinc-300 bg-zinc-100 text-sm font-bold text-zinc-400 dark:border-zinc-800 dark:bg-zinc-900 dark:text-zinc-600">
            Sin imágenes disponibles
          </div>
        )}
      </section>

      {/* Información de la figura */}
      <section class="lg:col-span-7 space-y-5">
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-amber-600 dark:text-amber-300">
            #{String(figura.pokemon?.pokedex_number).padStart(4, "0")} · Gen {figura.pokemon?.generation}
          </p>
          <h1 class="mt-1 text-3xl font-bold text-zinc-900 tracking-tight sm:text-4xl dark:text-white">{figura.pokemon?.full_names?.es}</h1>
          <p class="mt-2 inline-block rounded-md bg-zinc-200 px-2.5 py-1 text-sm font-bold text-zinc-700 border border-zinc-300 dark:bg-zinc-800 dark:text-zinc-300 dark:border-zinc-700">
            {getLineaLabel(figura.line)}
          </p>
        </div>

        <CollectionNav figure={figura} />

        {atributos.length > 0 && (
          <div class="flex flex-wrap gap-1.5">
            {atributos.map((attr: string) => (
              <a href={`/attribute/${createSlug(attr)}`} class="rounded-full bg-amber-100 border border-amber-300/60 px-3 py-0.5 text-xs font-semibold text-amber-800 hover:bg-amber-200/70 transition dark:bg-amber-300/10 dark:border-amber-300/30 dark:text-amber-300 dark:hover:bg-amber-300/20">
                {getAtributoLabel(attr)}
              </a>
            ))}
          </div>
        )}

        {etiquetas.length > 0 && (
          <div class="flex flex-wrap gap-1.5">
            {etiquetas.map((etiqueta: any) => (
              <span class="rounded-full bg-purple-100 border border-purple-300/60 px-3 py-0.5 text-xs font-semibold text-purple-800 dark:bg-purple-300/10 dark:border-purple-300/30 dark:text-purple-300">
                🏷️ {etiqueta.name}
              </span>
            ))}
          </div>
        )}

        {figura.details && (
          <div class="rounded-xl border border-zinc-200 bg-white p-4 shadow-inner dark:border-zinc-800 dark:bg-zinc-900">
            <h3 class="text-xs font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-500">Detalles de la pieza</h3>
            <p class="mt-2 text-base text-zinc-700 leading-relaxed dark:text-zinc-300">{figura.details}</p>
          </div>
        )}

        <div class="rounded-xl border border-zinc-200 bg-zinc-50/70 p-4 space-y-3 dark:border-zinc-800 dark:bg-zinc-900/40">
          <div class="flex justify-between items-center text-sm border-b border-zinc-200/80 pb-2 dark:border-zinc-800/60">
            <span class="text-zinc-500 font-medium dark:text-zinc-500">Año de lanzamiento</span>
            <span class="text-zinc-800 font-semibold dark:text-zinc-200">{figura.year ?? "Desconocido"}</span>
          </div>

          {figura.mfc_id && (
            <div class="flex justify-between items-center text-sm">
              <span class="text-zinc-500 font-medium dark:text-zinc-500">MyFigureCollection</span>
              <a
                href={`https://myfigurecollection.net/item/${figura.mfc_id}`}
                target="_blank"
                rel="noopener noreferrer"
                class="text-amber-700 hover:underline font-mono text-xs dark:text-amber-300"
              >
                #{figura.mfc_id} ↗
              </a>
            </div>
          )}
        </div>
      </section>
    </div>

  </main>

    {/* LIGHTBOX MODIFICADO PARA TAMAÑO 100% Y ADMITIR SCROLL SI SUPERA LA PANTALLA */}
    <div 
      id="lightbox" 
      class="hidden fixed inset-0 z-50 overflow-auto bg-black/95 p-4 cursor-zoom-out flex"
    >
      <button class="fixed top-4 right-4 text-zinc-900 text-4xl font-light active:scale-95 z-50 bg-white/80 rounded-full w-12 h-12 flex items-center justify-center dark:text-white dark:bg-black/40" aria-label="Cerrar modal">&times;</button>
      <img 
        id="lightbox-img" 
        class="max-w-none max-h-none rounded-lg shadow-2xl m-auto" 
        src="" 
        alt="Visualización a pantalla completa" 
      />
    </div>

<script>
  const fotoPrincipal = document.getElementById("foto-principal") as HTMLImageElement | null;
  const miniaturas = document.querySelectorAll(".foto-miniatura");
  
  const lightbox = document.getElementById("lightbox");
  const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement | null;

  if (fotoPrincipal && lightbox && lightboxImg) {
    fotoPrincipal.addEventListener("click", () => {
      lightboxImg.src = fotoPrincipal.src; 
      lightbox.classList.remove("hidden"); 
      document.body.classList.add("overflow-hidden"); 
    });
  }

 // 2. CERRAR EL LIGHTBOX: Al pulsar en cualquier parte del fondo negro
  lightbox?.addEventListener("click", () => {
    lightbox.classList.add("hidden");
    document.body.classList.remove("overflow-hidden");
  });
  
	  // 2b. CERRAR CON LA TECLA ESCAPE
	document.addEventListener("keydown", (event) => {
	  if (event.key === "Escape" && lightbox && !lightbox.classList.contains("hidden")) {
		lightbox.classList.add("hidden");
		document.body.classList.remove("overflow-hidden");
	  }
	});

  if (fotoPrincipal && miniaturas.length > 0) {
    (miniaturas[0] as HTMLElement).classList.replace("opacity-60", "opacity-100");

    miniaturas.forEach((miniatura) => {
      miniatura.addEventListener("click", () => {
        const nuevaUrl = miniatura.getAttribute("data-src");
        if (nuevaUrl) {
          fotoPrincipal.src = nuevaUrl;
          
          miniaturas.forEach((m) => m.classList.replace("opacity-100", "opacity-60"));
          miniatura.classList.replace("opacity-60", "opacity-100");
        }
      });
    });
  }
</script>
</BaseLayout>