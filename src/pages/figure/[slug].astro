---
import BaseLayout from "../../components/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import BackLink from "../../components/BackLink.astro";
import CollectionNav from "../../components/CollectionNav.astro";
import { getCatalog, getTagsForFigure } from "../../lib/catalogCache";
import { createSlug } from "../../lib/slug";
import { sortFigures } from "../../lib/sortFigures";
import { getFigurePhotos } from "../../lib/figurePhotos";
import { getLineLabel, getFigureAttributes, getAttributeLabel } from "../../lib/figureTaxonomy";
import { figureMeta, addImage, absoluteImageUrl, figureSchema, breadcrumbSchema } from "../../lib/seo";

export async function getStaticPaths() {
  const { figures } = await getCatalog();

  // Same fallback as figure links (FigureCard, index cards, seo.ts):
  // figures without a slug get a page at /figure/<id> so links never 404.
  return figures.map((fig: any) => ({
    params: { slug: String(fig.slug ?? fig.id) },
  }));
}

const { slug } = Astro.params;

const { figures, figureTags } = await getCatalog();
const figure = figures.find((f: any) => String(f.slug ?? f.id) === slug);

if (!figure) {
  return Astro.redirect("/404");
}

const tags = getTagsForFigure(figure.id, figureTags);

const sortedFigures = sortFigures(figures);
const currentIndex = sortedFigures.findIndex((f: any) => f.id === figure.id);
const prevFigure = currentIndex > 0 ? sortedFigures[currentIndex - 1] : null;
const nextFigure = currentIndex >= 0 && currentIndex < sortedFigures.length - 1 ? sortedFigures[currentIndex + 1] : null;

const figureHref = (fig: any) => `/figure/${String(fig.slug ?? fig.id)}/`;

const photos = getFigurePhotos(figure);
const attributes = getFigureAttributes(figure);

const collection = figure.releases?.collections;
const release = figure.releases;
const collectionSlug = collection ? createSlug(collection.name) : "";
const releaseSlug = release?.name ? createSlug(release.name) : String(release?.number ?? "");

function releaseLabel(release: any): string {
  const number = release.number;
  const name = release.name;

  if (number != null && !name) return `Release ${number}`;
  if (!number && name) return name;
  if (number != null && name) return `Release ${number} - ${name}`;
  return "Release";
}

const breadcrumbItems = [];
if (collection) {
  breadcrumbItems.push({ label: collection.name, href: `/collection/${collectionSlug}/` });
  if (release) {
    breadcrumbItems.push({ label: releaseLabel(release), href: `/collection/${collectionSlug}/release/${releaseSlug}/` });
  }
}
breadcrumbItems.push({ label: figure.pokemon?.full_names?.es });

const siteUrl = Astro.site?.toString() || "https://example.com";
const mainImage = photos.length > 0 ? absoluteImageUrl(siteUrl, photos[0]) : undefined;
const imageDomain = photos.length > 0 && photos[0].startsWith("http") ? new URL(photos[0]).hostname : undefined;
const baseMeta = figureMeta(figure, siteUrl);
const seo = mainImage ? addImage(baseMeta, mainImage) : baseMeta;
const schemas = [
  figureSchema(figure, siteUrl, mainImage),
  breadcrumbSchema(breadcrumbItems, siteUrl),
];
---

<BaseLayout title={seo.title} description={seo.description} seo={seo} schemas={schemas} preconnectDomains={imageDomain ? [imageDomain] : []}>
  <main class="mx-auto min-h-screen w-full max-w-6xl px-4 pb-12 pt-4 sm:px-6 lg:px-8">

    <header class="mb-4 flex items-center justify-between border-b border-zinc-200 pb-4 dark:border-zinc-800">
      <BackLink href="/" text="Back to catalogue" />
    </header>

    <Breadcrumb items={breadcrumbItems} />

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-12 lg:gap-10">
      {/* Photo gallery */}
      <section class="lg:col-span-5 lg:sticky lg:top-4 lg:self-start space-y-3">
        {photos.length > 0 ? (
          <>
            <div class="overflow-hidden rounded-xl border border-zinc-200 bg-white aspect-square shadow-xl shadow-zinc-900/10 cursor-zoom-in dark:border-zinc-800 dark:bg-zinc-900 dark:shadow-black/20">
              <img
                id="main-photo"
                class="h-full w-full object-cover"
                src={photos[0]}
                alt={figure.pokemon?.full_names?.es}
                fetchpriority="high"
                decoding="async"
              />
            </div>
            {photos.length > 1 && (
              <div class="grid grid-cols-5 gap-2">
                {photos.map((url: string, index: number) => (
                  <div class="overflow-hidden rounded-lg border border-zinc-200 bg-white aspect-square dark:border-zinc-800 dark:bg-zinc-900">
                    <img
                      class="thumbnail-photo h-full w-full object-cover opacity-60 hover:opacity-100 transition cursor-pointer"
                      src={url}
                      alt={`Photo ${index + 1} of ${figure.pokemon?.full_names?.es}`}
                      data-src={url}
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                ))}
              </div>
            )}
          </>
        ) : (
          <div class="grid aspect-square place-items-center rounded-xl border border-dashed border-zinc-300 bg-zinc-100 text-sm font-bold text-zinc-400 dark:border-zinc-800 dark:bg-zinc-900 dark:text-zinc-600">
            No images available
          </div>
        )}
      </section>

      {/* Figure information */}
      <section class="lg:col-span-7 space-y-5">
        <div>
          <p class="text-xs font-bold uppercase tracking-[0.2em] text-amber-600 dark:text-amber-300">
            #{String(figure.pokemon?.pokedex_number).padStart(4, "0")} · Gen {figure.pokemon?.generation}
          </p>
          <h1 class="mt-1 text-3xl font-bold text-zinc-900 tracking-tight sm:text-4xl dark:text-white">{figure.pokemon?.full_names?.es}</h1>
          <p class="mt-2 inline-block rounded-md bg-zinc-200 px-2.5 py-1 text-sm font-bold text-zinc-700 border border-zinc-300 dark:bg-zinc-800 dark:text-zinc-300 dark:border-zinc-700">
            {getLineLabel(figure.line)}
          </p>
        </div>

        <CollectionNav figure={figure} />

        {attributes.length > 0 && (
          <div class="flex flex-wrap gap-1.5">
            {attributes.map((attr: string) => (
              <a href={`/attribute/${createSlug(attr)}/`} class="rounded-full bg-amber-100 border border-amber-300/60 px-3 py-0.5 text-xs font-semibold text-amber-800 hover:bg-amber-200/70 transition dark:bg-amber-300/10 dark:border-amber-300/30 dark:text-amber-300 dark:hover:bg-amber-300/20">
                {getAttributeLabel(attr)}
              </a>
            ))}
          </div>
        )}

        {tags.length > 0 && (
          <div class="flex flex-wrap gap-1.5">
            {tags.map((tag: any) => (
              <span class="rounded-full bg-purple-100 border border-purple-300/60 px-3 py-0.5 text-xs font-semibold text-purple-800 dark:bg-purple-300/10 dark:border-purple-300/30 dark:text-purple-300">
                🏷️ {tag.name}
              </span>
            ))}
          </div>
        )}

        {figure.details && (
          <div class="rounded-xl border border-zinc-200 bg-white p-4 shadow-inner dark:border-zinc-800 dark:bg-zinc-900">
            <h3 class="text-xs font-semibold uppercase tracking-wider text-zinc-500 dark:text-zinc-500">Piece details</h3>
            <p class="mt-2 text-base text-zinc-700 leading-relaxed dark:text-zinc-300">{figure.details}</p>
          </div>
        )}

        <div class="rounded-xl border border-zinc-200 bg-zinc-50/70 p-4 space-y-3 dark:border-zinc-800 dark:bg-zinc-900/40">
          <div class="flex justify-between items-center text-sm border-b border-zinc-200/80 pb-2 dark:border-zinc-800/60">
            <span class="text-zinc-500 font-medium dark:text-zinc-500">Release year</span>
            <span class="text-zinc-800 font-semibold dark:text-zinc-200">{figure.year ?? "Unknown"}</span>
          </div>

          {figure.mfc_id && (
            <div class="flex justify-between items-center text-sm">
              <span class="text-zinc-500 font-medium dark:text-zinc-500">MyFigureCollection</span>
              <a
                href={`https://myfigurecollection.net/item/${figure.mfc_id}`}
                target="_blank"
                rel="noopener noreferrer"
                class="text-amber-700 hover:underline font-mono text-xs dark:text-amber-300"
              >
                #{figure.mfc_id} ↗
              </a>
            </div>
          )}
        </div>
      </section>
    </div>

    {/* Previous / next figure navigation */}
    <nav class="mt-10 grid grid-cols-2 gap-4 border-t border-zinc-200 pt-6 dark:border-zinc-800" aria-label="Figure navigation">
      <div class="flex justify-start">
        {prevFigure ? (
          <a
            href={figureHref(prevFigure)}
            class="group inline-flex max-w-full items-center gap-2 rounded-lg border border-zinc-300/80 bg-white/60 px-4 py-3 text-sm font-semibold text-zinc-700 shadow-sm backdrop-blur-sm transition hover:border-zinc-400 hover:bg-zinc-100 hover:text-zinc-900 dark:border-zinc-700/80 dark:bg-zinc-900/60 dark:text-zinc-300 dark:hover:border-zinc-500 dark:hover:bg-zinc-800 dark:hover:text-white"
          >
            <span aria-hidden="true">←</span>
            <span class="truncate">
              <span class="block text-xs font-medium uppercase tracking-wider text-zinc-500 dark:text-zinc-500">Previous</span>
              <span class="block truncate">{prevFigure.pokemon?.full_names?.es}</span>
            </span>
          </a>
        ) : (
          <span class="inline-flex items-center gap-2 rounded-lg border border-zinc-200/60 bg-zinc-100/40 px-4 py-3 text-sm font-semibold text-zinc-400 dark:border-zinc-800/60 dark:bg-zinc-900/40 dark:text-zinc-600">
            <span aria-hidden="true">←</span>
            Previous
          </span>
        )}
      </div>
      <div class="flex justify-end">
        {nextFigure ? (
          <a
            href={figureHref(nextFigure)}
            class="group inline-flex max-w-full items-center gap-2 rounded-lg border border-zinc-300/80 bg-white/60 px-4 py-3 text-sm font-semibold text-zinc-700 shadow-sm backdrop-blur-sm transition hover:border-zinc-400 hover:bg-zinc-100 hover:text-zinc-900 dark:border-zinc-700/80 dark:bg-zinc-900/60 dark:text-zinc-300 dark:hover:border-zinc-500 dark:hover:bg-zinc-800 dark:hover:text-white"
          >
            <span class="truncate text-right">
              <span class="block text-xs font-medium uppercase tracking-wider text-zinc-500 dark:text-zinc-500">Next</span>
              <span class="block truncate">{nextFigure.pokemon?.full_names?.es}</span>
            </span>
            <span aria-hidden="true">→</span>
          </a>
        ) : (
          <span class="inline-flex items-center gap-2 rounded-lg border border-zinc-200/60 bg-zinc-100/40 px-4 py-3 text-sm font-semibold text-zinc-400 dark:border-zinc-800/60 dark:bg-zinc-900/40 dark:text-zinc-600">
            Next
            <span aria-hidden="true">→</span>
          </span>
        )}
      </div>
    </nav>

  </main>

    {/* Lightbox */}
    <div
      id="lightbox"
      class="hidden fixed inset-0 z-50 overflow-hidden bg-black/95 cursor-zoom-out"
    >
      <button class="fixed top-4 right-4 text-zinc-900 text-4xl font-light active:scale-95 z-50 bg-white/80 rounded-full w-12 h-12 flex items-center justify-center dark:text-white dark:bg-black/40" aria-label="Close modal">&times;</button>
      <img
        id="lightbox-img"
        class="h-full w-full rounded-lg object-none object-center shadow-2xl"
        src=""
        alt="Full screen view"
      />
    </div>

<script>
  const mainPhoto = document.getElementById("main-photo") as HTMLImageElement | null;
  const thumbnails = document.querySelectorAll(".thumbnail-photo");
  
  const lightbox = document.getElementById("lightbox");
  const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement | null;

  if (mainPhoto && lightbox && lightboxImg) {
    mainPhoto.addEventListener("click", () => {
      lightboxImg.src = mainPhoto.src;
      lightbox.classList.remove("hidden");
      document.body.classList.add("overflow-hidden");
    });
  }

  // Close lightbox when clicking the dark background
  lightbox?.addEventListener("click", () => {
    lightbox.classList.add("hidden");
    document.body.classList.remove("overflow-hidden");
  });
  
  // Close with Escape key
  document.addEventListener("keydown", (event) => {
    if (event.key === "Escape" && lightbox && !lightbox.classList.contains("hidden")) {
      lightbox.classList.add("hidden");
      document.body.classList.remove("overflow-hidden");
    }
  });

  if (mainPhoto && thumbnails.length > 0) {
    (thumbnails[0] as HTMLElement).classList.replace("opacity-60", "opacity-100");

    thumbnails.forEach((thumbnail) => {
      thumbnail.addEventListener("click", () => {
        const newUrl = thumbnail.getAttribute("data-src");
        if (newUrl) {
          mainPhoto.src = newUrl;
          
          thumbnails.forEach((t) => t.classList.replace("opacity-100", "opacity-60"));
          thumbnail.classList.replace("opacity-60", "opacity-100");
        }
      });
    });
  }
</script>
</BaseLayout>