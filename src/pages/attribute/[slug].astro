---
import BaseLayout from "../../components/BaseLayout.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import BackLink from "../../components/BackLink.astro";
import FigureCard from "../../components/FigureCard.astro";
import EmptyState from "../../components/EmptyState.astro";
import { getCatalog, getTagsForFigure } from "../../lib/catalogCache";
import { createSlug } from "../../lib/slug";
import { getAttributeLabel } from "../../lib/figureTaxonomy";
import { attributeMeta, breadcrumbSchema } from "../../lib/seo";

export async function getStaticPaths() {
  const { figures } = await getCatalog();

  const uniqueAttributes = new Set<string>();
  figures.forEach((fig: any) => {
    if (fig?.is_shiny) uniqueAttributes.add("shiny");
    if (fig?.is_clear) uniqueAttributes.add("clear");
    if (fig?.is_pearl) uniqueAttributes.add("brillante");
    if (fig?.has_base) uniqueAttributes.add("con-base");
  });

  return Array.from(uniqueAttributes).map((attribute) => ({
    params: { slug: createSlug(attribute) },
  }));
}

const { slug } = Astro.params;

const attributesMap: { [key: string]: { value: string, column: string } } = {
  "brillante": { value: "brillante", column: "is_pearl" },
  "shiny": { value: "shiny", column: "is_shiny" },
  "clear": { value: "clear", column: "is_clear" },
  "con-base": { value: "con-base", column: "has_base" }
};

const attributeInfo = attributesMap[slug] || Object.values(attributesMap).find(v => createSlug(v.value) === slug);

if (!attributeInfo) {
  return Astro.redirect("/404");
}

const { figures, figureTags } = await getCatalog();

const attributeFigures = figures
  .filter((f: any) => f[attributeInfo.column] === true)
  .sort((a: any, b: any) => (a.visual_order ?? 0) - (b.visual_order ?? 0));

const figuresWithTags = attributeFigures.map((f: any) => ({
  ...f,
  tags: getTagsForFigure(f.id, figureTags)
}));

const siteUrl = Astro.site?.toString() || "https://example.com";
const attributeLabel = getAttributeLabel(attributeInfo.value);
const breadcrumbItems = [{ label: attributeLabel }];
const seo = attributeMeta(attributeLabel, slug, figuresWithTags.length, siteUrl);
const schemas = breadcrumbSchema(breadcrumbItems, siteUrl);
---

<BaseLayout title={seo.title} description={seo.description} seo={seo} schemas={schemas}>
  <main class="mx-auto min-h-screen w-full max-w-7xl px-4 pb-24 pt-5 sm:px-6 lg:px-8">

    <Breadcrumb items={breadcrumbItems} />

    <header class="mb-5 flex flex-col gap-4 sm:mb-8 sm:flex-row sm:items-end sm:justify-between">
      <div class="space-y-2">
        <BackLink href="/" text="Back to catalogue" />
        <h1 class="max-w-3xl text-4xl font-semibold leading-tight text-zinc-900 sm:text-6xl dark:text-white">
          {getAttributeLabel(attributeInfo.value)}
        </h1>
        <p class="max-w-2xl text-sm leading-6 text-zinc-600 sm:text-base dark:text-zinc-400">
          {figuresWithTags.length} figures with this attribute
        </p>
      </div>
    </header>

    {/* Figures with this attribute */}
    <section>
      {figuresWithTags.length > 0 ? (
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 sm:gap-4 lg:grid-cols-4">
          {figuresWithTags.map((fig: any) => (
            <FigureCard figure={fig} showCollection />
          ))}
        </div>
      ) : (
        <EmptyState message="No figures with this attribute." />
      )}
    </section>

  </main>
</BaseLayout>
