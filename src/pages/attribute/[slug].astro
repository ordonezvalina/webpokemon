---
import BaseLayout from "../../components/BaseLayout.astro";
import BackLink from "../../components/BackLink.astro";
import FigureCard from "../../components/FigureCard.astro";
import EmptyState from "../../components/EmptyState.astro";
import { getCatalog, getTagsForFigure } from "../../lib/catalogCache";
import { createSlug } from "../../lib/slug";
import { getAtributoLabel } from "../../lib/figureTaxonomy";

export async function getStaticPaths() {
  const { figures } = await getCatalog();

  const atributosUnicos = new Set<string>();
  figures.forEach((figura: any) => {
    if (figura?.is_shiny) atributosUnicos.add("shiny");
    if (figura?.is_clear) atributosUnicos.add("clear");
    if (figura?.is_pearl) atributosUnicos.add("brillante");
    if (figura?.has_base) atributosUnicos.add("con-base");
  });

  return Array.from(atributosUnicos).map((atributo) => ({
    params: { slug: createSlug(atributo) },
  }));
}

const { slug } = Astro.params;

const atributosMap: { [key: string]: { valor: string, columna: string } } = {
  "brillante": { valor: "brillante", columna: "is_pearl" },
  "shiny": { valor: "shiny", columna: "is_shiny" },
  "clear": { valor: "clear", columna: "is_clear" },
  "con-base": { valor: "con-base", columna: "has_base" }
};

const atributoInfo = atributosMap[slug] || Object.values(atributosMap).find(v => createSlug(v.valor) === slug);

if (!atributoInfo) {
  return Astro.redirect("/404");
}

const { figures, figureTags } = await getCatalog();

const figuras = figures
  .filter((f: any) => f[atributoInfo.columna] === true)
  .sort((a: any, b: any) => (a.visual_order ?? 0) - (b.visual_order ?? 0));

const figurasConEtiquetas = figuras.map((f: any) => ({
  ...f,
  etiquetas: getTagsForFigure(f.id, figureTags)
}));
---

<BaseLayout title={`${getAtributoLabel(atributoInfo.valor)} | Mi Colección`}>
  <main class="mx-auto min-h-screen w-full max-w-7xl px-4 pb-24 pt-5 sm:px-6 lg:px-8">

    <header class="mb-5 flex flex-col gap-4 sm:mb-8 sm:flex-row sm:items-end sm:justify-between">
      <div class="space-y-2">
        <BackLink href="/" text="Volver al catálogo" />
        <h1 class="max-w-3xl text-4xl font-semibold leading-tight text-white sm:text-6xl">
          {getAtributoLabel(atributoInfo.valor)}
        </h1>
        <p class="max-w-2xl text-sm leading-6 text-zinc-400 sm:text-base">
          {figurasConEtiquetas.length} figuras con este atributo
        </p>
      </div>
    </header>

    {/* Figuras con este atributo */}
    <section>
      {figurasConEtiquetas.length > 0 ? (
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-3 sm:gap-4 lg:grid-cols-4 xl:grid-cols-5">
          {figurasConEtiquetas.map((figura: any) => (
            <FigureCard figure={figura} showCollection />
          ))}
        </div>
      ) : (
        <EmptyState message="No hay figuras con este atributo." />
      )}
    </section>

  </main>
</BaseLayout>
