---
import { createSlug } from "../lib/slug";
import { getLineaLabel, getFigureAtributos, getAtributoLabel } from "../lib/figureTaxonomy";

interface Props {
  figure: any;
  linkAttributes?: boolean;
  limit?: number;
}

const { figure, linkAttributes = false, limit = 3 } = Astro.props;
const allAtributos = getFigureAtributos(figure);
const lineaBadge = {
  label: getLineaLabel(figure.line),
  class: "rounded-md border border-zinc-600 bg-zinc-700/60 px-1.5 py-0.5 text-[10px] font-bold text-zinc-300"
};
const visibleAtributos = allAtributos.slice(0, Math.max(0, limit - 1));
const overflowCount = allAtributos.length - visibleAtributos.length;

function getAtributoClass(atributo: string): string {
  const atributoClasses: { [key: string]: string } = {
    brillante: "border-fuchsia-300/50 bg-fuchsia-300/12 text-fuchsia-100",
    shiny: "border-amber-300/60 bg-amber-300/14 text-amber-100",
    clear: "border-cyan-300/50 bg-cyan-300/12 text-cyan-100",
    mega: "border-rose-300/55 bg-rose-300/12 text-rose-100",
    "con-base": "border-emerald-300/55 bg-emerald-300/12 text-emerald-100"
  };
  return atributoClasses[atributo] || "border-indigo-300/50 bg-indigo-300/12 text-indigo-100";
}

function baseClass(atributo: string): string {
  return `rounded-md border px-1.5 py-0.5 text-[10px] font-bold ${getAtributoClass(atributo)}`;
}
---

<div class="flex flex-wrap items-center gap-1">
  <span class={lineaBadge.class}>{lineaBadge.label}</span>
  {visibleAtributos.map((atributo: string) => {
    const label = getAtributoLabel(atributo);
    const classes = baseClass(atributo) + (linkAttributes ? " hover:opacity-80 transition" : "");
    return linkAttributes ? (
      <a href={`/attribute/${createSlug(atributo)}`} class={classes}>{label}</a>
    ) : (
      <span class={classes}>{label}</span>
    );
  })}
  {overflowCount > 0 && (
    <span class="rounded-md border border-zinc-700 bg-zinc-800/60 px-1.5 py-0.5 text-[10px] font-bold text-zinc-400">
      +{overflowCount}
    </span>
  )}
</div>
