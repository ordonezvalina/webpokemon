---
import { getLineLabel } from "../lib/figureTaxonomy";

interface Props {
  collection: any;
  collectionSlug: string;
  figureCount: number;
  releaseCount: number;
  coverImage?: string;
  dateLabel?: string | null;
  lines: string[];
}

const { collection, collectionSlug, figureCount, releaseCount, coverImage, dateLabel, lines } = Astro.props;
---

<a
  href={`/collection/${collectionSlug}/`}
  class="group flex h-full flex-col overflow-hidden rounded-2xl border border-zinc-200/80 bg-white shadow-lg shadow-zinc-900/10 transition-all duration-300 hover:-translate-y-1 hover:border-zinc-400 hover:shadow-xl hover:shadow-zinc-900/10 dark:border-zinc-800/50 dark:bg-zinc-900 dark:shadow-black/40 dark:hover:border-zinc-600 dark:hover:shadow-amber-500/5"
>
  <div class="relative aspect-[4/3] overflow-hidden bg-zinc-100 dark:bg-zinc-800/50">
    {coverImage ? (
      <img
        class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.03]"
        src={coverImage}
        alt={`Cover of ${collection.name}`}
        loading="lazy"
        decoding="async"
      />
    ) : (
      <div class="grid h-full w-full place-items-center bg-zinc-100 text-sm font-semibold text-zinc-400 dark:bg-zinc-800/50 dark:text-zinc-600">
        {collection.name}
      </div>
    )}
  </div>

  <div class="flex flex-1 flex-col gap-3 border-t border-zinc-200/80 bg-white/90 p-4 dark:border-zinc-800/60 dark:bg-zinc-900/90">
    <h2 class="text-lg font-semibold leading-tight text-zinc-900 dark:text-white">
      {collection.name}
    </h2>

    {dateLabel && (
      <p class="flex items-center gap-1.5 text-sm font-medium text-zinc-600 dark:text-zinc-400">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>
        <span>{dateLabel}</span>
      </p>
    )}

    <p class="text-sm text-zinc-500 dark:text-zinc-500">
      {figureCount} figure{figureCount === 1 ? "" : "s"}
      {releaseCount > 0 && (
        <span> · {releaseCount} release{releaseCount === 1 ? "" : "s"}</span>
      )}
    </p>

    {lines.length > 0 && (
      <div class="mt-auto flex flex-wrap gap-1.5 pt-1">
        {lines.map((line) => (
          <span class="inline-block rounded-full bg-zinc-100 px-2.5 py-0.5 text-xs font-semibold text-zinc-700 dark:bg-zinc-800 dark:text-zinc-300">
            {getLineLabel(line)}
          </span>
        ))}
      </div>
    )}
  </div>
</a>
