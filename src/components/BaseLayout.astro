---
import "../styles/global.css";
import type { SeoMeta } from "../lib/seo";
import JsonLd from "./JsonLd.astro";
import ThemeToggle from "./ThemeToggle.astro";

interface Props {
  title: string;
  description?: string;
  seo?: SeoMeta;
  schemas?: Record<string, any> | Record<string, any>[];
  preconnectDomains?: string[];
  showThemeToggle?: boolean;
}

const { title, description, seo, schemas, preconnectDomains = [], showThemeToggle = true } = Astro.props;

const pageTitle = seo?.title ?? title;
const pageDescription = seo?.description ?? description ?? "";
const canonical = seo?.canonical ?? Astro.url.href;
const og = seo?.og;
const twitter = seo?.twitter;

const siteUrl = Astro.site?.toString() ?? "";
const defaultOgImage = siteUrl ? `${siteUrl.replace(/\/$/, "")}/og-default.svg` : undefined;
const ogImage = og?.image ?? defaultOgImage;
const twitterImage = twitter?.image ?? defaultOgImage;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="color-scheme" content="light dark" />
    <meta name="theme-color" content="#111111" id="theme-color-meta" />
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme");
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const isDark = stored ? stored === "dark" : prefersDark;
        if (isDark) {
          document.documentElement.classList.add("dark");
        } else {
          document.documentElement.classList.remove("dark");
        }
        const meta = document.getElementById("theme-color-meta");
        if (meta) {
          meta.setAttribute("content", isDark ? "#111111" : "#fafafa");
        }
      })();
    </script>
    <title>{pageTitle}</title>
    {pageDescription && <meta name="description" content={pageDescription} />}
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:title" content={og?.title ?? pageTitle} />
    <meta property="og:description" content={og?.description ?? pageDescription} />
    <meta property="og:type" content={og?.type ?? "website"} />
    <meta property="og:url" content={og?.url ?? canonical} />
    <meta property="og:locale" content="es_ES" />
    {ogImage && <meta property="og:image" content={ogImage} />}

    <!-- Twitter Cards -->
    <meta name="twitter:card" content={twitter?.card ?? "summary_large_image"} />
    <meta name="twitter:title" content={twitter?.title ?? pageTitle} />
    <meta name="twitter:description" content={twitter?.description ?? pageDescription} />
    {twitterImage && <meta name="twitter:image" content={twitterImage} />}

    {preconnectDomains.map((domain) => (
      <>
        <link rel="preconnect" href={`https://${domain}`} />
        <link rel="dns-prefetch" href={`https://${domain}`} />
      </>
    ))}

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    {schemas && <JsonLd schema={schemas} />}
  </head>
  <body class="antialiased">
    {showThemeToggle && (
      <div class="fixed top-3 right-3 z-50 sm:top-4 sm:right-4">
        <ThemeToggle />
      </div>
    )}
    <slot />
  </body>
</html>
