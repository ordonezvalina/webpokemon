---
import { getFigurePhotos } from "../lib/figurePhotos";
import FigureBadges from "./FigureBadges.astro";

interface Props {
  figure: any;
  showVolume?: boolean;
  showCollection?: boolean;
}

const { figure, showVolume = false, showCollection = false } = Astro.props;
const fotos = getFigurePhotos(figure);

const hasMeta = figure.year || (showCollection && figure.volumes?.collections) || (showVolume && figure.volumes);
---

<a
  href={`/figure/${figure.slug ?? figure.id}`}
  class="group flex h-full flex-col overflow-hidden rounded-xl border border-zinc-800/50 bg-zinc-900/60 shadow-lg shadow-black/50 backdrop-blur-md transition-all duration-300 hover:-translate-y-1 hover:border-zinc-600 hover:shadow-xl hover:shadow-amber-500/5"
>
  <div class="relative aspect-square overflow-hidden bg-zinc-800/50">
    {fotos.length > 0 ? (
      <img
        class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.03]"
        src={fotos[0]}
        alt={figure.pokemon?.full_names?.es}
        loading="lazy"
        decoding="async"
      />
    ) : (
      <div class="grid h-full w-full place-items-center bg-zinc-800/50 text-sm font-semibold text-zinc-500">
        #{String(figure.pokemon?.pokedex_number).padStart(4, "0")}
      </div>
    )}
    <span class="absolute top-2 right-2 rounded-md bg-black/60 px-1.5 py-0.5 font-mono text-[10px] text-zinc-300 backdrop-blur-sm">
      #{String(figure.pokemon?.pokedex_number).padStart(4, "0")}
    </span>
  </div>
  <div class="flex min-h-[4.5rem] flex-col gap-2 border-t border-zinc-800/60 bg-zinc-900/80 p-3">
    <h2 class="truncate text-sm font-semibold leading-tight text-white sm:text-base">
      {figure.pokemon?.full_names?.es || `Figura #${String(figure.pokemon?.pokedex_number).padStart(4, "0")}`}
    </h2>
    {hasMeta && (
      <p class="truncate text-xs font-medium text-zinc-500">
        {figure.year && <span>{figure.year}</span>}
        {showCollection && figure.volumes?.collections && (
          <>
            {figure.year && <span> · </span>}
            {figure.volumes.collections.name}
            {` · Vol. ${figure.volumes.volume}${figure.volumes.name_eng ? ` · ${figure.volumes.name_eng}` : ""}`}
          </>
        )}
        {showVolume && figure.volumes && !showCollection && (
          <>
            {figure.year && <span> · </span>}
            {`Vol. ${figure.volumes.volume}${figure.volumes.name_eng ? ` · ${figure.volumes.name_eng}` : ""}`}
          </>
        )}
      </p>
    )}
    <FigureBadges figure={figure} limit={3} />
  </div>
</a>
