---
import { getFigurePhotos } from "../lib/figurePhotos";
import FigureBadges from "./FigureBadges.astro";

interface Props {
  figure: any;
  showRelease?: boolean;
  showCollection?: boolean;
}

function releaseLabel(release: any): string {
  const number = release.number;
  const name = release.name;

  if (number != null && !name) return `Release ${number}`;
  if (!number && name) return name;
  if (number != null && name) return `Release ${number} - ${name}`;
  return "Release";
}

const { figure, showRelease = false, showCollection = false } = Astro.props;
const photos = getFigurePhotos(figure);

const hasMeta = figure.year || (showCollection && figure.releases?.collections) || (showRelease && figure.releases);
---

<a
  href={`/figure/${figure.slug ?? figure.id}/`}
  class="group flex h-full flex-col overflow-hidden rounded-xl border border-zinc-200/80 bg-white/80 shadow-lg shadow-zinc-900/10 backdrop-blur-md transition-all duration-300 hover:-translate-y-1 hover:border-zinc-400 hover:shadow-xl hover:shadow-zinc-900/10 dark:border-zinc-800/50 dark:bg-zinc-900/60 dark:shadow-black/50 dark:hover:border-zinc-600 dark:hover:shadow-amber-500/5"
>
  <div class="relative aspect-square overflow-hidden bg-zinc-100 dark:bg-zinc-800/50">
    {photos.length > 0 ? (
      <img
        class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.03]"
        src={photos[0]}
        alt={figure.pokemon?.full_names?.es}
        loading="lazy"
        decoding="async"
      />
    ) : (
      <div class="grid h-full w-full place-items-center bg-zinc-100 text-sm font-semibold text-zinc-400 dark:bg-zinc-800/50 dark:text-zinc-500">
        #{String(figure.pokemon?.pokedex_number).padStart(4, "0")}
      </div>
    )}
    <span class="absolute top-2 right-2 rounded-md bg-black/60 px-1.5 py-0.5 font-mono text-xs text-white backdrop-blur-sm dark:bg-black/60 dark:text-zinc-300">
      #{String(figure.pokemon?.pokedex_number).padStart(4, "0")}
    </span>
  </div>
  <div class="flex min-h-[4.5rem] flex-col gap-2 border-t border-zinc-200/80 bg-white/90 p-3 dark:border-zinc-800/60 dark:bg-zinc-900/80">
    <h2 class="truncate text-sm font-semibold leading-tight text-zinc-900 sm:text-base dark:text-white">
      {figure.pokemon?.full_names?.es || `Figure #${String(figure.pokemon?.pokedex_number).padStart(4, "0")}`}
    </h2>
    {hasMeta && (
      <p class="truncate text-xs font-medium text-zinc-500 dark:text-zinc-500">
        {figure.year && <span>{figure.year}</span>}
        {showCollection && figure.releases?.collections && (
          <>
            {figure.year && <span> · </span>}
            {figure.releases.collections.name}
            {` · ${releaseLabel(figure.releases)}`}
          </>
        )}
        {showRelease && figure.releases && !showCollection && (
          <>
            {figure.year && <span> · </span>}
            {releaseLabel(figure.releases)}
          </>
        )}
      </p>
    )}
    <FigureBadges figure={figure} limit={3} />
  </div>
</a>
