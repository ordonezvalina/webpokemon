---
import { createSlug } from "../lib/slug";
import { getFigurePhotos } from "../lib/figurePhotos";
import { getFigureAtributos } from "../lib/figureTaxonomy";
import FigureBadges from "./FigureBadges.astro";

interface Props {
  figure: any;
  linkAttributes?: boolean;
  showVolume?: boolean;
  showCollection?: boolean;
}

const { figure, linkAttributes = false, showVolume = false, showCollection = false } = Astro.props;
const fotos = getFigurePhotos(figure);
---

<a
  href={`/figure/${figure.slug ?? figure.id}`}
  class="group block overflow-hidden rounded-lg border border-zinc-800 bg-zinc-900 shadow-lg shadow-black/20 transition duration-300 hover:-translate-y-0.5 hover:border-zinc-600"
>
  <div class="aspect-[4/5] overflow-hidden bg-zinc-800">
    {fotos.length > 0 ? (
      <img
        class="h-full w-full object-cover transition duration-300 group-hover:scale-[1.03]"
        src={fotos[0]}
        alt={figure.pokemon?.full_names?.es}
        loading="lazy"
      />
    ) : (
      <div class="grid h-full w-full place-items-center bg-zinc-800 text-sm font-semibold text-zinc-500">
        #{String(figure.pokemon?.pokedex_number).padStart(4, "0")}
      </div>
    )}
  </div>
  <div class="space-y-3 p-3">
    <div class="flex items-start justify-between gap-2">
      <div class="min-w-0">
        <h2 class="truncate text-sm font-semibold text-white sm:text-base">{figure.pokemon?.full_names?.es}</h2>
        {figure.year && <p class="mt-1 text-xs font-medium text-zinc-500">{figure.year}</p>}
        {showCollection && figure.volumes?.collections && (
          <p class="mt-1 text-xs font-medium text-zinc-500">
            <a href={`/collection/${createSlug(figure.volumes.collections.name)}`} class="hover:text-zinc-300 transition">
              {figure.volumes.collections.name}
            </a>
            {` · Vol. ${figure.volumes.volume}${figure.volumes.name_eng ? ` · ${figure.volumes.name_eng}` : ""}`}
          </p>
        )}
        {showVolume && figure.volumes && !showCollection && (
          <p class="mt-1 text-xs font-medium text-zinc-500">
            Vol. {figure.volumes.volume}{figure.volumes.name_eng ? ` · ${figure.volumes.name_eng}` : ""}
          </p>
        )}
      </div>
      <FigureBadges figure={figure} linkAttributes={linkAttributes} />
    </div>
    {figure.details && <p class="line-clamp-2 text-xs leading-5 text-zinc-400">{figure.details}</p>}
  </div>
</a>
