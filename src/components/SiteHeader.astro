---
import ThemeToggle from "./ThemeToggle.astro";

interface Props {
  showThemeToggle?: boolean;
}

const { showThemeToggle = true } = Astro.props;

const navLinks = [
  { label: "Home", href: "/" },
  { label: "Collections", href: "/collections" },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-40 w-full border-b border-zinc-200/80 bg-white/85 px-4 py-3 backdrop-blur-md dark:border-zinc-800/60 dark:bg-zinc-950/85 sm:px-6 lg:px-8">
  <div class="mx-auto flex max-w-7xl items-center justify-between">
    <nav aria-label="Main navigation">
      <ul class="flex items-center gap-1 sm:gap-2">
        {navLinks.map((link) => {
          const isActive = currentPath === link.href || currentPath.startsWith(`${link.href}/`);
          return (
            <li>
              <a
                href={link.href}
                class:list={[
                  "rounded-lg px-3 py-2 text-sm font-semibold transition sm:text-base",
                  isActive
                    ? "bg-zinc-100 text-zinc-900 dark:bg-zinc-800 dark:text-white"
                    : "text-zinc-600 hover:bg-zinc-100 hover:text-zinc-900 dark:text-zinc-300 dark:hover:bg-zinc-800 dark:hover:text-white"
                ]}
                aria-current={isActive ? "page" : undefined}
              >
                {link.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>

    {showThemeToggle && <ThemeToggle />}
  </div>
</header>
