---
import { createSlug } from "../lib/slug";

interface Props {
  figure: any;
}

const { figure } = Astro.props;
const coleccion = figure.volumes?.collections;
const volumen = figure.volumes;

if (!coleccion) return null;

const coleccionSlug = createSlug(coleccion.name);
const volumenSlug = volumen?.name_eng ? createSlug(volumen.name_eng) : String(volumen?.volume || "");
---

<div class="flex flex-wrap gap-1.5">
  <a
    href={`/collection/${coleccionSlug}`}
    class="inline-block rounded-full bg-emerald-300/10 border border-emerald-300/30 px-3 py-1 text-xs font-semibold text-emerald-300 hover:bg-emerald-300/20 transition"
  >
    📁 {coleccion.name}
  </a>
  <a
    href={`/collection/${coleccionSlug}/volume/${volumenSlug}`}
    class="inline-block rounded-full bg-blue-300/10 border border-blue-300/30 px-3 py-1 text-xs font-semibold text-blue-300 hover:bg-blue-300/20 transition"
  >
    📖 Vol. {volumen.volume}
    {volumen.name_eng ? ` · ${volumen.name_eng}` : ""}
  </a>
</div>
