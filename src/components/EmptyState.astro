---
interface Props {
  message: string;
}

const { message } = Astro.props;
---

<div class="rounded-lg border border-dashed border-zinc-300 bg-zinc-100/60 p-8 text-center dark:border-zinc-700 dark:bg-zinc-900/50">
  <p class="text-base font-semibold text-zinc-900 dark:text-white">{message}</p>
</div>
